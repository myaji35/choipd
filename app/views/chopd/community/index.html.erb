<% content_for :title, "커뮤니티" %>
<% content_for :description, "imPD 베타 커뮤니티 — 제품 업데이트와 회원 소식." %>

<style>
  .impd-comm-wrap { max-width: 900px; margin: 0 auto; padding: 0 40px; }
  .impd-comm-hero {
    padding: 88px 0 56px;
    border-bottom: 1px solid var(--impd-rule);
  }
  .impd-comm-eyebrow {
    font-family: var(--impd-font-mono);
    font-size: 11px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--impd-green);
    margin-bottom: 14px;
  }
  .impd-comm-title {
    font-family: var(--impd-font-display);
    font-weight: 800;
    font-size: clamp(40px, 6vw, 72px);
    letter-spacing: -0.03em;
    line-height: 1.02;
    color: var(--impd-ink);
    margin-bottom: 18px;
  }
  .impd-comm-title .accent { color: var(--impd-green); font-style: italic; font-family: var(--impd-font-serif); font-weight: 400; }
  .impd-comm-sub {
    font-size: 15px;
    color: var(--impd-muted);
    line-height: 1.7;
    max-width: 520px;
  }

  .impd-comm-section { padding: 56px 0; border-bottom: 1px solid var(--impd-rule); }
  .impd-comm-section:last-of-type { border-bottom: none; }
  .impd-comm-section-head {
    display: flex; align-items: baseline; gap: 14px;
    margin-bottom: 24px;
  }
  .impd-comm-section-head .impd-comm-eyebrow { margin-bottom: 0; }
  .impd-comm-section-head h2 {
    font-family: var(--impd-font-display);
    font-weight: 700;
    font-size: 22px;
    letter-spacing: -0.02em;
    color: var(--impd-ink);
    margin: 0;
  }

  .impd-notice-row {
    display: flex; align-items: center; gap: 14px;
    padding: 16px 18px;
    background: var(--impd-card);
    border: 1px solid var(--impd-rule);
    border-radius: 12px;
    margin-bottom: 10px;
    box-shadow: var(--impd-shadow-card);
  }
  .impd-notice-row .badge {
    flex-shrink: 0;
    background: var(--impd-green-mint);
    color: var(--impd-green);
    font-size: 10px; font-weight: 700;
    padding: 4px 10px; border-radius: 50px;
    letter-spacing: 1px;
  }
  .impd-notice-row .title { flex: 1; font-size: 14px; font-weight: 500; color: var(--impd-ink); line-height: 1.5; }
  .impd-notice-row .date { font-size: 11px; color: var(--impd-muted); white-space: nowrap; font-family: var(--impd-font-mono); letter-spacing: 0.8px; }

  .impd-empty-card {
    padding: 32px 28px;
    border: 1px dashed var(--impd-rule);
    border-radius: 16px;
    text-align: center;
    background: var(--impd-card);
  }
  .impd-empty-card .tag {
    display: inline-block;
    font-family: var(--impd-font-mono);
    font-size: 10px; letter-spacing: 1.4px; text-transform: uppercase;
    color: var(--impd-gold);
    margin-bottom: 8px;
  }
  .impd-empty-card .headline { font-size: 16px; font-weight: 600; line-height: 1.5; margin-bottom: 8px; color: var(--impd-ink); }
  .impd-empty-card .desc { font-size: 13px; color: var(--impd-muted); line-height: 1.6; }
  .impd-empty-card .cta { display: inline-block; margin-top: 16px; }

  .impd-newsletter-box {
    padding: 40px 32px;
    background: var(--impd-green-house);
    color: var(--impd-on-dark);
    border-radius: 16px;
    text-align: center;
  }
  .impd-newsletter-box .impd-comm-eyebrow { color: var(--impd-gold); }
  .impd-newsletter-box h2 {
    font-family: var(--impd-font-display);
    font-weight: 800;
    font-size: clamp(28px, 4vw, 40px);
    letter-spacing: -0.02em;
    color: var(--impd-on-dark);
    margin: 8px 0 14px;
  }
  .impd-newsletter-box p { font-size: 14px; color: var(--impd-on-dark-soft); line-height: 1.7; max-width: 460px; margin: 0 auto 24px; }
</style>

<section class="impd-comm-wrap impd-comm-hero">
  <div class="impd-comm-eyebrow">§ COMMUNITY · imPD 베타</div>
  <h1 class="impd-comm-title">
    회원 소식과 <span class="accent">제품 업데이트</span>.
  </h1>
  <p class="impd-comm-sub">
    imPD를 쓰는 분들께 보내는 공지, 기능 업데이트, 베타 초대 상태를 이곳에 모읍니다. 본격 런칭 전까지는 가볍게.
  </p>
</section>

<section class="impd-comm-wrap impd-comm-section">
  <div class="impd-comm-section-head">
    <span class="impd-comm-eyebrow">NOTICE</span>
    <h2>공지</h2>
  </div>

  <% if @notices.any? %>
    <% @notices.each do |notice| %>
      <div class="impd-notice-row">
        <span class="badge">공지</span>
        <span class="title"><%= notice.title %></span>
        <span class="date"><%= notice.created_at.strftime("%Y.%m.%d") %></span>
      </div>
    <% end %>
  <% else %>
    <div class="impd-empty-card">
      <div class="tag">BETA · 첫 공지 준비 중</div>
      <div class="headline">곧 만나요.</div>
      <div class="desc">
        imPD는 베타 기간입니다. 신규 회원 안내와 제품 업데이트가 이곳에 차례로 올라옵니다. <br/>
        먼저 받아보시려면 아래 뉴스레터로 남겨주세요.
      </div>
    </div>
  <% end %>
</section>

<section class="impd-comm-wrap impd-comm-section">
  <div class="impd-comm-section-head">
    <span class="impd-comm-eyebrow">VOICES</span>
    <h2>회원 후기</h2>
  </div>

  <% if @reviews.any? %>
    <% @reviews.each do |review| %>
      <div class="impd-notice-row">
        <span class="badge" style="background: var(--impd-gold); color: var(--impd-on-dark);">★</span>
        <span class="title"><%= review.title %> — <span style="color: var(--impd-muted); font-weight: 400;"><%= review.content.to_s.truncate(60) %></span></span>
        <span class="date"><%= review.created_at.strftime("%Y.%m.%d") %></span>
      </div>
    <% end %>
  <% else %>
    <div class="impd-empty-card">
      <div class="tag">BETA · 첫 후기 기다리는 중</div>
      <div class="headline">실제 회원의 이야기로 이 자리를 채울 예정입니다.</div>
      <div class="desc">
        imPD는 생성된 가짜 후기를 노출하지 않습니다. 먼저 페이지를 만드신 분들의 진짜 피드백으로 이 공간을 채워갈게요.
      </div>
      <a href="/auth/signup" class="impd-btn impd-btn-primary cta">내 페이지 만들기 →</a>
    </div>
  <% end %>
</section>

<section class="impd-comm-wrap impd-comm-section">
  <div class="impd-newsletter-box">
    <div class="impd-comm-eyebrow">§ NEWSLETTER</div>
    <h2>업데이트를 먼저 받아보세요.</h2>
    <p>새로운 기능, 베타 초대 확대, 회원 사례를 격주로 정리해 보내드려요. 언제든 구독 해지 가능합니다.</p>
    <%= turbo_frame_tag "newsletter-form" do %>
      <%= render "chopd/leads/form", lead: @lead %>
    <% end %>
  </div>
</section>
