<% content_for :title, "미디어 - 한국환경저널" %>

<style>
  /* ── 미디어 히어로 ─────────────────────────── */
  .media-hero {
    min-height: 56vh;
    display: flex; align-items: center; justify-content: center;
    text-align: center;
    position: relative; overflow: hidden;
    padding: 120px 48px 80px;
  }
  .media-hero::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 80% 80% at 50% 50%, rgba(168,255,62,.06) 0%, transparent 60%),
      radial-gradient(ellipse 50% 60% at 10% 70%, rgba(96,165,250,.07) 0%, transparent 55%);
  }
  .media-hero-bg {
    position: absolute;
    font-family: 'Black Han Sans', sans-serif;
    font-size: clamp(80px, 14vw, 160px);
    color: rgba(255,255,255,.022); letter-spacing: -.06em; line-height: 1;
    top: 50%; left: 50%; transform: translate(-50%,-50%);
    white-space: nowrap; pointer-events: none; z-index: 0;
  }
  .media-hero-content { position: relative; z-index: 1; }

  /* ── 잡지 배너 ─────────────────────────────── */
  .journal-banner {
    margin: 0 48px 0;
    border-radius: 24px; overflow: hidden;
    background: linear-gradient(135deg, #0d2410 0%, #1a3d1a 50%, #0d2410 100%);
    border: 1px solid rgba(168,255,62,.15);
    position: relative;
    max-width: 1200px;
    margin-left: auto; margin-right: auto;
  }
  .journal-banner::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 80% at 20% 50%, rgba(168,255,62,.1) 0%, transparent 60%),
      radial-gradient(ellipse 40% 60% at 80% 50%, rgba(168,255,62,.06) 0%, transparent 55%);
  }
  .journal-banner-inner {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 48px; align-items: center;
    padding: 64px 56px;
  }
  .journal-label {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 11px; font-weight: 700; letter-spacing: .12em;
    text-transform: uppercase; color: #a8ff3e;
    margin-bottom: 20px;
  }
  .journal-label::before { content: ''; display: block; width: 28px; height: 2px; background: #a8ff3e; }
  .journal-title {
    font-family: 'Black Han Sans', sans-serif;
    font-size: clamp(2rem,4vw,3.2rem);
    letter-spacing: -.02em; line-height: 1.2;
    margin-bottom: 16px;
  }
  .journal-desc {
    font-size: 14px; color: rgba(255,255,255,.55);
    line-height: 1.85; margin-bottom: 32px;
  }
  .journal-cta {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 28px; border-radius: 999px;
    background: #a8ff3e; color: #0a0e1a;
    font-size: 13px; font-weight: 700;
    text-decoration: none; transition: all .25s;
  }
  .journal-cta:hover { background: #c8ff70; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(168,255,62,.3); }
  .journal-visual {
    display: flex; flex-direction: column; gap: 16px;
  }
  .journal-stat-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
  }
  .journal-stat {
    border-radius: 16px; padding: 20px;
    background: rgba(168,255,62,.06);
    border: 1px solid rgba(168,255,62,.12);
    text-align: center;
  }
  .journal-stat-num {
    font-family: 'Black Han Sans', sans-serif;
    font-size: 28px; color: #a8ff3e;
    letter-spacing: -.02em;
  }
  .journal-stat-label { font-size: 12px; color: rgba(255,255,255,.45); margin-top: 4px; }

  /* ── 최신 미디어 소식 ─────────────────────── */
  .media-news { padding: 80px 48px; }
  .magazine-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 24px;
    max-width: 1200px; margin: 0 auto;
  }
  /* 피처 카드 (대형) */
  .feature-card {
    border-radius: 20px; overflow: hidden;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    transition: transform .3s, border-color .3s;
  }
  .feature-card:hover { transform: translateY(-4px); border-color: rgba(255,255,255,.15); }
  .feature-card-thumb {
    height: 240px;
    background: linear-gradient(135deg, #0d2410, #1a3d1a);
    display: flex; align-items: center; justify-content: center;
    font-size: 72px; position: relative;
    overflow: hidden;
  }
  .feature-card-thumb-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(10,14,26,.8) 100%);
  }
  .feature-badge {
    position: absolute; bottom: 16px; left: 16px;
    background: rgba(168,255,62,.9); color: #0a0e1a;
    font-size: 11px; font-weight: 700; letter-spacing: .04em;
    padding: 4px 12px; border-radius: 999px;
  }
  .feature-body { padding: 28px; }
  .feature-title { font-weight: 700; font-size: 20px; line-height: 1.45; margin-bottom: 10px; }
  .feature-excerpt { font-size: 14px; color: rgba(255,255,255,.45); line-height: 1.8; }
  .feature-meta { font-size: 12px; color: rgba(255,255,255,.25); margin-top: 16px; }

  /* 사이드 카드 목록 */
  .side-cards { display: flex; flex-direction: column; gap: 16px; }
  .side-card {
    border-radius: 16px; padding: 20px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    transition: transform .25s, border-color .25s;
    cursor: default;
  }
  .side-card:hover { transform: translateX(4px); border-color: rgba(168,255,62,.2); }
  .side-card-label {
    font-size: 10px; font-weight: 700; letter-spacing: .1em;
    color: #a8ff3e; text-transform: uppercase; margin-bottom: 8px;
  }
  .side-card-title { font-size: 14px; font-weight: 700; line-height: 1.5; margin-bottom: 6px; }
  .side-card-date  { font-size: 11px; color: rgba(255,255,255,.25); }

  /* ── 인사말 CTA ─────────────────────────── */
  .greeting-cta {
    margin: 0 auto 80px;
    max-width: 1200px; padding: 0 48px;
  }
  .greeting-card {
    border-radius: 24px; padding: 56px;
    background: rgba(255,255,255,.03);
    border: 1px solid rgba(255,255,255,.08);
    display: grid; grid-template-columns: 1fr auto;
    gap: 48px; align-items: center;
    position: relative; overflow: hidden;
  }
  .greeting-card::before {
    content: '🌿';
    position: absolute; right: -20px; top: -20px;
    font-size: 160px; opacity: .04; line-height: 1;
  }
  .greeting-link {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 14px 32px; border-radius: 999px;
    background: transparent; color: #a8ff3e;
    font-size: 14px; font-weight: 700;
    text-decoration: none; white-space: nowrap;
    border: 1.5px solid rgba(168,255,62,.35);
    transition: all .25s;
    position: relative; z-index: 1;
  }
  .greeting-link:hover {
    background: #a8ff3e; color: #0a0e1a;
    border-color: #a8ff3e;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(168,255,62,.25);
  }

  /* 반응형 */
  @media (max-width: 1024px) {
    .magazine-grid { grid-template-columns: 1fr; }
    .journal-banner-inner { grid-template-columns: 1fr; gap: 32px; }
  }
  @media (max-width: 640px) {
    .media-hero, .media-news, .greeting-cta { padding-left: 20px; padding-right: 20px; }
    .journal-banner { margin: 0 20px; }
    .journal-banner-inner { padding: 36px 28px; }
    .greeting-card { grid-template-columns: 1fr; gap: 28px; padding: 32px; }
    .media-news { padding: 60px 20px; }
  }
</style>

<!-- ══ HERO ═══════════════════════════════════ -->
<section class="media-hero">
  <div class="media-hero-bg" aria-hidden="true">MEDIA</div>
  <div class="media-hero-content reveal">
    <div class="section-label" style="justify-content:center;margin-bottom:20px;color:#a8ff3e;">
      <span style="background:#a8ff3e;"></span>Media
    </div>
    <h1 style="font-family:'Black Han Sans',sans-serif;font-size:clamp(2.8rem,5vw,5rem);letter-spacing:-0.02em;line-height:1.1;margin-bottom:20px;">
      환경을 기록하는<br>
      <span style="color:#a8ff3e;">저널리스트</span>
    </h1>
    <p style="font-size:16px;color:rgba(255,255,255,.5);max-width:440px;margin:0 auto;line-height:1.8;">
      한국환경저널 발행인 최범희 PD<br>환경 미디어 리터러시의 최전선
    </p>
  </div>
</section>

<!-- ══ 한국환경저널 배너 ════════════════════════ -->
<div style="padding: 0 48px 80px; max-width: 1296px; margin: 0 auto;">
  <div class="journal-banner reveal">
    <div class="journal-banner-inner">
      <!-- 텍스트 -->
      <div>
        <div class="journal-label">한국환경저널</div>
        <h2 class="journal-title">
          환경 저널리즘<br>의 새로운 표준
        </h2>
        <p class="journal-desc">
          기후변화·생태계·환경 정책을 깊이 있게 다루는<br>
          전문 환경 미디어. 지속가능한 미래를 위한<br>
          담론을 이끌어 갑니다.
        </p>
        <%= link_to media_greeting_path, class: "journal-cta" do %>
          <svg width="16" height="16" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          발행인 인사말 보기
        <% end %>
      </div>
      <!-- 통계 -->
      <div class="journal-visual">
        <div class="journal-stat-grid">
          <% [
            ["창간", "2016"],
            ["누적 기사", "2,400+"],
            ["월 독자", "18만+"],
            ["수상 횟수", "12회"],
          ].each do |label, num| %>
            <div class="journal-stat">
              <div class="journal-stat-num"><%= num %></div>
              <div class="journal-stat-label"><%= label %></div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ══ 최신 미디어 소식 ════════════════════════ -->
<section class="media-news">
  <div style="max-width:1200px;margin:0 auto;">
    <div class="section-label" style="margin-bottom:32px;color:#a8ff3e;"><span style="background:#a8ff3e;"></span>Latest</div>
    <% if @media_posts.any? %>
      <div class="magazine-grid">
        <!-- 피처 (첫 번째 기사) -->
        <% feature = @media_posts.first %>
        <div class="feature-card reveal">
          <div class="feature-card-thumb">
            🌿
            <div class="feature-card-thumb-overlay"></div>
            <span class="feature-badge">환경</span>
          </div>
          <div class="feature-body">
            <div class="feature-title"><%= feature.title %></div>
            <div class="feature-excerpt"><%= feature.content.to_s.truncate(160) %></div>
            <div class="feature-meta"><%= feature.created_at.strftime("%Y.%m.%d") %></div>
          </div>
        </div>
        <!-- 사이드 카드 목록 -->
        <div class="side-cards">
          <% @media_posts.drop(1).first(4).each_with_index do |post, i| %>
            <div class="side-card reveal reveal-delay-<%= i + 1 %>">
              <div class="side-card-label">미디어</div>
              <div class="side-card-title"><%= post.title %></div>
              <div class="side-card-date"><%= post.created_at.strftime("%Y.%m.%d") %></div>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <!-- 샘플 레이아웃 -->
      <% sample_posts = [
        { label: "환경", title: "2024 탄소 중립 로드맵 분석 - 기업들의 ESG 실천 현황", excerpt: "국내 주요 기업들의 탄소 중립 추진 현황을 심층 분석합니다. 정부 정책과 민간 자본의 움직임을 통해 2050 탄소중립 달성 가능성을 전망합니다.", date: "2024.11.20", emoji: "🌿" },
        { label: "기후", title: "해수면 상승과 해안 도시의 미래", date: "2024.11.15", emoji: "🌊" },
        { label: "정책", title: "재생에너지 확대 정책, 그 실효성은?", date: "2024.11.08", emoji: "☀️" },
        { label: "생태", title: "도시 생태계 복원 프로젝트 현장 르포", date: "2024.10.30", emoji: "🦋" },
        { label: "교육", title: "환경 미디어 리터러시 교육 확산 사례", date: "2024.10.22", emoji: "📚" },
      ] %>
      <div class="magazine-grid">
        <div class="feature-card reveal">
          <div class="feature-card-thumb" style="font-size:80px;">
            <%= sample_posts[0][:emoji] %>
            <div class="feature-card-thumb-overlay"></div>
            <span class="feature-badge"><%= sample_posts[0][:label] %></span>
          </div>
          <div class="feature-body">
            <div class="feature-title"><%= sample_posts[0][:title] %></div>
            <div class="feature-excerpt"><%= sample_posts[0][:excerpt] %></div>
            <div class="feature-meta"><%= sample_posts[0][:date] %></div>
          </div>
        </div>
        <div class="side-cards">
          <% sample_posts[1..].each_with_index do |post, i| %>
            <div class="side-card reveal reveal-delay-<%= i + 1 %>">
              <div class="side-card-label"><%= post[:label] %></div>
              <div class="side-card-title"><%= post[:title] %></div>
              <div class="side-card-date"><%= post[:date] %></div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>

<!-- ══ 발행인 인사말 CTA ══════════════════════ -->
<div class="greeting-cta">
  <div class="greeting-card reveal">
    <div style="position:relative;z-index:1;">
      <div class="section-label" style="color:#a8ff3e;"><span style="background:#a8ff3e;"></span>Publisher's Message</div>
      <h3 style="font-family:'Black Han Sans',sans-serif;font-size:clamp(1.6rem,2.5vw,2.2rem);letter-spacing:-.02em;line-height:1.3;margin-bottom:12px;">
        발행인의 목소리로<br>전하는 환경 이야기
      </h3>
      <p style="font-size:14px;color:rgba(255,255,255,.45);line-height:1.85;">
        한국환경저널 발행인 최범희 PD가<br>
        직접 전하는 환경 미디어의 방향성과 비전을 만나보세요.
      </p>
    </div>
    <%= link_to media_greeting_path, class: "greeting-link" do %>
      인사말 전문 보기
      <svg width="16" height="16" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    <% end %>
  </div>
</div>
