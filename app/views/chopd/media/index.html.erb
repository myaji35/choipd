<% content_for :title, "미디어 - 한국환경저널" %>

<section class="bg-gradient-to-br from-green-900 to-green-700 py-16">
  <div class="max-w-7xl mx-auto px-4 text-center">
    <div class="inline-flex items-center bg-white/10 border border-white/20 rounded-full px-4 py-1.5 mb-6">
      <span class="text-green-200 text-sm font-medium">한국환경저널 발행인</span>
    </div>
    <h1 class="text-4xl font-bold text-white mb-4">미디어</h1>
    <p class="text-green-200 text-lg">환경 미디어 리터러시, 환경 저널리즘의 최전선</p>
  </div>
</section>

<!-- 한국환경저널 소개 -->
<section class="py-16">
  <div class="max-w-5xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl font-bold text-navy mb-4">한국환경저널</h2>
        <p class="text-gray-600 leading-relaxed mb-6">
          한국환경저널은 환경 이슈를 깊이 있게 다루는 전문 미디어입니다.
          환경 정책, 기후변화, 생태계 보전 등 다양한 주제를 통해
          환경에 대한 인식을 높이고 지속가능한 미래를 위한 담론을 이끌어 갑니다.
        </p>
        <%= link_to media_greeting_path, class: "inline-flex items-center text-primary font-medium hover:text-primary-dark" do %>
          발행인 인사말 보기
          <svg class="w-4 h-4 ml-1" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
      <div class="bg-green-50 rounded-xl p-8 text-center">
        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-10 h-10 text-green-600" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/>
            <line x1="4" y1="22" x2="4" y2="15"/>
          </svg>
        </div>
        <h3 class="font-bold text-navy text-lg mb-2">환경 저널리즘의 선구자</h3>
        <p class="text-gray-500 text-sm">환경 미디어 리터러시 교육 및 실천</p>
      </div>
    </div>
  </div>
</section>

<!-- 미디어 콘텐츠 -->
<% if @media_posts.any? %>
<section class="py-12 bg-surface">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-2xl font-bold text-navy mb-8">최신 미디어 소식</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% @media_posts.each do |post| %>
        <div class="bg-white rounded-lg border border-gray-100 p-5 shadow-sm hover:shadow-md transition-shadow">
          <h3 class="font-bold text-navy mb-2"><%= post.title %></h3>
          <p class="text-gray-500 text-sm line-clamp-3 mb-3"><%= post.content.truncate(150) %></p>
          <p class="text-xs text-gray-400"><%= post.created_at.strftime("%Y.%m.%d") %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>
<% end %>
