<%= form_with model: lead, url: leads_path, class: "flex flex-col sm:flex-row gap-3" do |f| %>
  <%= f.email_field :email, placeholder: "이메일 주소를 입력하세요",
      class: "flex-1 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
  <%= f.submit "구독하기",
      class: "bg-primary text-white px-6 py-2.5 rounded-lg font-medium hover:bg-primary-dark transition-colors cursor-pointer whitespace-nowrap" %>
<% end %>
<% if lead.errors.any? %>
  <p class="text-red-500 text-sm mt-2"><%= lead.errors.full_messages.first %></p>
<% end %>
