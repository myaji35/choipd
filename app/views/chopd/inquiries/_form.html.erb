<%= form_with model: inquiry, url: inquiries_path, class: "space-y-4" do |f| %>
  <% if inquiry.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <% inquiry.errors.full_messages.each do |msg| %>
        <p class="text-red-600 text-sm"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :name, "이름", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, placeholder: "홍길동", class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" %>
    </div>
    <div>
      <%= f.label :email, "이메일", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email, placeholder: "example@email.com", class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :phone, "연락처", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :phone, placeholder: "010-0000-0000", class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" %>
    </div>
    <div>
      <%= f.label :inquiry_type, "문의 유형", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :inquiry_type, [["B2B/B2G 교육", "b2b"], ["일반 문의", "contact"]],
          { include_blank: "선택하세요" },
          class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" %>
    </div>
  </div>

  <div>
    <%= f.label :message, "문의 내용", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :message, rows: 5, placeholder: "문의하실 내용을 자세히 적어주세요.", class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent resize-none" %>
  </div>

  <%= f.submit "문의 접수하기", class: "w-full bg-primary text-white py-3 rounded-lg font-semibold hover:bg-primary-dark transition-colors cursor-pointer" %>
<% end %>
