<% content_for :title, "홈" %>

<!-- Hero 섹션 -->
<section class="relative bg-navy overflow-hidden" data-controller="hero-slideshow" data-hero-slideshow-interval-value="5000">
  <!-- 히어로 슬라이드 -->
  <div class="relative h-[560px] md:h-[640px]">
    <% if @hero_images.any? %>
      <% @hero_images.each_with_index do |hero, i| %>
        <div class="absolute inset-0 transition-opacity duration-1000 <%= i == 0 ? 'opacity-100' : 'opacity-0' %>"
             data-hero-slideshow-target="slide">
          <% if hero.image.attached? %>
            <%= image_tag hero.image, class: "w-full h-full object-cover", alt: hero.alt_text %>
          <% end %>
          <div class="absolute inset-0 bg-navy/60"></div>
        </div>
      <% end %>
    <% else %>
      <!-- 기본 히어로 배경 -->
      <div class="absolute inset-0 bg-gradient-to-br from-navy via-blue-900 to-primary"></div>
    <% end %>

    <!-- 히어로 콘텐츠 -->
    <div class="relative z-10 flex items-center justify-center h-full text-center px-4">
      <div class="max-w-3xl">
        <div class="inline-flex items-center bg-primary/20 border border-primary/30 rounded-full px-4 py-1.5 mb-6">
          <span class="text-primary text-sm font-medium">스마트폰 창업 전략가</span>
        </div>
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
          최범희 PD의<br>
          <span class="text-primary">스마트폰 연구소</span>
        </h1>
        <p class="text-gray-300 text-lg md:text-xl mb-8 leading-relaxed">
          스마트폰 하나로 시작하는 나만의 창업 여정.<br>
          50-60대 베이비부머의 디지털 전환을 함께합니다.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <%= link_to "강좌 보기", education_path, class: "bg-primary text-white px-8 py-3 rounded-lg font-semibold hover:bg-primary-dark transition-colors" %>
          <%= link_to "문의하기", new_inquiry_path, class: "bg-transparent border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-navy transition-colors" %>
        </div>
      </div>
    </div>

    <!-- 슬라이드 인디케이터 -->
    <% if @hero_images.count > 1 %>
      <div class="absolute bottom-6 left-1/2 transform -translate-x-1/2 flex space-x-2" data-hero-slideshow-target="indicators">
        <% @hero_images.each_with_index do |_, i| %>
          <button class="w-2 h-2 rounded-full transition-all <%= i == 0 ? 'bg-white w-6' : 'bg-white/40' %>"
                  data-action="click->hero-slideshow#goTo"
                  data-index="<%= i %>"></button>
        <% end %>
      </div>
    <% end %>
  </div>
</section>

<!-- 서비스 허브 -->
<section class="py-16 bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-navy mb-4">서비스 허브</h2>
      <p class="text-gray-500">최PD가 제공하는 다양한 서비스를 경험하세요</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- 교육 카드 -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow group">
        <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4 group-hover:bg-primary/20 transition-colors">
          <svg class="w-6 h-6 text-primary" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
            <path d="M2 17l10 5 10-5"/>
            <path d="M2 12l10 5 10-5"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-navy mb-2">교육</h3>
        <p class="text-gray-500 text-sm mb-4">스마트폰 창업 전략, 디지털 마케팅, B2B/B2G 과정</p>
        <%= link_to education_path, class: "text-primary text-sm font-medium hover:text-primary-dark transition-colors inline-flex items-center" do %>
          강좌 보기
          <svg class="w-4 h-4 ml-1" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>

      <!-- 미디어 카드 -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow group">
        <div class="w-12 h-12 bg-green-50 rounded-lg flex items-center justify-center mb-4 group-hover:bg-green-100 transition-colors">
          <svg class="w-6 h-6 text-green-600" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/>
            <line x1="4" y1="22" x2="4" y2="15"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-navy mb-2">미디어</h3>
        <p class="text-gray-500 text-sm mb-4">한국환경저널 발행인, 환경 미디어 콘텐츠</p>
        <%= link_to media_path, class: "text-primary text-sm font-medium hover:text-primary-dark transition-colors inline-flex items-center" do %>
          저널 보기
          <svg class="w-4 h-4 ml-1" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>

      <!-- 작품 카드 -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow group">
        <div class="w-12 h-12 bg-purple-50 rounded-lg flex items-center justify-center mb-4 group-hover:bg-purple-100 transition-colors">
          <svg class="w-6 h-6 text-purple-600" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-navy mb-2">작품</h3>
        <p class="text-gray-500 text-sm mb-4">저서, 모바일 스케치 갤러리, 언론 보도</p>
        <%= link_to works_path, class: "text-primary text-sm font-medium hover:text-primary-dark transition-colors inline-flex items-center" do %>
          갤러리 보기
          <svg class="w-4 h-4 ml-1" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
    </div>
  </div>
</section>

<!-- 최신 강좌 -->
<% if @latest_courses.any? %>
<section class="py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-3xl font-bold text-navy">최신 강좌</h2>
      <%= link_to "전체 보기", education_path, class: "text-primary text-sm font-medium hover:text-primary-dark" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @latest_courses.each do |course| %>
        <div class="bg-white border border-gray-100 rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <% if course.thumbnail_url.present? %>
            <div class="h-40 bg-gray-100 overflow-hidden">
              <%= image_tag course.thumbnail_url, class: "w-full h-full object-cover", alt: course.title %>
            </div>
          <% else %>
            <div class="h-40 bg-gradient-to-br from-primary/20 to-primary/5 flex items-center justify-center">
              <svg class="w-12 h-12 text-primary/30" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="1.5">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5"/>
                <path d="M2 12l10 5 10-5"/>
              </svg>
            </div>
          <% end %>
          <div class="p-4">
            <div class="flex items-center justify-between mb-2">
              <span class="text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full font-medium">
                <%= course.course_type == 'online' ? '온라인' : course.course_type == 'offline' ? '오프라인' : 'B2B' %>
              </span>
              <% if course.price.present? && course.price > 0 %>
                <span class="text-sm font-semibold text-navy"><%= number_with_delimiter(course.price) %>원</span>
              <% else %>
                <span class="text-sm text-green-600 font-medium">무료</span>
              <% end %>
            </div>
            <h3 class="font-semibold text-navy text-sm mb-2 line-clamp-2"><%= course.title %></h3>
            <% if course.external_link.present? %>
              <%= link_to "수강 신청", course.external_link, target: "_blank", rel: "noopener", class: "w-full block text-center bg-primary text-white text-sm py-2 rounded hover:bg-primary-dark transition-colors mt-3" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- 최신 소식 -->
<% if @latest_posts.any? %>
<section class="py-16 bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-3xl font-bold text-navy">최신 소식</h2>
      <%= link_to "전체 보기", community_path, class: "text-primary text-sm font-medium hover:text-primary-dark" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <% @latest_posts.each do |post| %>
        <div class="bg-white border border-gray-100 rounded-lg p-5 shadow-sm">
          <span class="text-xs text-gray-400 uppercase tracking-wider">
            <%= post.category == 'notice' ? '공지' : post.category == 'review' ? '후기' : '미디어' %>
          </span>
          <h3 class="font-semibold text-navy mt-2 mb-3 line-clamp-2"><%= post.title %></h3>
          <p class="text-gray-500 text-sm line-clamp-3"><%= post.content.truncate(100) %></p>
          <p class="text-xs text-gray-400 mt-3"><%= post.created_at.strftime("%Y.%m.%d") %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- CTA 섹션 -->
<section class="py-16 bg-primary">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-3xl font-bold text-white mb-4">B2B/B2G 파트너십 문의</h2>
    <p class="text-blue-100 text-lg mb-8">기업, 기관, 지자체를 위한 맞춤형 교육 프로그램을 제공합니다.</p>
    <%= link_to "지금 문의하기", new_inquiry_path(type: 'b2b'), class: "bg-white text-primary px-8 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors" %>
  </div>
</section>
