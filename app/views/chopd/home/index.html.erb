<% content_for :title, "imPD — 강사·공방·아티스트의 홍보 페이지" %>
<% content_for :description, "사진과 수료증만 올리면 자동으로 홍보 페이지가 완성됩니다. imPD." %>

<style>
  body { background: var(--impd-paper); color: var(--impd-ink); }
  .impd-wrap { max-width: 1200px; margin: 0 auto; padding: 0 40px; }
  .impd-section { padding: 80px 0; }
  @media (max-width: 768px) {
    /* 섹션들이 인라인 style 로 padding 을 지정해 이 규칙을 이긴다.
       좌우만 !important 로 되돌려 375px 뷰포트 가로 오버플로(22px)를 막는다. */
    .impd-wrap { padding-left: 20px !important; padding-right: 20px !important; }
    .impd-section { padding: 48px 0; }
    /* 통계 4열은 375px 에서 열당 44px 밖에 안 남아 숫자가 눌리고 3px 넘친다. 2x2 로 전환. */
    .impd-stats-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
</style>

<div style="background: var(--impd-paper); color: var(--impd-ink); font-family: var(--impd-font-sans);">

  <!-- ── Marquee ───────────────────────── -->
  <div style="overflow: hidden; border-bottom: 1px solid var(--impd-rule); padding: 8px 0;">
    <div class="impd-marquee" style="display: flex; gap: 48px; white-space: nowrap; font-family: var(--impd-font-mono); font-size: 11px; letter-spacing: 1.4px; text-transform: uppercase; color: var(--impd-muted);">
      <% 2.times do %>
        <span>지금 신청 받는 중</span>
        <span>vol. 04 · 2026 봄</span>
        <span>강사·공방·아티스트를 위해</span>
        <span>템플릿 없음</span>
        <span>매번 새로 디자인</span>
        <span>베타 초대 진행 중 · 실제 페이지만 노출</span>
      <% end %>
    </div>
  </div>

  <!-- ── HERO §01 (v2: 좌우 2컬럼 + Polaroid Stack) ───────────────────────── -->
  <section class="impd-wrap" style="padding: 80px 40px 40px;">
    <div class="impd-label" style="margin-bottom: 28px;">§01 · 업로드만 하세요. 나머지는 저희가.</div>

    <div class="impd-hero-grid" style="display: grid; grid-template-columns: 1.15fr 0.85fr; gap: 60px; align-items: start;">
      <!-- 좌: 헤드라인 + 본문 + CTA -->
      <div>
        <div class="impd-fade-in" data-controller="impd-rotator"
             style="font-family: var(--impd-font-display); font-weight: 800; font-size: clamp(48px, 8vw, 96px); letter-spacing: -4.5px; line-height: 0.9;">
          <div>당신은</div>
          <div style="height: 1em; overflow: hidden; position: relative;">
            <div data-impd-rotator-target="word" style="color: var(--impd-accent); font-style: italic;">강사</div>
          </div>
          <div>사진 몇 장,</div>
          <div><span style="color: var(--impd-accent); font-style: italic;">수료증 하나</span>면</div>
          <div>완성됩니다.</div>
        </div>

        <p style="margin-top: 36px; font-size: 16px; line-height: 1.6; color: var(--impd-ink2); max-width: 480px;">
          SNS에 흩어진 사진, 서랍 속 수료증, 그동안 진행해 온 강의 이력 —
          그냥 올리기만 하세요. imPD가 자동으로 정리해 당신만의 홍보 페이지로 만들어 드립니다.
        </p>

        <div style="display: flex; gap: 12px; margin-top: 28px; flex-wrap: wrap;">
          <%= link_to "내 페이지 만들기 →", member_signup_path,
              class: "impd-btn impd-btn-primary", style: "height: 54px; padding: 0 22px; font-size: 16px;" %>
          <%
            # 실제 회원 slug로 연결 — 첫 번째 featured 회원을 "예시"로 노출.
            # 이름은 노출하지 않고 링크만 slug 기반. anti-pattern(랜딩에 개인 노출) 회피.
            sample_slug = (@featured_members || []).first&.slug || "choi-pd"
          %>
          <%= link_to "예시 보기 →", "/#{sample_slug}",
              class: "impd-btn impd-btn-secondary", style: "height: 54px; padding: 0 22px; font-size: 16px;" %>
          <%= link_to promo_watch_path,
              class: "impd-btn impd-btn-secondary",
              style: "height: 54px; padding: 0 22px; font-size: 16px; display: inline-flex; align-items: center; gap: 8px;",
              data: { "promo-popup": true } do %>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polygon points="6 3 20 12 6 21 6 3" fill="currentColor" stroke="none"/>
            </svg>
            홍보 영상 <span style="font-family: var(--impd-font-mono); font-size: 11px; color: var(--impd-muted); letter-spacing: 1px;">30s</span>
          <% end %>
        </div>
      </div>

      <!-- 우: Polaroid Stack (340x400) -->
      <div class="impd-polaroid-slot" style="display: flex; justify-content: center; padding-top: 20px;">
        <%= render "shared/polaroid_stack", width: 340, height: 400, items: [
          { color: "#ff5a1f", kind: "활동 사진", date: "26.04",   caption: "수강생 환한 표정." },
          { color: "#3a2af0", kind: "수료증",    date: "23.07",   caption: "요가 지도자 자격." },
          { color: "#2a9d8f", kind: "SNS",       date: "이번 달", caption: "팔로워 급증한 릴." },
          { color: "#e4b230", kind: "포스터",    date: "지난달",  caption: "워크숍 모객 전단." },
          { color: "#aa2a6a", kind: "후기",      date: "최근",    caption: "5점 만점 리뷰들." },
          { color: "#1a1a1a", kind: "릴스",      date: "이번주",  caption: "조회수 1.2만." }
        ] %>
      </div>
    </div>

    <style>
      @media (max-width: 768px) {
        .impd-hero-grid { grid-template-columns: 1fr !important; }
        /* 폴라로이드 스택은 340px 고정폭이라 좁은 화면에서 부모를 넘친다.
           슬롯 기준으로 축소해 오버플로를 막는다(비율 340:400 유지). */
        .impd-polaroid-slot > [data-controller="polaroid-stack"] {
          width: 100% !important;
          max-width: 340px;
          height: auto !important;
          aspect-ratio: 340 / 400;
        }
      }
    </style>
  </section>

  <!-- ── Stats — 베타 단계 솔직 수치 ───────────────────────── -->
  <%
    live_member_count = Member.where(status: "approved").count rescue 0
    featured_count    = (@featured_members || []).size
  %>
  <section class="impd-wrap" style="padding: 40px 40px 80px;">
    <div class="impd-stats-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border-top: 1px solid var(--impd-ink);">
      <% [
        ["BETA",                "지금 초대 시작",  "제한 회원 대상 오픈"],
        ["#{live_member_count}", "공개 중인 페이지", "실제 운영 중"],
        ["#{featured_count}",    "공개 레퍼런스",   "\"예시 보기\"로 확인"],
        ["0원",                  "시작 비용",      "카드 등록 불필요"]
      ].each_with_index do |(num, label, sub), i| %>
        <div style="padding: 24px 20px; <%= 'border-left: 1px solid var(--impd-rule);' if i > 0 %>">
          <div class="impd-display" style="font-size: 44px; letter-spacing: -0.03em; color: var(--impd-green);"><%= num %></div>
          <div class="impd-label-muted" style="margin-top: 6px;"><%= label %></div>
          <div style="font-size: 11px; color: var(--impd-soft-muted); margin-top: 2px; font-family: var(--impd-font-mono); letter-spacing: 0.5px;"><%= sub %></div>
        </div>
      <% end %>
    </div>
    <p style="margin-top: 10px; font-size: 11px; color: var(--impd-muted); font-family: var(--impd-font-mono); letter-spacing: 1px; text-align: right;">
      VOL. 04 · 2026 봄 · imPD 베타. 수치는 매 페이지 로드마다 DB에서 갱신됩니다.
    </p>
  </section>

  <!-- ── §02 3-step pitch ───────────────────────── -->
  <section class="impd-wrap impd-section">
    <div class="impd-section-header">
      <span class="impd-label">§02</span>
      <span class="impd-display" style="font-size: 36px; flex: 1;">자료를 올리면, 페이지가 됩니다.</span>
      <span class="impd-label-muted">3 STEPS</span>
    </div>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0;">
      <% [
        ["01", "업로드", "사진·수료증·이력서·SNS 링크 — 무엇이든 올려주세요."],
        ["02", "자동 정리", "AI가 카테고리별로 분류하고 핵심 정보를 추출합니다."],
        ["03", "페이지 완성", "잡지처럼 다듬어진 당신만의 홍보 페이지가 열립니다."]
      ].each_with_index do |(num, title, desc), i| %>
        <div style="padding: 32px 24px; <%= 'border-left: 1px solid var(--impd-rule);' if i > 0 %>">
          <div class="impd-label" style="color: var(--impd-accent);">§<%= num %></div>
          <h3 class="impd-display" style="font-size: 28px; margin: 12px 0 16px;"><%= title %></h3>
          <p style="font-size: 15px; line-height: 1.55; color: var(--impd-ink2);"><%= desc %></p>
        </div>
      <% end %>
    </div>
  </section>

  <!-- ── §03 자료 종류 그리드 ───────────────────────── -->
  <section class="impd-wrap impd-section">
    <div class="impd-section-header">
      <span class="impd-label">§03</span>
      <span class="impd-display" style="font-size: 36px; flex: 1;">이런 자료들이 페이지가 됩니다.</span>
      <span class="impd-label-muted">6 TYPES</span>
    </div>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; border-top: 1px solid var(--impd-rule); border-left: 1px solid var(--impd-rule);">
      <% [
        ["📸", "현장 사진", "갤러리 그리드"],
        ["📜", "수료증·자격증", "달란트 배지"],
        ["🎬", "유튜브·SNS", "포트폴리오 임베드"],
        ["📝", "강의 이력", "타임라인"],
        ["⭐", "고객 후기", "테스티모니얼"],
        ["💼", "프로젝트", "케이스 스터디"]
      ].each do |emoji, title, result| %>
        <div style="padding: 24px; border-right: 1px solid var(--impd-rule); border-bottom: 1px solid var(--impd-rule);">
          <div style="font-size: 32px; margin-bottom: 12px;"><%= emoji %></div>
          <h4 class="impd-display" style="font-size: 20px;"><%= title %></h4>
          <p class="impd-label-muted" style="margin-top: 8px;">→ <%= result %></p>
        </div>
      <% end %>
    </div>
  </section>

  <!-- ── §05 Creators (실제 회원 카드 + 클릭 시 공개 페이지로 이동) ───── -->
  <%
    # profession 한글 매핑 (Member::PROFESSIONS 값 → UI 노출)
    profession_labels = {
      "insurance_agent" => "보험 설계사",
      "realtor"         => "공인중개사",
      "educator"        => "강사",
      "author"          => "작가",
      "shopowner"       => "자영업자",
      "freelancer"      => "프리랜서",
      "custom"          => "크리에이터",
    }
    palette = ["#ff5a1f", "#2a9d8f", "#3a2af0", "#e4b230", "#1a1a1a", "#aa2a6a"]
    # 실제 회원 < 6명이면 fallback 더미로 보강
    fallback_cards = [
      { name: "요가 강사", role: "강사",        region: "성수동", slug: nil },
      { name: "도예 공방", role: "자영업자",    region: "양평",   slug: nil },
      { name: "플라워",    role: "강사",        region: "연남동", slug: nil },
      { name: "목공 장인", role: "자영업자",    region: "파주",   slug: nil },
      { name: "홈베이킹",  role: "작가",        region: "일산",   slug: nil },
      { name: "캘리그라피",role: "크리에이터",  region: "대구",   slug: nil },
    ]
    real_cards = (@featured_members || []).map do |m|
      {
        name:   m.name.to_s,
        role:   profession_labels[m.profession.to_s] || "크리에이터",
        region: m.region.presence || "",
        slug:   m.slug,
      }
    end
    cards = (real_cards + fallback_cards).first(6)
  %>
  <section class="impd-wrap impd-section">
    <div class="impd-section-header">
      <span class="impd-label">§05</span>
      <span class="impd-display" style="font-size: 36px; flex: 1;">imPD를 쓰는 사람들.</span>
      <span class="impd-label-muted"><%= cards.size %> CREATORS</span>
    </div>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;">
      <% cards.each_with_index do |c, i| %>
        <%
          color = palette[i % palette.size]
          clickable = c[:slug].present?
          tag_name = clickable ? "a" : "div"
          common_style = "background: #{color}; color: #fff; padding: 0; aspect-ratio: 1.1; display: flex; flex-direction: column; justify-content: space-between; position: relative; overflow: hidden; text-decoration: none; #{clickable ? 'cursor: pointer;' : ''}"
        %>
        <%= content_tag(tag_name, href: clickable ? "/#{c[:slug]}" : nil, style: common_style) do %>
          <div class="impd-stripe" style="position: absolute; inset: 0;"></div>
          <div style="position: relative; padding: 16px; z-index: 1; display: flex; justify-content: space-between; align-items: start; gap: 8px;">
            <div class="impd-label" style="color: rgba(255,255,255,.7);"><%= c[:region] %></div>
            <% if clickable %>
              <div style="font-family: var(--impd-font-mono); font-size: 10px; letter-spacing: 1px; color: rgba(255,255,255,.65); background: rgba(0,0,0,.18); padding: 3px 8px; border-radius: 3px; white-space: nowrap;">LIVE</div>
            <% end %>
          </div>
          <div style="position: relative; padding: 16px; z-index: 1;">
            <div class="impd-display" style="font-size: 24px; line-height: 1.15; word-break: keep-all;"><%= c[:name] %></div>
            <div style="font-size: 13px; opacity: 0.85; margin-top: 4px;"><%= c[:role] %></div>
            <% if clickable %>
              <div style="font-family: var(--impd-font-mono); font-size: 10px; letter-spacing: 0.5px; opacity: 0.75; margin-top: 8px; display: inline-flex; align-items: center; gap: 4px;">
                impd.me/<%= c[:slug] %> <span style="font-size: 13px;">→</span>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
    <p style="margin-top: 16px; font-size: 12px; color: var(--impd-muted); text-align: right;">
      LIVE 태그가 붙은 카드는 실제 회원 페이지로 이동합니다
    </p>
  </section>

  <!-- ── §05.5 Real Moments (회원들이 올린 실제 장면) ──────────── -->
  <% if @featured_moments.present? && @featured_moments.any? %>
    <%# full-bleed 배경: 부모 overflow-x: hidden과 호환되도록 wrapper 내부에서 처리 %>
    <div style="background: var(--impd-card); border-top: 1px solid var(--impd-rule); border-bottom: 1px solid var(--impd-rule); margin: 40px 0;">
      <section class="impd-wrap" style="padding-top: 64px; padding-bottom: 64px;">
        <div class="impd-section-header">
          <span class="impd-label">§05.5</span>
          <span class="impd-display" style="font-size: 36px; flex: 1;">실제 페이지에서 살아있는 장면들.</span>
          <span class="impd-label-muted"><%= @featured_moments.size %> MOMENTS</span>
        </div>
        <p style="font-family: var(--impd-font-serif); font-style: italic; font-size: 17px; color: var(--impd-ink2); line-height: 1.55; max-width: 58ch; margin-bottom: 28px;">
          템플릿이 아니라 진짜 순간들. imPD 회원들이 <span style="color: var(--impd-accent-2);">직접 올린 사진과 영상</span>이
          자동으로 정리된 결과물입니다.
        </p>

        <%# 마스타헤드 마퀴 — 최대 10장 %>
        <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px;">
        <% @featured_moments.first(10).each_with_index do |photo, i| %>
          <% next unless photo.image.attached? %>
          <% link = "/" + photo.member.slug.to_s %>
          <% aspect = (i.zero? || i == 5) ? "3/4" : "1/1" %>
          <a href="<%= link %>" style="display: block; text-decoration: none; position: relative; aspect-ratio: <%= aspect %>; overflow: hidden; background: var(--impd-ink); border: 1px solid var(--impd-rule); grid-row: span <%= (i.zero? || i == 5) ? 2 : 1 %>;">
            <% if photo.video? %>
              <video src="<%= photo.display_url %>"
                     style="width: 100%; height: 100%; object-fit: cover; display: block; background: #000;"
                     preload="metadata" muted playsinline loop
                     onmouseover="this.play()" onmouseout="this.pause(); this.currentTime=0;"></video>
            <% else %>
              <img src="<%= photo.thumbnail_url %>"
                   data-fallback="<%= photo.display_url %>"
                   onerror="if(this.dataset.fallback && this.src !== this.dataset.fallback){this.src=this.dataset.fallback;this.dataset.fallback='';}"
                   alt="<%= photo.member.name %>의 <%= photo.category %>"
                   style="width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 400ms ease;"
                   loading="lazy"
                   onmouseover="this.style.transform='scale(1.04)'"
                   onmouseout="this.style.transform='scale(1)'">
            <% end %>
            <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 10px 12px; background: linear-gradient(to top, rgba(15,13,11,0.85), transparent); color: #fff;">
              <div style="font-family: var(--impd-font-mono); font-size: 9px; letter-spacing: 1.2px; text-transform: uppercase; opacity: 0.75;">
                <%= photo.category %> · <%= photo.member.name %>
              </div>
            </div>
          </a>
        <% end %>
      </div>

        <div style="margin-top: 28px; display: flex; align-items: center; justify-content: center; gap: 14px;">
          <a href="#signup" class="impd-btn impd-btn-primary">내 페이지 만들기 →</a>
          <span style="font-family: var(--impd-font-mono); font-size: 11px; color: var(--impd-muted);">업로드 한 번 · 정리 자동</span>
        </div>
      </section>
    </div>
  <% end %>

  <!-- ── §06 Testimonials ───────────────────────── -->
  <section class="impd-wrap impd-section">
    <div class="impd-section-header">
      <span class="impd-label">§06</span>
      <span class="impd-display" style="font-size: 36px; flex: 1;">실제 사용자의 이야기.</span>
      <span class="impd-label-muted">2 STORIES</span>
    </div>
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0; border-top: 1px solid var(--impd-rule);">
      <% [
        ["사진 몇 장 올렸을 뿐인데, 수강생이 늘었어요. 처음으로 디자이너 없이 페이지가 생겼습니다.", "김다인", "요가 강사 · 성수동"],
        ["수료증을 어떻게 보여줘야 할지 몰랐는데, imPD가 알아서 깔끔하게 정리해줬어요.", "박민준", "도예 공방장 · 양평"]
      ].each_with_index do |(quote, name, meta), i| %>
        <div style="padding: 40px 32px; <%= 'border-left: 1px solid var(--impd-rule);' if i > 0 %>">
          <p class="impd-serif" style="font-size: 24px; line-height: 1.4; color: var(--impd-ink);">"<%= quote %>"</p>
          <div style="margin-top: 24px; display: flex; gap: 12px; align-items: center;">
            <span class="impd-display" style="font-size: 18px;"><%= name %></span>
            <span class="impd-label-muted"><%= meta %></span>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <!-- ── §07 Reward Feature Band (C2 Starbucks-style dark green) ───────────────────────── -->
  <section id="pricing" class="impd-c2-band impd-stripe" style="padding: 80px 40px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div class="impd-label" style="color: var(--impd-gold); margin-bottom: 18px;" id="faq">§07 · imPD 리워드</div>
      <h2 class="impd-display" style="font-size: clamp(36px, 5vw, 56px); color: var(--impd-on-dark); max-width: 860px; margin-bottom: 12px;">
        오래 쓸수록 더 예뻐지는 페이지.
      </h2>
      <p style="color: var(--impd-on-dark-soft); font-size: 16px; line-height: 1.6; max-width: 720px;">
        첫 페이지를 연 순간부터 방문 수·후기·수료증이 쌓입니다. imPD는 그 기록을 <span class="impd-serif" style="color: var(--impd-gold);">골드 레이어</span>로 페이지 위에 얹어드려요.
      </p>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-top: 40px;">
        <% [
          ["FREE", "누구나 무료", "0원 / 월", ["공개 페이지 1개", "QR · 디지털 명함", "방문자 분석", "AI 자동 정리 · 3회"], false],
          ["PRO", "1인 사업가 기본", "9,900원 / 월", ["무제한 갤러리", "AI 자동 정리 · 무제한", "맞춤 도메인", "후기·예약 수집", "리워드 골드 배지"], true],
          ["STUDIO", "공방 · 소수팀", "29,000원 / 월", ["Pro 전부 +", "최대 5인 공동 편집", "클래스 예약·결제", "월간 성과 리포트"], false],
        ].each do |tag, title, price, features, highlight| %>
          <div style="background: <%= highlight ? 'var(--impd-gold-light)' : 'var(--impd-card)' %>; color: var(--impd-ink); border-radius: 12px; padding: 28px 24px; box-shadow: var(--impd-shadow-card); position: relative; <%= 'outline: 2px solid var(--impd-gold);' if highlight %>">
            <% if highlight %>
              <span style="position: absolute; top: -10px; right: 20px; background: var(--impd-gold); color: var(--impd-ink); font-size: 10px; font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase; padding: 4px 10px; border-radius: 50px;">추천</span>
            <% end %>
            <div class="impd-label" style="color: <%= highlight ? 'var(--impd-gold)' : 'var(--impd-green)' %>;"><%= tag %></div>
            <div class="impd-display" style="font-size: 22px; margin: 8px 0 4px; color: var(--impd-green);"><%= title %></div>
            <div class="impd-display" style="font-size: 28px; margin-bottom: 20px;"><%= price %></div>
            <ul style="list-style: none; padding: 0; margin: 0 0 24px; display: flex; flex-direction: column; gap: 10px;">
              <% features.each do |f| %>
                <li style="display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: var(--impd-ink);">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" style="flex-shrink: 0; margin-top: 2px;"><path d="M4 12l5 5L20 6" stroke="<%= highlight ? '#cba258' : '#00754A' %>" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span><%= f %></span>
                </li>
              <% end %>
            </ul>
            <%= link_to (highlight ? "Pro 시작하기 →" : "#{tag} 시작"), member_signup_path,
                class: "impd-btn #{highlight ? 'impd-btn-accent' : 'impd-btn-outlined'}",
                style: "width: 100%;" %>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <!-- ── §09 Final CTA — C2 house green band ───────────────────────── -->
  <section class="impd-wrap impd-section">
    <div class="impd-stripe" style="background: var(--impd-green-house); color: var(--impd-on-dark); padding: 80px 60px; position: relative; overflow: hidden; border-radius: 12px;">
      <div class="impd-label" style="color: var(--impd-gold); margin-bottom: 24px;">§09 · 시작</div>
      <h2 class="impd-display" style="font-size: clamp(44px, 7vw, 88px); color: var(--impd-on-dark); max-width: 900px;">
        지금 가지고 있는<br>
        <span class="impd-serif" style="color: var(--impd-gold);">자료 한 장</span>으로<br>
        시작하세요.
      </h2>
      <div style="margin-top: 48px; display: flex; gap: 16px; align-items: center; flex-wrap: wrap;">
        <%= link_to "내 페이지 만들기 →", member_signup_path,
            class: "impd-btn impd-btn-primary impd-btn-lg" %>
        <%= link_to "예시 먼저 보기", "/choi-pd",
            class: "impd-btn", style: "background: transparent; color: var(--impd-on-dark); border: 1px solid var(--impd-on-dark);" %>
        <span class="impd-label-muted" style="color: var(--impd-on-dark-soft);">카드 등록 불필요 · 언제든 비공개</span>
      </div>
    </div>
  </section>

  <!-- ── Footer ───────────────────────── -->
  <footer style="border-top: 1px solid var(--impd-rule); margin-top: 0; padding: 32px 40px 60px; display: flex; gap: 32px; flex-wrap: wrap; align-items: center; font-family: var(--impd-font-mono); font-size: 10px; letter-spacing: 1.2px; text-transform: uppercase; color: var(--impd-muted);">
    <span class="impd-display" style="font-size: 16px; text-transform: none; color: var(--impd-ink);">
      imPD<span style="color: var(--impd-accent);">.</span>
    </span>
    <span>vol. 04 · 2026</span>
    <span style="flex: 1;">강사·공방·아티스트를 위한 홍보 페이지</span>
    <%= link_to "이용약관", terms_path, class: "text-muted" %>
    <%= link_to "개인정보", privacy_path, class: "text-muted" %>
    <span>hello@impd.page</span>
  </footer>
</div>

<script>
  // 회전 단어 (Stimulus 대체로 inline)
  (function() {
    const target = document.querySelector('[data-impd-rotator-target="word"]');
    if (!target) return;
    const words = ['강사', '공방장', '작가', '셀러', '코치', '유튜버', '디렉터', '장인'];
    let i = 0;
    setInterval(() => {
      i = (i + 1) % words.length;
      target.style.transition = 'opacity 200ms';
      target.style.opacity = '0';
      setTimeout(() => {
        target.textContent = words[i] + '입니다.';
        target.style.opacity = '1';
      }, 220);
    }, 1800);
  })();
</script>
