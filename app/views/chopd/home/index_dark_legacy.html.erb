<% content_for :title, "홈" %>

<style>
  /* ── 히어로 ──────────────────────────────── */
  #hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow: hidden;
    padding-top: 80px;
  }
  /* 그라디언트 배경 */
  #hero::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 70% 80% at 20% 30%, rgba(255,77,28,.15) 0%, transparent 60%),
      radial-gradient(ellipse 60% 60% at 85% 70%, rgba(61,80,128,.35) 0%, transparent 60%);
    z-index: 0;
  }

  .hero-left {
    position: relative; z-index: 1;
    display: flex; flex-direction: column; justify-content: center;
    padding: 60px 64px;
  }
  .hero-right {
    position: relative; z-index: 1;
    display: flex; align-items: center; justify-content: center;
    padding: 60px 48px;
  }

  /* 배경 대형 텍스트 */
  .hero-bg-text {
    position: absolute;
    font-family: 'Black Han Sans', sans-serif;
    font-size: clamp(120px, 18vw, 200px);
    color: rgba(255,255,255,0.03);
    letter-spacing: -0.06em;
    line-height: 1;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    white-space: nowrap;
    pointer-events: none; z-index: 0;
  }

  .hero-label {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 11px; font-weight: 700; letter-spacing: .14em;
    text-transform: uppercase; color: rgba(255,255,255,.45);
    margin-bottom: 28px;
  }
  .hero-label span { width: 32px; height: 1px; background: #ff4d1c; display: inline-block; }
  .hero-label em { color: #ff4d1c; font-style: normal; }

  .hero-title {
    font-family: 'Black Han Sans', sans-serif;
    font-size: clamp(3rem, 5.5vw, 5.5rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin-bottom: 32px;
  }
  .hero-title .word-coral { color: #ff4d1c; }

  .hero-desc {
    font-size: 16px; color: rgba(255,255,255,.55); line-height: 1.85;
    max-width: 420px; margin-bottom: 40px;
  }
  .hero-desc strong { color: rgba(255,255,255,.9); font-weight: 600; }

  .hero-btns { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 48px; }

  .btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    background: #ff4d1c; color: #fff;
    padding: 14px 28px; border-radius: 999px;
    font-size: 14px; font-weight: 700;
    text-decoration: none; transition: all .25s;
    border: none; cursor: pointer;
  }
  .btn-primary:hover { background: #ff7850; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(255,77,28,.4); }

  .btn-ghost {
    display: inline-flex; align-items: center; gap: 8px;
    background: transparent; color: rgba(255,255,255,.8);
    padding: 14px 28px; border-radius: 999px;
    font-size: 14px; font-weight: 600;
    text-decoration: none; transition: all .25s;
    border: 1.5px solid rgba(255,255,255,.2);
  }
  .btn-ghost:hover { border-color: rgba(255,255,255,.6); color: #fff; background: rgba(255,255,255,.06); }

  /* 히어로 스탯 */
  .hero-stats { display: flex; gap: 36px; }
  .hero-stat-num {
    font-family: 'Black Han Sans', sans-serif;
    font-size: 2.2rem; line-height: 1;
    background: linear-gradient(135deg, #fff 30%, rgba(255,255,255,.5));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .hero-stat-label { font-size: 12px; color: rgba(255,255,255,.4); margin-top: 4px; }

  /* 프로필 카드 */
  .profile-card {
    background: rgba(255,255,255,.06);
    backdrop-filter: blur(24px);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 28px;
    padding: 36px;
    width: 100%; max-width: 340px;
    transform: rotate(-3deg);
    transition: transform .4s cubic-bezier(.34,1.56,.64,1);
  }
  .profile-card:hover { transform: rotate(0deg) scale(1.02); }
  .profile-avatar {
    width: 80px; height: 80px; border-radius: 50%;
    background: linear-gradient(135deg, #ff4d1c, #ff8050);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 20px;
    box-shadow: 0 12px 32px rgba(255,77,28,.4);
    font-family: 'Black Han Sans', sans-serif; font-size: 32px; color: #fff;
  }
  .profile-name { font-family: 'Black Han Sans', sans-serif; font-size: 22px; margin-bottom: 4px; }
  .profile-role { font-size: 12px; color: rgba(255,255,255,.45); margin-bottom: 24px; line-height: 1.6; }
  .tag-cloud { display: flex; flex-wrap: wrap; gap: 8px; }

  /* 플로팅 배지 */
  .float-badge {
    position: absolute;
    background: rgba(10,14,26,.85);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 16px;
    padding: 12px 18px;
    display: flex; align-items: center; gap: 10px;
    font-size: 13px; font-weight: 600;
  }
  .float-badge-top    { top: 20%; right: -12px; }
  .float-badge-bottom { bottom: 24%; right: -16px; }

  /* ── 마퀴 ────────────────────────────────── */
  #marquee {
    background: #ff4d1c;
    padding: 14px 0;
    overflow: hidden;
  }
  .marquee-item {
    display: inline-flex; align-items: center; gap: 16px;
    padding: 0 20px;
    font-size: 14px; font-weight: 700; white-space: nowrap; color: #fff;
  }
  .marquee-dot { color: rgba(255,255,255,.5); font-size: 18px; }

  /* ── Identity 섹션 ───────────────────────── */
  #identity { padding: 120px 48px; }
  .identity-header { margin-bottom: 64px; }
  .identity-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1200px; margin: 0 auto;
  }
  .ic-card {
    position: relative; border-radius: 24px; padding: 40px 36px;
    overflow: hidden; cursor: pointer;
    transition: transform .3s, box-shadow .3s;
  }
  .ic-card:hover { transform: translateY(-6px); box-shadow: 0 24px 48px rgba(0,0,0,.3); }
  .ic-education { background: linear-gradient(135deg, #1a0f2e, #2d1852); border: 1px solid rgba(168,255,62,.15); }
  .ic-media     { background: linear-gradient(135deg, #0f2014, #1a4020); border: 1px solid rgba(74,222,128,.15); }
  .ic-works     { background: linear-gradient(135deg, #1a0a0a, #3d1010); border: 1px solid rgba(255,77,28,.2); }
  .ic-number {
    position: absolute; top: 20px; right: 24px;
    font-family: 'Black Han Sans', sans-serif; font-size: 80px;
    opacity: .08; line-height: 1;
  }
  .ic-icon {
    width: 56px; height: 56px; border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 24px;
  }
  .ic-title {
    font-family: 'Black Han Sans', sans-serif;
    font-size: 22px; letter-spacing: -0.01em; margin-bottom: 12px;
  }
  .ic-desc { font-size: 14px; color: rgba(255,255,255,.5); line-height: 1.85; margin-bottom: 28px; }
  .ic-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 13px; font-weight: 700; color: inherit; text-decoration: none;
    opacity: .65; transition: opacity .2s;
  }
  .ic-link:hover { opacity: 1; }

  /* ── 숫자 섹션 ───────────────────────────── */
  #numbers { padding: 0; }
  .stats-strip {
    display: grid; grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid rgba(255,255,255,.06);
    border-bottom: 1px solid rgba(255,255,255,.06);
    max-width: 1200px; margin: 0 auto;
  }
  .stat-box {
    padding: 60px 40px; text-align: center;
    border-right: 1px solid rgba(255,255,255,.06);
    transition: background .3s;
  }
  .stat-box:last-child { border-right: none; }
  .stat-box:hover { background: rgba(255,255,255,.04); }
  .stat-num {
    font-family: 'Black Han Sans', sans-serif;
    font-size: clamp(3rem, 5vw, 5rem); line-height: 1; margin-bottom: 8px;
  }
  .stat-unit { font-size: .6em; }
  .stat-label { font-size: 13px; color: rgba(255,255,255,.4); }

  /* ── 강좌 섹션 ───────────────────────────── */
  #courses { padding: 120px 48px; }
  .courses-header {
    display: flex; align-items: flex-end; justify-content: space-between;
    margin-bottom: 48px; max-width: 1200px; margin-left: auto; margin-right: auto;
  }
  .courses-scroll {
    display: flex; gap: 24px; overflow-x: auto; padding-bottom: 16px;
    max-width: 1200px; margin: 0 auto;
    scrollbar-width: thin; scrollbar-color: rgba(255,255,255,.1) transparent;
  }
  .course-card {
    min-width: 280px; border-radius: 20px; overflow: hidden;
    background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08);
    flex-shrink: 0; transition: transform .3s, box-shadow .3s;
  }
  .course-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(0,0,0,.3); }
  .course-thumb {
    height: 160px;
    display: flex; align-items: center; justify-content: center;
    font-size: 48px;
  }
  .course-body { padding: 20px; }
  .course-badge {
    display: inline-block; padding: 3px 10px; border-radius: 999px;
    font-size: 11px; font-weight: 700; letter-spacing: .04em; margin-bottom: 10px;
  }
  .badge-online  { background: rgba(168,255,62,.12); color: #a8ff3e; }
  .badge-offline { background: rgba(240,192,64,.12); color: #f0c040; }
  .badge-b2b     { background: rgba(255,77,28,.12); color: #ff7850; }
  .course-title { font-size: 15px; font-weight: 700; margin-bottom: 8px; line-height: 1.4; }
  .course-desc  { font-size: 13px; color: rgba(255,255,255,.45); margin-bottom: 16px; line-height: 1.6; }
  .course-footer { display: flex; align-items: center; justify-content: space-between; }
  .course-price  { font-family: 'Black Han Sans', sans-serif; font-size: 18px; color: #f0c040; }
  .course-btn {
    background: rgba(255,77,28,.15); color: #ff7850;
    padding: 7px 16px; border-radius: 999px; font-size: 12px; font-weight: 700;
    text-decoration: none; transition: all .2s; border: 1px solid rgba(255,77,28,.25);
  }
  .course-btn:hover { background: #ff4d1c; color: #fff; border-color: #ff4d1c; }

  /* ── CTA 섹션 ────────────────────────────── */
  #cta-section {
    padding: 120px 48px; text-align: center;
    background:
      radial-gradient(ellipse 60% 80% at 50% 50%, rgba(255,77,28,.12) 0%, transparent 60%),
      rgba(255,255,255,.01);
  }
  .cta-title {
    font-family: 'Black Han Sans', sans-serif;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 24px;
  }
  .cta-title .line2 { color: #ff4d1c; }
  .cta-desc { font-size: 16px; color: rgba(255,255,255,.5); max-width: 480px; margin: 0 auto 40px; line-height: 1.8; }

  /* 뉴스레터 폼 */
  .newsletter-form {
    display: flex; gap: 12px; max-width: 420px; margin: 0 auto;
  }
  .newsletter-input {
    flex: 1; background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.12);
    border-radius: 999px; padding: 13px 22px; color: #fff; font-size: 14px; outline: none;
    transition: border-color .2s;
  }
  .newsletter-input:focus { border-color: rgba(255,77,28,.5); }
  .newsletter-input::placeholder { color: rgba(255,255,255,.3); }
  .newsletter-btn {
    background: #ff4d1c; color: #fff; border: none; cursor: pointer;
    padding: 13px 26px; border-radius: 999px; font-size: 14px; font-weight: 700;
    transition: all .2s;
  }
  .newsletter-btn:hover { background: #ff7850; transform: translateY(-1px); }
  .newsletter-hint { font-size: 12px; color: rgba(255,255,255,.3); margin-top: 16px; }

  /* 반응형 */
  @media (max-width: 1024px) {
    #hero { grid-template-columns: 1fr; min-height: auto; padding: 120px 24px 60px; }
    .hero-right { display: none; }
    .hero-left { padding: 0; }
    .identity-grid { grid-template-columns: 1fr; }
    .stats-strip { grid-template-columns: repeat(2, 1fr); }
    #identity, #courses, #cta-section { padding: 80px 24px; }
  }
  @media (max-width: 640px) {
    .stats-strip { grid-template-columns: repeat(2, 1fr); }
    .hero-stats { gap: 24px; }
    .hero-btns { flex-direction: column; }
    .newsletter-form { flex-direction: column; }
  }
</style>

<!-- ══ HERO ══════════════════════════════════════════ -->
<section id="hero">
  <div class="hero-bg-text" aria-hidden="true">imPD</div>

  <!-- 왼쪽: 텍스트 -->
  <div class="hero-left">
    <div class="hero-label">
      <span></span>
      <em>Personal Brand</em>
      <span style="color:rgba(255,255,255,.2)">·</span>
      Since 2017
    </div>

    <h1 class="hero-title">
      스마트폰<br>
      하나로<br>
      <span class="word-coral" id="word-swap">창업</span> 하다
    </h1>

    <p class="hero-desc">
      <strong>최범희 PD</strong>와 함께라면 기술 몰라도 괜찮습니다.<br>
      8년, 2,400명의 인생 2막을 함께 열었습니다.<br>
      지금 당신 차례입니다.
    </p>

    <div class="hero-btns">
      <%= link_to education_path, class: "btn-primary" do %>
        <svg width="15" height="15" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        강좌 시작하기
      <% end %>
      <%= link_to "#identity", class: "btn-ghost" do %>
        스토리 보기
        <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      <% end %>
    </div>

    <div class="hero-stats">
      <div>
        <div class="hero-stat-num">2,400+</div>
        <div class="hero-stat-label">누적 수강생</div>
      </div>
      <div style="width:1px;background:rgba(255,255,255,.1)"></div>
      <div>
        <div class="hero-stat-num">8년</div>
        <div class="hero-stat-label">강의 경력</div>
      </div>
      <div style="width:1px;background:rgba(255,255,255,.1)"></div>
      <div>
        <div class="hero-stat-num">98%</div>
        <div class="hero-stat-label">수강생 만족도</div>
      </div>
    </div>
  </div>

  <!-- 오른쪽: 프로필 카드 -->
  <div class="hero-right">
    <div style="position:relative;">
      <!-- 프로필 카드 -->
      <div class="profile-card">
        <div class="profile-avatar">최</div>
        <div class="profile-name">최범희 PD</div>
        <div class="profile-role">스마트폰 창업 전략가<br>한국환경저널 발행인 · 작가</div>
        <div class="tag-cloud">
          <span class="tag">유튜브</span>
          <span class="tag">SNS 마케팅</span>
          <span class="tag">창업 전략</span>
          <span class="tag">환경저널</span>
          <span class="tag">저자</span>
          <span class="tag">B2B 강연</span>
        </div>
      </div>

      <!-- 플로팅 배지 -->
      <div class="float-badge float-badge-top">
        <span style="font-size:16px;">🎯</span>
        <div>
          <div style="font-size:11px;color:rgba(255,255,255,.45);">수강생 만족도</div>
          <div style="font-size:15px;font-weight:700;">98%</div>
        </div>
      </div>
      <div class="float-badge float-badge-bottom">
        <span style="font-size:16px;">📚</span>
        <div>
          <div style="font-size:11px;color:rgba(255,255,255,.45);">출간 저서</div>
          <div style="font-size:15px;font-weight:700;">5권</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ MARQUEE ════════════════════════════════════════ -->
<div id="marquee" aria-hidden="true">
  <div class="marquee-track">
    <% 2.times do %>
      <span class="marquee-item">스마트폰 창업 <span class="marquee-dot">★</span></span>
      <span class="marquee-item">유튜브 채널 운영 <span class="marquee-dot">★</span></span>
      <span class="marquee-item">SNS 마케팅 전략 <span class="marquee-dot">★</span></span>
      <span class="marquee-item">한국환경저널 <span class="marquee-dot">★</span></span>
      <span class="marquee-item">B2B 기업 교육 <span class="marquee-dot">★</span></span>
      <span class="marquee-item">스마트폰 스케치 <span class="marquee-dot">★</span></span>
      <span class="marquee-item">2,400명 배출 <span class="marquee-dot">★</span></span>
    <% end %>
  </div>
</div>

<!-- ══ IDENTITY ═══════════════════════════════════════ -->
<section id="identity">
  <div style="max-width:1200px;margin:0 auto;">
    <div class="identity-header reveal">
      <div class="section-label">Identity</div>
      <h2 style="font-family:'Black Han Sans',sans-serif;font-size:clamp(2.2rem,4vw,3.8rem);letter-spacing:-0.02em;line-height:1.15;margin-bottom:16px;">
        최PD는 세 가지 얼굴을<br>가지고 있습니다
      </h2>
      <p style="font-size:16px;color:rgba(255,255,255,.5);max-width:480px;line-height:1.85;">
        교육가, 미디어 발행인, 작가. 세 가지 정체성이 하나의 브랜드를 만듭니다.
      </p>
    </div>

    <div class="identity-grid">
      <!-- 교육 -->
      <div class="ic-card ic-education reveal reveal-delay-1">
        <div class="ic-number">01</div>
        <div class="ic-icon" style="background:rgba(168,255,62,.12);">
          <svg width="26" height="26" viewBox="0 0 24 24" stroke="#a8ff3e" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <div class="ic-title">스마트폰 창업 교육가</div>
        <div class="ic-desc">
          스마트폰 하나로 시작하는 창업의 모든 것.<br>
          온라인, 오프라인, B2B 기업 교육까지.<br>
          8년간 2,400명의 실제 창업을 이끌었습니다.
        </div>
        <%= link_to education_path, class: "ic-link" do %>
          강좌 보기
          <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        <% end %>
      </div>

      <!-- 미디어 -->
      <div class="ic-card ic-media reveal reveal-delay-2">
        <div class="ic-number">02</div>
        <div class="ic-icon" style="background:rgba(74,222,128,.12);">
          <svg width="26" height="26" viewBox="0 0 24 24" stroke="#4ade80" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
        </div>
        <div class="ic-title">한국환경저널 발행인</div>
        <div class="ic-desc">
          환경 이슈를 쉽게 풀어 전하는 전문 미디어.<br>
          발행인으로서 직접 기획하고 글을 씁니다.<br>
          독자와 나누는 환경 이야기.
        </div>
        <%= link_to media_path, class: "ic-link" do %>
          저널 보기
          <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        <% end %>
      </div>

      <!-- 작품 -->
      <div class="ic-card ic-works reveal reveal-delay-3">
        <div class="ic-number">03</div>
        <div class="ic-icon" style="background:rgba(255,77,28,.12);">
          <svg width="26" height="26" viewBox="0 0 24 24" stroke="#ff7850" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
        </div>
        <div class="ic-title">작가 · 스케치 아티스트</div>
        <div class="ic-desc">
          스마트폰 스케치 작가로서의 또 다른 얼굴.<br>
          5권의 저서를 출간한 실용서 작가.<br>
