  <div class="stats-strip reveal">
    <div class="stat-box">
      <div class="stat-num" style="color:#ff4d1c;" data-count="2400" data-suffix="+">0</div>
      <div class="stat-label">누적 수강생</div>
    </div>
    <div class="stat-box">
      <div class="stat-num" style="color:#f0c040;" data-count="8" data-suffix="년">0</div>
      <div class="stat-label">강의 경력</div>
    </div>
    <div class="stat-box">
      <div class="stat-num" style="color:#a8ff3e;" data-count="98" data-suffix="%">0</div>
      <div class="stat-label">수강생 만족도</div>
    </div>
    <div class="stat-box">
      <div class="stat-num" style="color:#60a5fa;" data-count="5" data-suffix="권">0</div>
