<!-- ══ COURSES ════════════════════════════════════════ -->
<section id="courses">
  <div class="courses-header reveal">
    <div>
      <div class="section-label">Courses</div>
      <h2 style="font-family:'Black Han Sans',sans-serif;font-size:clamp(2.2rem,4vw,3.5rem);letter-spacing:-0.02em;margin-bottom:0;">지금 인기 강좌</h2>
    </div>
    <%= link_to education_path, style: "display:inline-flex;align-items:center;gap:6px;font-size:14px;font-weight:600;color:rgba(255,255,255,.55);text-decoration:none;transition:color .2s;" do %>
      전체 보기
      <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    <% end %>
  </div>

  <div class="courses-scroll">
    <% if @latest_courses.any? %>
      <% @latest_courses.each do |course| %>
        <div class="course-card">
          <div class="course-thumb" style="background: <%= %w[#1a1435 #0d2410 #1a0808 #0d1a3a #1a1200].sample %>;">
            <%= %w[📱 📣 🏫 💰 ✍️].sample %>
          </div>
          <div class="course-body">
            <span class="course-badge <%= course.course_type == 'online' ? 'badge-online' : course.course_type == 'offline' ? 'badge-offline' : 'badge-b2b' %>">
              <%= course.course_type == 'online' ? '온라인' : course.course_type == 'offline' ? '오프라인' : 'B2B' %>
            </span>
            <div class="course-title"><%= course.title %></div>
            <div class="course-desc"><%= truncate(course.description.to_s, length: 55) %></div>
            <div class="course-footer">
              <div class="course-price">
                <% if course.price.to_i > 0 %>
                  ₩<%= number_with_delimiter(course.price) %>
                <% else %>
                  별도 문의
                <% end %>
              </div>
              <% if course.external_link.present? %>
                <%= link_to "수강 신청", course.external_link, target: "_blank", rel: "noopener", class: "course-btn" %>
              <% else %>
                <%= link_to "문의하기", new_inquiry_path, class: "course-btn" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <!-- 기본 샘플 카드 -->
      <% [
        { emoji: "📱", bg: "#1a1435", badge: "badge-online", type: "온라인 · 입문", title: "유튜브 채널 시작하기", desc: "스마트폰으로 촬영부터 편집, 업로드까지", price: "₩89,000" },
        { emoji: "📣", bg: "#0d2410", badge: "badge-online", type: "온라인 · 중급", title: "SNS 마케팅 완성 패키지", desc: "인스타그램·블로그·유튜브 통합 SNS 전략", price: "₩129,000" },
        { emoji: "🏫", bg: "#1a0808", badge: "badge-b2b",    type: "오프라인 · B2B", title: "기업 맞춤 집중 교육", desc: "기관·기업 임직원 단체 교육. 맞춤 커리큘럼", price: "별도 문의" },
        { emoji: "💰", bg: "#0d1a3a", badge: "badge-online", type: "온라인 · 고급", title: "스마트폰 수익화 전략", desc: "유튜브 광고·제휴마케팅·디지털 상품 판매", price: "₩199,000" },
      ].each do |c| %>
        <div class="course-card">
          <div class="course-thumb" style="background:<%= c[:bg] %>;"><%= c[:emoji] %></div>
          <div class="course-body">
            <span class="course-badge <%= c[:badge] %>"><%= c[:type] %></span>
            <div class="course-title"><%= c[:title] %></div>
            <div class="course-desc"><%= c[:desc] %></div>
            <div class="course-footer">
              <div class="course-price"><%= c[:price] %></div>
              <%= link_to "수강 신청", new_inquiry_path, class: "course-btn" %>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</section>

<!-- ══ CTA / NEWSLETTER ═══════════════════════════════ -->
<section id="cta-section">
  <div class="reveal" style="max-width:680px;margin:0 auto;">
    <div class="section-label" style="justify-content:center;">Newsletter</div>
    <h2 class="cta-title">
      매달 창업 인사이트를<br>
      <span class="line2">무료로 받아보세요</span>
    </h2>
    <p class="cta-desc">
      최PD의 월간 창업 노하우, SNS 트렌드, 수익화 팁을<br>이메일로 전달합니다.
    </p>

    <%= turbo_frame_tag "newsletter_form" do %>
      <%= form_with url: leads_path, data: { turbo_frame: "newsletter_form" }, html: { class: "newsletter-form" } do |f| %>
        <%= f.email_field :email, placeholder: "이메일 주소를 입력하세요", class: "newsletter-input", required: true %>
        <%= f.submit "구독하기", class: "newsletter-btn" %>
      <% end %>
    <% end %>

    <p class="newsletter-hint">이미 <strong style="color:rgba(255,255,255,.6)">1,248명</strong>이 구독 중입니다 · 언제든 해지 가능</p>
  </div>
</section>

<script>
  // Word swap
  const words = ['창업', '성공', '수익', '도전', '성장'];
  const colors = ['#ff4d1c', '#f0c040', '#a8ff3e', '#60a5fa', '#ff4d1c'];
  let wi = 0;
  const wordEl = document.getElementById('word-swap');
  if (wordEl) {
    setInterval(() => {
      wi = (wi + 1) % words.length;
      wordEl.style.opacity = '0';
      wordEl.style.transform = 'translateY(-10px)';
      setTimeout(() => {
        wordEl.textContent = words[wi];
        wordEl.style.color = colors[wi];
        wordEl.style.opacity = '1';
        wordEl.style.transform = 'translateY(0)';
        wordEl.style.transition = 'opacity .3s, transform .3s, color .3s';
      }, 300);
    }, 2400);
  }

  // 카운터 애니메이션
  const countEls = document.querySelectorAll('[data-count]');
  const countObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target;
      const target = parseInt(el.dataset.count);
      const suffix = el.dataset.suffix || '';
      const duration = 1800;
      const step = target / (duration / 16);
      let current = 0;
      const timer = setInterval(() => {
        current = Math.min(current + step, target);
        el.textContent = Math.floor(current).toLocaleString() + suffix;
        if (current >= target) clearInterval(timer);
      }, 16);
      countObserver.unobserve(el);
    });
  }, { threshold: 0.5 });
  countEls.forEach(el => countObserver.observe(el));
</script>
