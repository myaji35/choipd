<% content_for :title, "교육 과정" %>

<style>
  /* ── 교육 히어로 ─────────────────────────── */
  .edu-hero {
    min-height: 52vh;
    display: flex; align-items: center; justify-content: center;
    text-align: center;
    position: relative; overflow: hidden;
    padding: 120px 48px 80px;
  }
  .edu-hero::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 70% 80% at 30% 40%, rgba(168,255,62,.08) 0%, transparent 55%),
      radial-gradient(ellipse 60% 60% at 80% 60%, rgba(255,77,28,.1) 0%, transparent 55%);
  }
  .edu-hero-bg {
    position: absolute;
    font-family: 'Black Han Sans', sans-serif;
    font-size: clamp(100px, 16vw, 180px);
    color: rgba(255,255,255,.025); letter-spacing: -.06em; line-height: 1;
    top: 50%; left: 50%; transform: translate(-50%,-50%);
    white-space: nowrap; pointer-events: none; z-index: 0;
  }
  .edu-hero-content { position: relative; z-index: 1; }

  /* ── 필터 바 ─────────────────────────────── */
  .filter-bar {
    position: sticky; top: 64px; z-index: 100;
    background: rgba(10,14,26,.92);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,.06);
    padding: 16px 48px;
    display: flex; gap: 10px; align-items: center;
  }
  .filter-pill {
    padding: 8px 20px; border-radius: 999px;
    font-size: 13px; font-weight: 600;
    text-decoration: none; transition: all .2s;
    border: 1px solid rgba(255,255,255,.1);
    color: rgba(255,255,255,.5);
    background: transparent;
  }
  .filter-pill:hover { color: #fff; border-color: rgba(255,255,255,.3); }
  .filter-pill.active {
    background: #ff4d1c; color: #fff;
    border-color: #ff4d1c;
    box-shadow: 0 4px 16px rgba(255,77,28,.35);
  }
  .filter-pill.active-online  { background: #a8ff3e; color: #0a0e1a; border-color: #a8ff3e; box-shadow: 0 4px 16px rgba(168,255,62,.35); }
  .filter-pill.active-offline { background: #f0c040; color: #0a0e1a; border-color: #f0c040; box-shadow: 0 4px 16px rgba(240,192,64,.35); }
  .filter-pill.active-b2b    { background: #60a5fa; color: #0a0e1a; border-color: #60a5fa; box-shadow: 0 4px 16px rgba(96,165,250,.35); }

  /* ── 강좌 그리드 ─────────────────────────── */
  .courses-section { padding: 64px 48px 80px; }
  .courses-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    max-width: 1200px; margin: 0 auto;
  }
  .course-card {
    border-radius: 20px; overflow: hidden;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    transition: transform .3s, box-shadow .3s, border-color .3s;
    display: flex; flex-direction: column;
  }
  .course-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 48px rgba(0,0,0,.35);
    border-color: rgba(255,255,255,.15);
  }
  .course-thumb {
    height: 180px; position: relative; overflow: hidden;
    display: flex; align-items: center; justify-content: center; font-size: 52px;
  }
  .course-thumb-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(10,14,26,.7) 100%);
  }
  .course-type-badge {
    position: absolute; top: 14px; left: 14px;
    padding: 4px 12px; border-radius: 999px;
    font-size: 11px; font-weight: 700; letter-spacing: .04em;
  }
  .badge-online  { background: rgba(168,255,62,.9); color: #0a0e1a; }
  .badge-offline { background: rgba(240,192,64,.9); color: #0a0e1a; }
  .badge-b2b     { background: rgba(96,165,250,.9); color: #0a0e1a; }
  .course-body { padding: 24px; flex: 1; display: flex; flex-direction: column; }
  .course-title { font-size: 16px; font-weight: 700; line-height: 1.45; margin-bottom: 10px; }
  .course-desc  { font-size: 13px; color: rgba(255,255,255,.45); line-height: 1.75; flex: 1; margin-bottom: 20px; }
  .course-footer { display: flex; align-items: center; justify-content: space-between; padding-top: 16px; border-top: 1px solid rgba(255,255,255,.06); }
  .course-price { font-family: 'Black Han Sans', sans-serif; font-size: 20px; }
  .course-price.paid  { color: #f0c040; }
  .course-price.free  { color: #a8ff3e; font-size: 15px; }
  .course-price.inquiry { color: rgba(255,255,255,.4); font-size: 14px; }
  .course-cta {
    padding: 9px 20px; border-radius: 999px;
    font-size: 13px; font-weight: 700; text-decoration: none;
    transition: all .2s;
  }
  .cta-enroll { background: rgba(255,77,28,.15); color: #ff7850; border: 1px solid rgba(255,77,28,.25); }
  .cta-enroll:hover { background: #ff4d1c; color: #fff; border-color: #ff4d1c; }
  .cta-inquiry { background: rgba(96,165,250,.12); color: #93c5fd; border: 1px solid rgba(96,165,250,.2); }
  .cta-inquiry:hover { background: #60a5fa; color: #fff; border-color: #60a5fa; }

  /* 빈 상태 */
  .empty-state { text-align: center; padding: 80px 24px; color: rgba(255,255,255,.3); }

  /* ── B2B CTA 섹션 ─────────────────────────── */
  .b2b-section {
    padding: 100px 48px;
    background:
      radial-gradient(ellipse 70% 80% at 50% 50%, rgba(96,165,250,.08) 0%, transparent 60%),
      rgba(255,255,255,.01);
    border-top: 1px solid rgba(255,255,255,.06);
  }
  .b2b-inner { max-width: 760px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
  .b2b-perks { display: flex; flex-direction: column; gap: 20px; margin-top: 28px; }
  .b2b-perk  { display: flex; align-items: flex-start; gap: 14px; }
  .b2b-perk-dot {
    width: 8px; height: 8px; border-radius: 50%; background: #60a5fa;
    flex-shrink: 0; margin-top: 6px;
  }

  /* 반응형 */
  @media (max-width: 1024px) { .courses-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) {
    .courses-grid { grid-template-columns: 1fr; }
    .filter-bar, .courses-section, .b2b-section { padding-left: 20px; padding-right: 20px; }
    .b2b-inner { grid-template-columns: 1fr; gap: 40px; }
  }
</style>

<!-- ══ HERO ═══════════════════════════════════ -->
<section class="edu-hero">
  <div class="edu-hero-bg" aria-hidden="true">EDU</div>
  <div class="edu-hero-content reveal">
    <div class="section-label" style="justify-content:center;margin-bottom:20px;">Education</div>
    <h1 style="font-family:'Black Han Sans',sans-serif;font-size:clamp(2.8rem,5vw,5rem);letter-spacing:-0.02em;line-height:1.1;margin-bottom:20px;">
      스마트폰 하나로<br>
      <span style="color:#ff4d1c;">시작하는 창업</span>
    </h1>
    <p style="font-size:16px;color:rgba(255,255,255,.5);max-width:440px;margin:0 auto;line-height:1.8;">
      온라인·오프라인·B2B 맞춤 강좌로<br>나만의 창업 여정을 설계합니다.
    </p>
  </div>
</section>

<!-- ══ 필터 바 ═════════════════════════════════ -->
<div class="filter-bar">
  <%= link_to "전체", education_path,
      class: "filter-pill #{params[:type].blank? ? 'active' : ''}" %>
  <%= link_to "온라인", education_path(type: 'online'),
      class: "filter-pill #{params[:type] == 'online' ? 'active-online active' : ''}" %>
  <%= link_to "오프라인", education_path(type: 'offline'),
      class: "filter-pill #{params[:type] == 'offline' ? 'active-offline active' : ''}" %>
  <%= link_to "B2B/B2G", education_path(type: 'b2b'),
      class: "filter-pill #{params[:type] == 'b2b' ? 'active-b2b active' : ''}" %>
</div>

<!-- ══ 강좌 목록 ════════════════════════════════ -->
<section class="courses-section">
  <% if @courses.any? %>
    <div class="courses-grid">
      <% @courses.each_with_index do |course, i| %>
        <% thumbs  = %w[📱 📣 🏫 💰 ✍️ 🎬 📊 🌐]
           bgs     = %w[#1a1435 #0d2410 #1a0808 #0d1a3a #1a1200 #0a1a1a #1a0f2e #101a0d] %>
        <div class="course-card reveal reveal-delay-<%= (i % 3) + 1 %>">
          <!-- 섬네일 -->
          <div class="course-thumb" style="background:<%= bgs[i % bgs.size] %>;">
            <% if course.thumbnail_url.present? %>
              <%= image_tag course.thumbnail_url, class: "w-full h-full object-cover absolute inset-0", alt: course.title %>
            <% else %>
              <%= thumbs[i % thumbs.size] %>
            <% end %>
            <div class="course-thumb-overlay"></div>
            <span class="course-type-badge badge-<%= course.course_type %>">
              <%= course.course_type == 'online' ? '온라인' : course.course_type == 'offline' ? '오프라인' : 'B2B/B2G' %>
            </span>
          </div>

          <!-- 본문 -->
          <div class="course-body">
            <div class="course-title"><%= course.title %></div>
            <div class="course-desc"><%= truncate(course.description.to_s, length: 80) %></div>
            <div class="course-footer">
              <% if course.price.to_i > 0 %>
                <div class="course-price paid">₩<%= number_with_delimiter(course.price) %></div>
              <% elsif course.course_type == 'b2b' %>
                <div class="course-price inquiry">별도 문의</div>
              <% else %>
                <div class="course-price free">무료</div>
              <% end %>

              <% if course.external_link.present? %>
                <%= link_to "수강 신청", course.external_link, target: "_blank", rel: "noopener", class: "course-cta cta-enroll" %>
              <% else %>
                <%= link_to "문의하기", new_inquiry_path(type: 'b2b'), class: "course-cta cta-inquiry" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <div style="font-size:48px;margin-bottom:16px;">📚</div>
      <p style="font-size:15px;">등록된 강좌가 없습니다.</p>
      <p style="font-size:13px;margin-top:8px;color:rgba(255,255,255,.2);">곧 새로운 강좌가 추가될 예정입니다.</p>
    </div>
  <% end %>
</section>

<!-- ══ B2B/B2G CTA ══════════════════════════════ -->
<section class="b2b-section">
  <div class="b2b-inner">
    <!-- 텍스트 -->
    <div class="reveal">
      <div class="section-label">B2B / B2G</div>
      <h2 style="font-family:'Black Han Sans',sans-serif;font-size:clamp(1.8rem,3vw,2.8rem);letter-spacing:-0.02em;line-height:1.2;margin-bottom:12px;">
        기관·기업<br>맞춤 교육
      </h2>
      <p style="font-size:14px;color:rgba(255,255,255,.45);line-height:1.8;margin-bottom:28px;">
        지자체, 공공기관, 기업 임직원을 위한<br>방문 교육 프로그램을 제공합니다.
      </p>
      <div class="b2b-perks">
        <% [
          ["맞춤 커리큘럼 제공", "기관 특성에 맞게 100% 커스터마이징"],
          ["강사 직접 방문", "전국 어디든 출강 가능"],
          ["수료증 발급", "공식 수료증 및 교육 확인서 제공"],
        ].each do |title, desc| %>
          <div class="b2b-perk">
            <div class="b2b-perk-dot"></div>
            <div>
              <div style="font-size:14px;font-weight:700;margin-bottom:3px;"><%= title %></div>
              <div style="font-size:12px;color:rgba(255,255,255,.4);"><%= desc %></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- 문의 폼 -->
    <div class="reveal reveal-delay-2">
      <%= turbo_frame_tag "inquiry-form" do %>
        <%= render "chopd/inquiries/form", inquiry: @inquiry %>
      <% end %>
    </div>
  </div>
</section>
