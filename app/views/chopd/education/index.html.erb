<% content_for :title, "교육 과정" %>

<!-- 교육 히어로 -->
<section class="bg-gradient-to-br from-navy to-blue-800 py-16">
  <div class="max-w-7xl mx-auto px-4 text-center">
    <h1 class="text-4xl font-bold text-white mb-4">교육 과정</h1>
    <p class="text-blue-200 text-lg">스마트폰 창업 전략부터 B2B/B2G 특강까지</p>
  </div>
</section>

<!-- 필터 -->
<section class="bg-white border-b py-4">
  <div class="max-w-7xl mx-auto px-4 flex space-x-4">
    <%= link_to "전체", education_path, class: "px-4 py-2 rounded-full text-sm font-medium #{params[:type].blank? ? 'bg-primary text-white' : 'text-gray-500 hover:text-primary'}" %>
    <%= link_to "온라인", education_path(type: 'online'), class: "px-4 py-2 rounded-full text-sm font-medium #{params[:type] == 'online' ? 'bg-primary text-white' : 'text-gray-500 hover:text-primary'}" %>
    <%= link_to "오프라인", education_path(type: 'offline'), class: "px-4 py-2 rounded-full text-sm font-medium #{params[:type] == 'offline' ? 'bg-primary text-white' : 'text-gray-500 hover:text-primary'}" %>
    <%= link_to "B2B/B2G", education_path(type: 'b2b'), class: "px-4 py-2 rounded-full text-sm font-medium #{params[:type] == 'b2b' ? 'bg-primary text-white' : 'text-gray-500 hover:text-primary'}" %>
  </div>
</section>

<!-- 강좌 목록 -->
<section class="py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <% if @courses.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @courses.each do |course| %>
          <div class="bg-white border border-gray-100 rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
            <% if course.thumbnail_url.present? %>
              <div class="h-48 overflow-hidden bg-gray-100">
                <%= image_tag course.thumbnail_url, class: "w-full h-full object-cover", alt: course.title %>
              </div>
            <% else %>
              <div class="h-48 bg-gradient-to-br from-primary/15 to-primary/5 flex items-center justify-center">
                <svg class="w-16 h-16 text-primary/25" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="1">
                  <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
                </svg>
              </div>
            <% end %>
            <div class="p-5">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs bg-primary/10 text-primary px-2.5 py-1 rounded-full font-medium">
                  <%= course.course_type == 'online' ? '온라인' : course.course_type == 'offline' ? '오프라인' : 'B2B/B2G' %>
                </span>
                <% if course.price.present? && course.price > 0 %>
                  <span class="text-sm font-bold text-navy"><%= number_with_delimiter(course.price) %>원</span>
                <% else %>
                  <span class="text-sm text-green-600 font-bold">무료</span>
                <% end %>
              </div>
              <h3 class="font-bold text-navy mb-2"><%= course.title %></h3>
              <p class="text-gray-500 text-sm line-clamp-2 mb-4"><%= course.description %></p>
              <% if course.external_link.present? %>
                <%= link_to "수강 신청하기", course.external_link, target: "_blank", rel: "noopener noreferrer",
                    class: "block w-full text-center bg-primary text-white py-2.5 rounded-lg font-medium hover:bg-primary-dark transition-colors text-sm" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16 text-gray-400">
        <svg class="w-16 h-16 mx-auto mb-4 text-gray-200" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="1">
          <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
        </svg>
        <p>등록된 강좌가 없습니다.</p>
      </div>
    <% end %>
  </div>
</section>

<!-- B2B/B2G 문의 섹션 -->
<section class="py-16 bg-surface">
  <div class="max-w-3xl mx-auto px-4">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold text-navy mb-4">B2B/B2G 기관 문의</h2>
      <p class="text-gray-500">기업, 기관, 지자체를 위한 맞춤형 교육 과정을 제안해 드립니다.</p>
    </div>

    <%= turbo_frame_tag "inquiry-form" do %>
      <%= render "chopd/inquiries/form", inquiry: @inquiry %>
    <% end %>
  </div>
</section>
