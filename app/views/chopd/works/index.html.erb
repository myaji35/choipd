<% content_for :title, "작품" %>

<style>
  /* ── 작품 히어로 ─────────────────────────── */
  .works-hero {
    min-height: 52vh;
    display: flex; align-items: center; justify-content: center;
    text-align: center;
    position: relative; overflow: hidden;
    padding: 120px 48px 80px;
  }
  .works-hero::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 70% 80% at 20% 40%, rgba(168,255,62,.07) 0%, transparent 55%),
      radial-gradient(ellipse 60% 60% at 85% 55%, rgba(240,192,64,.09) 0%, transparent 55%);
  }
  .works-hero-bg {
    position: absolute;
    font-family: 'Black Han Sans', sans-serif;
    font-size: clamp(100px, 16vw, 180px);
    color: rgba(255,255,255,.025); letter-spacing: -.06em; line-height: 1;
    top: 50%; left: 50%; transform: translate(-50%,-50%);
    white-space: nowrap; pointer-events: none; z-index: 0;
  }
  .works-hero-content { position: relative; z-index: 1; }

  /* ── 탭 바 ─────────────────────────────── */
  .tab-bar {
    position: sticky; top: 64px; z-index: 100;
    background: rgba(10,14,26,.92);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,.06);
    padding: 16px 48px;
    display: flex; gap: 10px; align-items: center;
  }
  .tab-pill {
    padding: 8px 24px; border-radius: 999px;
    font-size: 13px; font-weight: 600;
    cursor: pointer; transition: all .2s;
    border: 1px solid rgba(255,255,255,.1);
    color: rgba(255,255,255,.5);
    background: transparent;
  }
  .tab-pill:hover { color: #fff; border-color: rgba(255,255,255,.3); }
  .tab-pill.active {
    background: #f0c040; color: #0a0e1a;
    border-color: #f0c040;
    box-shadow: 0 4px 16px rgba(240,192,64,.35);
  }

  /* ── 갤러리 섹션 ─────────────────────────── */
  .works-section { padding: 64px 48px 80px; }

  /* 저서 그리드 */
  .books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 32px;
    max-width: 1000px; margin: 0 auto 80px;
  }
  .book-card {
    display: flex; flex-direction: column; align-items: center; gap: 16px;
    text-align: center;
    transition: transform .3s;
  }
  .book-card:hover { transform: translateY(-6px); }
  .book-cover {
    width: 100%; aspect-ratio: 3/4;
    border-radius: 12px; overflow: hidden;
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.1);
    display: flex; align-items: center; justify-content: center;
    font-size: 56px;
    position: relative;
    box-shadow: 4px 8px 24px rgba(0,0,0,.4);
  }
  .book-cover img { width: 100%; height: 100%; object-fit: cover; }
  .book-title { font-weight: 700; font-size: 14px; line-height: 1.5; }
  .book-desc  { font-size: 12px; color: rgba(255,255,255,.4); line-height: 1.7; }

  /* Masonry 갤러리 */
  .masonry-grid {
    columns: 3;
    column-gap: 16px;
    max-width: 1200px; margin: 0 auto;
  }
  .masonry-item {
    break-inside: avoid;
    margin-bottom: 16px;
    border-radius: 12px; overflow: hidden;
    position: relative;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    cursor: pointer;
    transition: transform .3s, box-shadow .3s;
  }
  .masonry-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,.35);
  }
  .masonry-item img { width: 100%; display: block; }
  .masonry-placeholder {
    width: 100%; aspect-ratio: 1;
    display: flex; align-items: center; justify-content: center;
    font-size: 40px;
  }
  .masonry-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.7) 0%, transparent 50%);
    opacity: 0; transition: opacity .3s;
    display: flex; align-items: flex-end; padding: 16px;
  }
  .masonry-item:hover .masonry-overlay { opacity: 1; }
  .masonry-overlay-title {
    color: #fff; font-size: 13px; font-weight: 600;
  }

  /* 언론 보도 리스트 */
  .press-list {
    max-width: 860px; margin: 0 auto;
    display: flex; flex-direction: column; gap: 16px;
  }
  .press-item {
    border-radius: 16px; padding: 24px 28px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    display: flex; gap: 20px; align-items: flex-start;
    transition: transform .25s, border-color .25s;
  }
  .press-item:hover {
    transform: translateX(4px);
    border-color: rgba(240,192,64,.25);
  }
  .press-icon {
    width: 44px; height: 44px; flex-shrink: 0;
    border-radius: 10px;
    background: rgba(240,192,64,.12);
    border: 1px solid rgba(240,192,64,.2);
    display: flex; align-items: center; justify-content: center;
    color: #f0c040;
  }
  .press-title { font-weight: 700; font-size: 14px; margin-bottom: 6px; }
  .press-desc  { font-size: 13px; color: rgba(255,255,255,.4); line-height: 1.75; }
  .press-date  { font-size: 11px; color: rgba(255,255,255,.25); margin-top: 8px; font-family: 'Black Han Sans', sans-serif; }

  /* 섹션 헤딩 */
  .works-heading {
    font-family: 'Black Han Sans', sans-serif;
    font-size: clamp(1.8rem,3vw,2.6rem);
    letter-spacing: -.02em; line-height: 1.2;
    margin-bottom: 40px;
    text-align: center;
  }

  /* 빈 상태 */
  .empty-state { text-align: center; padding: 80px 24px; color: rgba(255,255,255,.3); }

  /* 탭 패널 토글 */
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* 반응형 */
  @media (max-width: 1024px) { .masonry-grid { columns: 2; } }
  @media (max-width: 640px) {
    .tab-bar, .works-section { padding-left: 20px; padding-right: 20px; }
    .masonry-grid { columns: 2; }
    .books-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<!-- ══ HERO ═══════════════════════════════════ -->
<section class="works-hero">
  <div class="works-hero-bg" aria-hidden="true">WORKS</div>
  <div class="works-hero-content reveal">
    <div class="section-label" style="justify-content:center;margin-bottom:20px;">Works</div>
    <h1 style="font-family:'Black Han Sans',sans-serif;font-size:clamp(2.8rem,5vw,5rem);letter-spacing:-0.02em;line-height:1.1;margin-bottom:20px;">
      글로 쓰고<br>
      <span style="color:#f0c040;">그림으로 남기다</span>
    </h1>
    <p style="font-size:16px;color:rgba(255,255,255,.5);max-width:440px;margin:0 auto;line-height:1.8;">
      저서·모바일 스케치 갤러리·언론 보도<br>최범희 PD의 창작 세계를 만나보세요.
    </p>
  </div>
</section>

<!-- ══ 탭 바 ═════════════════════════════════ -->
<div class="tab-bar" id="works-tabs">
  <button class="tab-pill active" data-tab="books">저서</button>
  <button class="tab-pill" data-tab="gallery">갤러리</button>
  <button class="tab-pill" data-tab="press">언론 보도</button>
</div>

<!-- ══ 저서 ══════════════════════════════════ -->
<section class="works-section tab-panel active" id="tab-books">
  <div class="works-heading reveal">대표 저서</div>
  <% books = [
    { emoji: "📱", title: "스마트폰으로 창업하라", desc: "스마트폰 하나로 시작하는 1인 창업 전략서" },
    { emoji: "📣", title: "SNS 마케팅 바이블",    desc: "중소기업·소상공인을 위한 실전 SNS 마케팅" },
    { emoji: "✍️", title: "디지털 글쓰기 혁명",   desc: "콘텐츠로 수익 만드는 글쓰기 기법" },
    { emoji: "🌱", title: "환경 저널리즘 입문",    desc: "한국환경저널 발행인의 환경 미디어 실무" },
  ] %>
  <div class="books-grid">
    <% if @books.present? && @books.any? %>
      <% @books.each_with_index do |book, i| %>
        <div class="book-card reveal reveal-delay-<%= (i % 3) + 1 %>">
          <div class="book-cover">
            <% if book.image.attached? %>
              <%= image_tag book.image, alt: book.title %>
            <% elsif book.image_url.present? %>
              <%= image_tag book.image_url, alt: book.title %>
            <% else %>
              <%= %w[📱 📣 ✍️ 🌱 📗 📘][i % 6] %>
            <% end %>
          </div>
          <div class="book-title"><%= book.title %></div>
          <div class="book-desc"><%= book.description.to_s.truncate(60) %></div>
        </div>
      <% end %>
    <% else %>
      <% books.each_with_index do |b, i| %>
        <div class="book-card reveal reveal-delay-<%= (i % 3) + 1 %>">
          <div class="book-cover"><%= b[:emoji] %></div>
          <div class="book-title"><%= b[:title] %></div>
          <div class="book-desc"><%= b[:desc] %></div>
        </div>
      <% end %>
    <% end %>
  </div>
</section>

<!-- ══ 갤러리 ════════════════════════════════ -->
<section class="works-section tab-panel" id="tab-gallery">
  <div class="works-heading reveal">모바일 스케치 갤러리</div>
  <% if @gallery_works.any? %>
    <div class="masonry-grid">
      <% @gallery_works.each_with_index do |work, i| %>
        <div class="masonry-item reveal reveal-delay-<%= (i % 3) + 1 %>">
          <% if work.image.attached? %>
            <%= image_tag work.image, alt: work.title %>
          <% elsif work.image_url.present? %>
            <%= image_tag work.image_url, alt: work.title %>
          <% else %>
            <% gallery_emojis = ["🎨","🖼️","✏️","📐","🖌️","🎭","🌿","🏙️"] %>
            <% gallery_bgs    = ["rgba(168,255,62,.08)","rgba(240,192,64,.08)","rgba(255,77,28,.08)","rgba(96,165,250,.08)"] %>
            <div class="masonry-placeholder" style="background:<%= gallery_bgs[i % 4] %>;">
              <%= gallery_emojis[i % 8] %>
            </div>
          <% end %>
          <div class="masonry-overlay">
            <div class="masonry-overlay-title"><%= work.title %></div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <!-- 플레이스홀더 갤러리 -->
    <% placeholders = [
      { emoji: "🎨", h: "1/1",  title: "도시 스케치 #1", bg: "rgba(168,255,62,.06)" },
      { emoji: "🖌️", h: "4/3",  title: "자연 드로잉",    bg: "rgba(240,192,64,.06)" },
      { emoji: "✏️", h: "3/4",  title: "카페 풍경",      bg: "rgba(255,77,28,.06)" },
      { emoji: "🌿", h: "1/1",  title: "식물 스케치",    bg: "rgba(96,165,250,.06)" },
      { emoji: "🏙️", h: "4/3",  title: "거리 풍경 #2",  bg: "rgba(168,255,62,.06)" },
      { emoji: "🖼️", h: "3/4",  title: "추상 드로잉",    bg: "rgba(240,192,64,.06)" },
      { emoji: "📐", h: "1/1",  title: "건축 스케치",    bg: "rgba(255,77,28,.06)" },
      { emoji: "🎭", h: "4/3",  title: "인물 드로잉",    bg: "rgba(96,165,250,.06)" },
    ] %>
    <div class="masonry-grid">
      <% placeholders.each_with_index do |p, i| %>
        <div class="masonry-item reveal reveal-delay-<%= (i % 3) + 1 %>">
          <div class="masonry-placeholder" style="background:<%= p[:bg] %>;aspect-ratio:<%= p[:h] %>;">
            <span style="font-size:48px;"><%= p[:emoji] %></span>
          </div>
          <div class="masonry-overlay" style="opacity:.6;">
            <div class="masonry-overlay-title"><%= p[:title] %></div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</section>

<!-- ══ 언론 보도 ══════════════════════════════ -->
<section class="works-section tab-panel" id="tab-press">
  <div class="works-heading reveal">언론 보도</div>
  <% if @press_works.any? %>
    <div class="press-list">
      <% @press_works.each_with_index do |work, i| %>
        <div class="press-item reveal reveal-delay-<%= (i % 3) + 1 %>">
          <div class="press-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
          </div>
          <div>
            <div class="press-title"><%= work.title %></div>
            <div class="press-desc"><%= work.description.to_s.truncate(100) %></div>
            <div class="press-date"><%= work.created_at.strftime("%Y.%m.%d") %></div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <% press_samples = [
      ["뉴시스", "스마트폰 창업 전도사 최PD '1인 창업이 답이다'", "2024.09.15"],
      ["한국경제TV", "중장년층 재창업 해법 제시한 최범희 강사 인터뷰", "2024.07.22"],
      ["머니투데이", "SNS 마케팅 강의 전문가 최PD의 성공 비결", "2024.05.10"],
      ["한국환경저널", "발행인 최범희 PD, 환경 미디어 리터러시 강조", "2024.03.05"],
    ] %>
    <div class="press-list">
      <% press_samples.each_with_index do |(outlet, title, date), i| %>
        <div class="press-item reveal reveal-delay-<%= (i % 3) + 1 %>">
          <div class="press-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
          </div>
          <div>
            <div class="press-title"><span style="color:#f0c040;margin-right:8px;font-size:11px;"><%= outlet %></span><%= title %></div>
            <div class="press-date"><%= date %></div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</section>

<script>
  // 탭 전환
  document.querySelectorAll('[data-tab]').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab;
      document.querySelectorAll('.tab-pill').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('tab-' + target)?.classList.add('active');
    });
  });
</script>
