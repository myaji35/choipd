<% content_for :title, "작품 갤러리" %>

<section class="bg-gradient-to-br from-purple-900 to-purple-700 py-16">
  <div class="max-w-7xl mx-auto px-4 text-center">
    <h1 class="text-4xl font-bold text-white mb-4">작품</h1>
    <p class="text-purple-200 text-lg">저서, 모바일 스케치 갤러리, 언론 보도</p>
  </div>
</section>

<!-- 탭 -->
<section class="bg-white border-b py-4" data-controller="tabs">
  <div class="max-w-7xl mx-auto px-4 flex space-x-4">
    <button class="px-4 py-2 rounded-full text-sm font-medium bg-primary text-white"
            data-tabs-target="tab" data-action="click->tabs#select" data-target="gallery">갤러리</button>
    <button class="px-4 py-2 rounded-full text-sm font-medium text-gray-500 hover:text-primary"
            data-tabs-target="tab" data-action="click->tabs#select" data-target="press">언론 보도</button>
  </div>
</section>

<!-- 갤러리 -->
<section class="py-12" data-tabs-target="panel" id="gallery-panel">
  <div class="max-w-7xl mx-auto px-4">
    <% if @gallery_works.any? %>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        <% @gallery_works.each do |work| %>
          <div class="group relative bg-gray-100 rounded-lg overflow-hidden aspect-square">
            <% if work.image.attached? %>
              <%= image_tag work.image, class: "w-full h-full object-cover", alt: work.title %>
            <% elsif work.image_url.present? %>
              <%= image_tag work.image_url, class: "w-full h-full object-cover", alt: work.title %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center bg-purple-50">
                <svg class="w-12 h-12 text-purple-200" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="1">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21 15 16 10 5 21"/>
                </svg>
              </div>
            <% end %>
            <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-3">
              <p class="text-white text-sm font-medium line-clamp-2"><%= work.title %></p>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16 text-gray-400">갤러리 작품이 없습니다.</div>
    <% end %>
  </div>
</section>

<!-- 언론 보도 -->
<section class="py-12 hidden" data-tabs-target="panel" id="press-panel">
  <div class="max-w-5xl mx-auto px-4">
    <% if @press_works.any? %>
      <div class="space-y-4">
        <% @press_works.each do |work| %>
          <div class="bg-white border border-gray-100 rounded-lg p-5 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-start space-x-4">
              <div class="w-10 h-10 bg-gray-100 rounded flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-navy mb-1"><%= work.title %></h3>
                <p class="text-gray-500 text-sm line-clamp-2"><%= work.description %></p>
                <p class="text-xs text-gray-400 mt-2"><%= work.created_at.strftime("%Y.%m.%d") %></p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16 text-gray-400">언론 보도 내용이 없습니다.</div>
    <% end %>
  </div>
</section>
