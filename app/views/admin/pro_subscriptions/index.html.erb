<% content_for :title, "Pro 구독" %>
<div class="mb-6">
  <h1 class="text-2xl font-bold text-navy">⚡ Pro 구독 관리</h1>
</div>

<% if @subscription %>
  <div class="bg-white border border-gray-200 rounded-lg p-6 max-w-2xl">
    <div class="flex justify-between items-start mb-4">
      <div>
        <span class="text-xs px-2 py-0.5 bg-yellow-100 text-yellow-700 rounded">Pro</span>
        <h2 class="text-xl font-bold text-navy mt-2"><%= @subscription.tier %></h2>
      </div>
      <% color = case @subscription.status; when 'active' then 'green'; when 'trial' then 'blue'; when 'cancelled' then 'gray'; else 'red'; end %>
      <span class="text-xs px-3 py-1 bg-<%= color %>-100 text-<%= color %>-700 rounded-full"><%= @subscription.status %></span>
    </div>
    <dl class="space-y-3 text-sm">
      <div class="flex justify-between"><dt class="text-gray-500">월 요금</dt><dd class="font-bold">₩<%= number_with_delimiter(@subscription.price_krw || 14900) %></dd></div>
      <% if @subscription.trial? %>
        <div class="flex justify-between"><dt class="text-gray-500">체험 종료</dt><dd><%= @subscription.trial_ends_at.strftime("%Y.%m.%d") %> (<%= @subscription.trial_days_left %>일 남음)</dd></div>
      <% end %>
      <% if @subscription.current_period_end %>
        <div class="flex justify-between"><dt class="text-gray-500">다음 결제</dt><dd><%= @subscription.current_period_end.strftime("%Y.%m.%d") %></dd></div>
      <% end %>
    </dl>
    <div class="mt-6 flex gap-2">
      <% if @subscription.status == "trial" %>
        <%= button_to "🚀 지금 결제 활성화 (stub)", activate_admin_pro_subscription_path(@subscription),
            class: "bg-primary text-white px-4 py-2 rounded-lg text-sm" %>
      <% end %>
      <% unless @subscription.status == "cancelled" %>
        <%= button_to "구독 취소", cancel_admin_pro_subscription_path(@subscription), method: :post,
            class: "bg-red-50 text-red-600 px-4 py-2 rounded-lg text-sm",
            data: { turbo_confirm: "정말 취소하시겠습니까?" } %>
      <% end %>
    </div>
  </div>
<% else %>
  <div class="bg-gradient-to-br from-yellow-50 to-amber-50 border border-yellow-300 rounded-lg p-8 max-w-2xl text-center">
    <h2 class="text-2xl font-bold text-amber-900">⚡ Pro 14일 무료 체험</h2>
    <p class="text-amber-800 mt-2">카카오 채널 어시스턴트 + 일일 요약 + 긴급 알림</p>
    <%= button_to "체험 시작 →", start_trial_admin_pro_subscriptions_path,
        class: "mt-6 bg-amber-700 text-white px-6 py-3 rounded-lg text-sm font-medium hover:bg-amber-800" %>
    <p class="text-xs text-amber-600 mt-3">카드 등록 불필요 · 14일 후 자동 종료</p>
  </div>
<% end %>

<div class="mt-6 max-w-2xl">
  <h3 class="font-semibold text-navy mb-2">💎 Pro 기능</h3>
  <ul class="space-y-1 text-sm text-gray-700 list-disc list-inside">
    <li>카카오 비즈니스 채널 1개 연결</li>
    <li>일일 대화 3줄 요약 (저녁 8시 자동 푸시)</li>
    <li>긴급 키워드(환불/불만/법적) 즉시 알림</li>
    <li>미답변 문의 감지 → 사장님이 답해야 할 것 3줄 추천</li>
    <li>원문 7일 후 자동 파기 (개인정보 보호)</li>
    <li class="text-gray-400">자동 답변 발송 X (브랜드 보호 — 답변은 사장님이 직접)</li>
  </ul>
</div>
