<% content_for :title, "작품 관리" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-xl font-bold text-navy">작품 관리</h1>
  <%= link_to "새 작품", new_admin_work_path, class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-600 transition-colors" %>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
  <% @works.each do |work| %>
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm overflow-hidden">
      <% if work.image_url.present? %>
        <div class="h-40 bg-gray-100 overflow-hidden">
          <%= image_tag work.image_url, class: "w-full h-full object-cover", alt: work.title %>
        </div>
      <% else %>
        <div class="h-40 bg-gray-50 flex items-center justify-center">
          <svg class="w-10 h-10 text-gray-300" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="1.5">
            <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
      <% end %>
      <div class="p-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs bg-purple-100 text-purple-600 px-2 py-0.5 rounded-full">
            <%= work.gallery? ? '갤러리' : '언론' %>
          </span>
        </div>
        <h3 class="font-medium text-navy text-sm mb-3"><%= work.title %></h3>
        <div class="flex space-x-2">
          <%= link_to "수정", edit_admin_work_path(work), class: "text-primary text-xs hover:text-blue-700" %>
          <%= button_to "삭제", admin_work_path(work), method: :delete,
              class: "text-red-500 text-xs hover:text-red-700",
              data: { turbo_confirm: "삭제하시겠습니까?" } %>
        </div>
      </div>
    </div>
  <% end %>
  <% if @works.empty? %>
    <div class="col-span-3 py-12 text-center text-gray-400">등록된 작품이 없습니다.</div>
  <% end %>
</div>
