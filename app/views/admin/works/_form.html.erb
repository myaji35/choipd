<%= form_with model: [:admin, work], class: "space-y-4" do |f| %>
  <% if work.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <% work.errors.full_messages.each do |msg| %>
        <p class="text-red-600 text-sm"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "제목", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :title, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
  </div>

  <div>
    <%= f.label :category, "카테고리", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :category, [["갤러리", "gallery"], ["언론", "press"]], {}, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
  </div>

  <div>
    <%= f.label :description, "설명", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 4, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary resize-none" %>
  </div>

  <div>
    <%= f.label :image_url, "이미지 URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.url_field :image_url, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
  </div>

  <div>
    <%= f.label :source_url, "원본 링크", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.url_field :source_url, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
  </div>

  <div class="flex space-x-3">
    <%= f.submit work.persisted? ? "수정" : "등록", class: "bg-primary text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-blue-600 transition-colors cursor-pointer" %>
    <%= link_to "취소", admin_works_path, class: "bg-gray-100 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors" %>
  </div>
<% end %>
