<% content_for :title, "유통사 자료" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-xl font-bold text-navy">유통사 자료</h1>
  <%= link_to "자료 추가", new_admin_resource_path, class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-600 transition-colors" %>
</div>

<div class="bg-white rounded-lg border border-gray-100 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b">
      <tr>
        <th class="text-left text-xs text-gray-400 uppercase tracking-wider px-4 py-3">제목</th>
        <th class="text-left text-xs text-gray-400 uppercase tracking-wider px-4 py-3">카테고리</th>
        <th class="text-left text-xs text-gray-400 uppercase tracking-wider px-4 py-3">필수 플랜</th>
        <th class="text-left text-xs text-gray-400 uppercase tracking-wider px-4 py-3">다운로드</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @resources.each do |resource| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium text-navy"><%= resource.title %></td>
          <td class="px-4 py-3 text-gray-500"><%= resource.category %></td>
          <td class="px-4 py-3 text-gray-500"><%= resource.required_plan || '없음' %></td>
          <td class="px-4 py-3 text-gray-500"><%= resource.download_count %></td>
          <td class="px-4 py-3 text-right space-x-2">
            <%= link_to "수정", edit_admin_resource_path(resource), class: "text-primary text-xs hover:text-blue-700" %>
            <%= button_to "삭제", admin_resource_path(resource), method: :delete,
                class: "text-red-500 text-xs hover:text-red-700",
                data: { turbo_confirm: "삭제하시겠습니까?" } %>
          </td>
        </tr>
      <% end %>
      <% if @resources.empty? %>
        <tr><td colspan="5" class="px-4 py-8 text-center text-gray-400">등록된 자료가 없습니다.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
