<% content_for :title, @test.name %>

<div class="mb-6 flex items-center justify-between">
  <div>
    <%= link_to "← AB 테스트", admin_ab_tests_path, class: "text-primary text-sm" %>
    <h1 class="text-2xl font-bold text-navy mt-2"><%= @test.name %></h1>
    <% color = case @test.status; when 'running' then 'green'; when 'paused' then 'yellow'; when 'completed' then 'blue'; when 'archived' then 'gray'; else 'gray'; end %>
    <span class="text-xs px-2 py-0.5 bg-<%= color %>-100 text-<%= color %>-700 rounded-full"><%= @test.status %></span>
  </div>
  <div class="flex gap-2">
    <% if @test.status == "draft" %>
      <%= button_to "▶ 시작", start_admin_ab_test_path(@test),
          class: "bg-green-500 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-green-600" %>
    <% elsif @test.status == "running" %>
      <%= button_to "⏸ 일시정지", pause_admin_ab_test_path(@test),
          class: "bg-yellow-500 text-white px-4 py-2 rounded-lg text-sm font-medium" %>
      <%= button_to "✓ 완료", complete_admin_ab_test_path(@test),
          class: "bg-blue-500 text-white px-4 py-2 rounded-lg text-sm font-medium" %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
  <div class="lg:col-span-2 space-y-4">
    <% if @test.hypothesis.present? %>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <p class="text-xs font-semibold text-amber-700 mb-1">💡 가설</p>
        <p class="text-sm text-navy"><%= @test.hypothesis %></p>
      </div>
    <% end %>

    <div class="bg-white border border-gray-200 rounded-lg p-5">
      <h2 class="font-semibold text-navy mb-3">변형별 성과</h2>
      <div class="space-y-3">
        <% @variants_stats.each do |s| %>
          <div class="border border-gray-200 rounded-lg p-3 <%= 'ring-2 ring-green-400' if @test.winner == s[:variant] %>">
            <div class="flex justify-between items-center mb-2">
              <span class="font-bold text-navy"><%= s[:variant] %><%= ' 🏆' if @test.winner == s[:variant] %></span>
              <span class="text-2xl font-bold text-blue-600"><%= s[:rate] %>%</span>
            </div>
            <div class="grid grid-cols-3 gap-2 text-xs text-gray-600">
              <div>참여 <span class="font-bold text-navy"><%= s[:count] %></span></div>
              <div>전환 <span class="font-bold text-navy"><%= s[:converted] %></span></div>
              <div>매출 <span class="font-bold text-navy"><%= number_with_delimiter(s[:revenue].to_i) %></span></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="space-y-4">
    <div class="bg-white border border-gray-200 rounded-lg p-5">
      <h2 class="font-semibold text-navy mb-3 text-sm">테스트 정보</h2>
      <dl class="space-y-2 text-xs">
        <div class="flex justify-between"><dt class="text-gray-500">목표 지표</dt><dd class="font-bold text-navy"><%= @test.target_metric %></dd></div>
        <div class="flex justify-between"><dt class="text-gray-500">전체 참여</dt><dd class="font-bold"><%= @participants_count %></dd></div>
        <div class="flex justify-between"><dt class="text-gray-500">신뢰 수준</dt><dd class="font-bold"><%= @test.confidence_level %>%</dd></div>
        <% if @test.start_date %>
          <div class="flex justify-between"><dt class="text-gray-500">시작일</dt><dd><%= @test.start_date.strftime("%Y.%m.%d") %></dd></div>
        <% end %>
        <% if @test.end_date %>
          <div class="flex justify-between"><dt class="text-gray-500">종료일</dt><dd><%= @test.end_date.strftime("%Y.%m.%d") %></dd></div>
        <% end %>
        <div class="flex justify-between"><dt class="text-gray-500">생성자</dt><dd><%= @test.created_by %></dd></div>
      </dl>
    </div>

    <div class="bg-white border border-gray-200 rounded-lg p-5">
      <h2 class="font-semibold text-navy mb-3 text-sm">트래픽 분배</h2>
      <% @test.allocation_hash.each do |variant, pct| %>
        <div class="mb-2">
          <div class="flex justify-between text-xs mb-1">
            <span><%= variant %></span>
            <span class="font-bold"><%= pct %>%</span>
          </div>
          <div class="w-full bg-gray-200 rounded h-2">
            <div class="bg-blue-500 rounded h-2" style="width: <%= pct %>%"></div>
          </div>
        </div>
      <% end %>
    </div>

    <%= button_to "삭제", admin_ab_test_path(@test), method: :delete,
        class: "w-full bg-red-50 text-red-600 px-4 py-2 rounded-lg text-sm hover:bg-red-100",
        data: { turbo_confirm: "정말 삭제하시겠습니까?" } %>
  </div>
</div>
