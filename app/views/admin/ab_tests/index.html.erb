<% content_for :title, "AB 테스트" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <%= link_to "← 분석 대시보드", admin_analytics_path, class: "text-primary text-sm" %>
    <h1 class="text-2xl font-bold text-navy mt-2">🧪 AB 테스트</h1>
    <p class="text-sm text-gray-500 mt-1">전체 <%= @tests.size %>개</p>
  </div>
  <%= link_to "+ 새 테스트", new_admin_ab_test_path,
      class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90" %>
</div>

<div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b">
      <tr>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">이름</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">상태</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">목표 지표</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">변형</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">참여자</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">시작일</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @tests.each do |t| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium text-navy"><%= t.name %></td>
          <td class="px-4 py-3">
            <% color = case t.status; when 'running' then 'green'; when 'paused' then 'yellow'; when 'completed' then 'blue'; when 'archived' then 'gray'; else 'gray'; end %>
            <span class="text-xs px-2 py-0.5 bg-<%= color %>-100 text-<%= color %>-700 rounded-full"><%= t.status %></span>
          </td>
          <td class="px-4 py-3 text-xs text-gray-600"><%= t.target_metric %></td>
          <td class="px-4 py-3 text-xs text-gray-500"><%= t.variants_list.join(", ") %></td>
          <td class="px-4 py-3 text-xs"><%= t.total_participants %></td>
          <td class="px-4 py-3 text-xs text-gray-400"><%= t.start_date&.strftime("%Y.%m.%d") || '—' %></td>
          <td class="px-4 py-3 text-right"><%= link_to "보기", admin_ab_test_path(t), class: "text-xs text-primary" %></td>
        </tr>
      <% end %>
      <% if @tests.empty? %>
        <tr><td colspan="7" class="px-4 py-12 text-center text-gray-400">등록된 AB 테스트가 없습니다.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
