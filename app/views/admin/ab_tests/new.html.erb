<% content_for :title, "새 AB 테스트" %>

<div class="mb-6">
  <%= link_to "← AB 테스트", admin_ab_tests_path, class: "text-primary text-sm" %>
  <h1 class="text-2xl font-bold text-navy mt-2">+ 새 AB 테스트</h1>
</div>

<%= form_with url: admin_ab_tests_path, class: "bg-white border border-gray-200 rounded-lg p-6 max-w-2xl space-y-4" do |f| %>
  <div>
    <%= f.label :name, "테스트 이름", class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.text_field :name, required: true, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
  </div>
  <div>
    <%= f.label :hypothesis, "가설", class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.text_area :hypothesis, rows: 3, placeholder: "버튼 색상을 빨간색으로 바꾸면 클릭률이 10% 증가할 것이다",
        class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
  </div>
  <div>
    <%= f.label :description, "설명", class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 2, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
  </div>
  <div>
    <%= f.label :variants_text, "변형 (쉼표로 구분)", class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.text_field :variants_text, value: "control,variant_a", class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono" %>
    <p class="text-xs text-gray-500 mt-1">예: control,variant_a 또는 control,red,blue,green</p>
  </div>
  <div>
    <%= f.label :target_metric, "목표 지표", class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.select :target_metric, [["전환율", "conversion_rate"], ["매출", "revenue"], ["클릭률", "ctr"], ["가입율", "signup_rate"]],
        {}, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
  </div>
  <div class="flex gap-3 pt-2">
    <%= f.submit "테스트 생성", class: "bg-primary text-white px-6 py-2 rounded-lg text-sm font-medium cursor-pointer" %>
    <%= link_to "취소", admin_ab_tests_path, class: "text-gray-500 px-6 py-2 rounded-lg text-sm" %>
  </div>
<% end %>
