<% content_for :title, "워크플로우" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-navy">⚡ 워크플로우 자동화</h1>
    <p class="text-sm text-gray-500 mt-1">전체 <%= @workflows.size %>개 (활성 <%= @workflows.select(&:is_active?).size %>개)</p>
  </div>
  <%= link_to "+ 새 워크플로우", new_admin_workflow_path,
      class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90" %>
</div>

<div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b">
      <tr>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">이름</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">트리거</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">실행 / 성공 / 실패</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">마지막 실행</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">상태</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @workflows.each do |w| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium text-navy"><%= w.name %></td>
          <td class="px-4 py-3"><span class="text-xs px-2 py-0.5 bg-blue-100 text-blue-700 rounded"><%= w.trigger %></span></td>
          <td class="px-4 py-3 text-xs">
            <%= w.execution_count %> / <span class="text-green-600 font-bold"><%= w.success_count %></span> / <span class="text-red-600 font-bold"><%= w.failure_count %></span>
          </td>
          <td class="px-4 py-3 text-xs text-gray-400"><%= w.last_executed_at&.strftime("%y.%m.%d %H:%M") || "—" %></td>
          <td class="px-4 py-3">
            <% if w.is_active? %>
              <span class="text-xs px-2 py-0.5 bg-green-100 text-green-700 rounded">활성</span>
            <% else %>
              <span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-600 rounded">비활성</span>
            <% end %>
          </td>
          <td class="px-4 py-3 text-right">
            <%= link_to "보기", admin_workflow_path(w), class: "text-xs text-primary" %>
          </td>
        </tr>
      <% end %>
      <% if @workflows.empty? %>
        <tr><td colspan="6" class="px-4 py-12 text-center text-gray-400">등록된 워크플로우가 없습니다.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
