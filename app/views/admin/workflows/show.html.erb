<% content_for :title, @workflow.name %>

<div class="mb-6 flex items-center justify-between">
  <div>
    <%= link_to "← 워크플로우", admin_workflows_path, class: "text-primary text-sm" %>
    <h1 class="text-2xl font-bold text-navy mt-2"><%= @workflow.name %></h1>
    <% if @workflow.description.present? %>
      <p class="text-sm text-gray-500 mt-1"><%= @workflow.description %></p>
    <% end %>
  </div>
  <div class="flex gap-2">
    <%= button_to "▶ 수동 실행", execute_admin_workflow_path(@workflow),
        class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium" %>
    <%= button_to (@workflow.is_active? ? "⏸ 비활성화" : "▶ 활성화"), toggle_admin_workflow_path(@workflow),
        class: "bg-gray-100 text-gray-700 px-4 py-2 rounded-lg text-sm" %>
    <%= button_to "삭제", admin_workflow_path(@workflow), method: :delete,
        class: "bg-red-50 text-red-600 px-4 py-2 rounded-lg text-sm",
        data: { turbo_confirm: "삭제하시겠습니까?" } %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
  <div class="lg:col-span-2 space-y-4">
    <!-- 액션 단계 -->
    <div class="bg-white border border-gray-200 rounded-lg p-5">
      <h2 class="font-semibold text-navy mb-3">⚙️ 액션 단계 (<%= @workflow.actions_list.size %>)</h2>
      <% if @workflow.actions_list.any? %>
        <div class="space-y-2">
          <% @workflow.actions_list.each_with_index do |a, i| %>
            <div class="flex items-start gap-3 bg-gray-50 rounded p-3">
              <span class="text-xs font-mono text-gray-400 w-6"><%= i + 1 %></span>
              <div class="flex-1">
                <span class="text-xs px-2 py-0.5 bg-blue-100 text-blue-700 rounded font-mono"><%= a["type"] %></span>
                <p class="text-sm text-navy mt-1 font-mono"><%= a["message"] || a["url"] || a.inspect %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-400">액션이 없습니다.</p>
      <% end %>
    </div>

    <!-- 최근 실행 -->
    <div class="bg-white border border-gray-200 rounded-lg p-5">
      <h2 class="font-semibold text-navy mb-3">🕒 최근 실행 (<%= @recent_executions.size %>)</h2>
      <% if @recent_executions.any? %>
        <table class="w-full text-sm">
          <thead class="border-b">
            <tr class="text-xs text-gray-500">
              <th class="text-left py-2">시간</th>
              <th class="text-left py-2">트리거</th>
              <th class="text-left py-2">상태</th>
              <th class="text-left py-2">소요</th>
            </tr>
          </thead>
          <tbody class="divide-y">
            <% @recent_executions.each do |e| %>
              <tr>
                <td class="py-2 text-xs"><%= e.created_at.strftime("%m/%d %H:%M:%S") %></td>
                <td class="py-2 text-xs font-mono"><%= e.trigger %></td>
                <td class="py-2">
                  <% color = case e.status; when 'completed' then 'green'; when 'failed' then 'red'; when 'running' then 'blue'; else 'gray'; end %>
                  <span class="text-xs px-2 py-0.5 bg-<%= color %>-100 text-<%= color %>-700 rounded"><%= e.status %></span>
                </td>
                <td class="py-2 text-xs"><%= e.duration ? "#{e.duration}ms" : "—" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-sm text-gray-400">실행 이력이 없습니다.</p>
      <% end %>
    </div>
  </div>

  <div class="space-y-4">
    <div class="bg-white border border-gray-200 rounded-lg p-5">
      <h2 class="font-semibold text-navy mb-3 text-sm">통계</h2>
      <dl class="space-y-2 text-xs">
        <div class="flex justify-between"><dt class="text-gray-500">총 실행</dt><dd class="font-bold"><%= @workflow.execution_count %></dd></div>
        <div class="flex justify-between"><dt class="text-gray-500">성공</dt><dd class="font-bold text-green-600"><%= @workflow.success_count %></dd></div>
        <div class="flex justify-between"><dt class="text-gray-500">실패</dt><dd class="font-bold text-red-600"><%= @workflow.failure_count %></dd></div>
        <% rate = @workflow.execution_count.zero? ? 0 : (@workflow.success_count.to_f / @workflow.execution_count * 100).round(1) %>
        <div class="flex justify-between border-t border-gray-100 pt-2"><dt class="text-gray-500">성공률</dt><dd class="font-bold text-blue-600"><%= rate %>%</dd></div>
      </dl>
    </div>
    <div class="bg-white border border-gray-200 rounded-lg p-5">
      <h2 class="font-semibold text-navy mb-3 text-sm">정보</h2>
      <dl class="space-y-2 text-xs">
        <div class="flex justify-between"><dt class="text-gray-500">트리거</dt><dd class="font-mono"><%= @workflow.trigger %></dd></div>
        <div class="flex justify-between"><dt class="text-gray-500">생성자</dt><dd><%= @workflow.created_by %></dd></div>
        <div class="flex justify-between"><dt class="text-gray-500">생성일</dt><dd><%= @workflow.created_at.strftime("%Y.%m.%d") %></dd></div>
      </dl>
    </div>
  </div>
</div>
