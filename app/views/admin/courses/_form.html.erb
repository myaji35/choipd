<%= form_with model: [:admin, course], class: "space-y-4" do |f| %>
  <% if course.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <% course.errors.full_messages.each do |msg| %>
        <p class="text-red-600 text-sm"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "제목", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :title, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :course_type, "유형", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :course_type, [["온라인", "online"], ["오프라인", "offline"], ["B2B", "b2b"]], {}, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
    </div>
    <div>
      <%= f.label :price, "가격 (0 = 무료)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :price, min: 0, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
    </div>
  </div>

  <div>
    <%= f.label :description, "설명", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 4, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary resize-none" %>
  </div>

  <div>
    <%= f.label :thumbnail_url, "썸네일 URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.url_field :thumbnail_url, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
  </div>

  <div>
    <%= f.label :external_link, "외부 링크 (수강 신청)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.url_field :external_link, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
  </div>

  <div class="flex items-center space-x-2">
    <%= f.check_box :published, class: "rounded border-gray-300 text-primary" %>
    <%= f.label :published, "공개", class: "text-sm font-medium text-gray-700" %>
  </div>

  <div class="flex space-x-3">
    <%= f.submit course.persisted? ? "수정" : "등록", class: "bg-primary text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-blue-600 transition-colors cursor-pointer" %>
    <%= link_to "취소", admin_courses_path, class: "bg-gray-100 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors" %>
  </div>
<% end %>
