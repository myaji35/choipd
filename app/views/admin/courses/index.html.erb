<% content_for :title, "강좌 관리" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-xl font-bold text-navy">강좌 관리</h1>
  <%= link_to "새 강좌", new_admin_course_path, class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-600 transition-colors" %>
</div>

<div class="bg-white rounded-lg border border-gray-100 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b">
      <tr>
        <th class="text-left text-xs text-gray-400 uppercase tracking-wider px-4 py-3">제목</th>
        <th class="text-left text-xs text-gray-400 uppercase tracking-wider px-4 py-3">유형</th>
        <th class="text-left text-xs text-gray-400 uppercase tracking-wider px-4 py-3">가격</th>
        <th class="text-left text-xs text-gray-400 uppercase tracking-wider px-4 py-3">상태</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @courses.each do |course| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium text-navy"><%= course.title %></td>
          <td class="px-4 py-3 text-gray-500">
            <% types = { 'online' => '온라인', 'offline' => '오프라인', 'b2b' => 'B2B' } %>
            <%= types[course.course_type] || course.course_type %>
          </td>
          <td class="px-4 py-3 text-gray-500">
            <% if course.price.present? && course.price > 0 %>
              <%= number_with_delimiter(course.price) %>원
            <% else %>
              <span class="text-green-600">무료</span>
            <% end %>
          </td>
          <td class="px-4 py-3">
            <% if course.published? %>
              <span class="bg-green-100 text-green-700 text-xs px-2 py-0.5 rounded-full">공개</span>
            <% else %>
              <span class="bg-gray-100 text-gray-500 text-xs px-2 py-0.5 rounded-full">비공개</span>
            <% end %>
          </td>
          <td class="px-4 py-3 text-right space-x-2">
            <%= link_to "수정", edit_admin_course_path(course), class: "text-primary text-xs hover:text-blue-700" %>
            <%= button_to "삭제", admin_course_path(course), method: :delete,
                class: "text-red-500 text-xs hover:text-red-700",
                data: { turbo_confirm: "삭제하시겠습니까?" } %>
          </td>
        </tr>
      <% end %>
      <% if @courses.empty? %>
        <tr><td colspan="5" class="px-4 py-8 text-center text-gray-400">등록된 강좌가 없습니다.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
