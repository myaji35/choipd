<% content_for :title, "강좌 관리" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-navy">📚 강좌 관리</h1>
    <p class="text-sm text-gray-500 mt-1">전체 <%= @courses.size %>개 강좌</p>
  </div>
  <div class="flex items-center gap-2">
    <%= form_with url: admin_courses_path, method: :get, class: "flex gap-2" do |f| %>
      <%= f.select :type, [["전체 유형", ""], ["온라인", "online"], ["오프라인", "offline"], ["B2B", "b2b"]],
          { selected: params[:type] }, class: "border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
      <%= f.select :published, [["전체", ""], ["공개", "true"], ["비공개", "false"]],
          { selected: params[:published] }, class: "border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
      <%= f.submit "필터", class: "bg-gray-100 text-gray-700 px-3 py-2 rounded-lg text-sm cursor-pointer" %>
    <% end %>
    <%= link_to "+ 새 강좌", new_admin_course_path,
        class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90" %>
  </div>
</div>

<!-- View 토글 -->
<div class="mb-3 flex gap-2">
  <a href="?<%= request.query_parameters.merge(view: 'card').to_query %>" class="text-xs px-2 py-1 <%= 'bg-primary text-white' if params[:view] != 'list' %> rounded">카드 뷰</a>
  <a href="?<%= request.query_parameters.merge(view: 'list').to_query %>" class="text-xs px-2 py-1 <%= 'bg-primary text-white' if params[:view] == 'list' %> rounded">리스트 뷰</a>
</div>

<% if params[:view] != 'list' && @courses.any? %>
  <!-- 카드 그리드 -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @courses.each do |course| %>
      <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden hover:shadow-md transition-shadow">
        <% if course.thumbnail_url.present? %>
          <img src="<%= course.thumbnail_url %>" alt="" class="w-full h-40 object-cover">
        <% else %>
          <div class="w-full h-40 bg-gradient-to-br from-blue-400 to-purple-500 flex items-center justify-center text-white text-4xl">📚</div>
        <% end %>
        <div class="p-4">
          <div class="flex items-start justify-between mb-2">
            <h3 class="font-bold text-navy line-clamp-1"><%= course.title %></h3>
            <% if course.published? %>
              <span class="text-xs px-2 py-0.5 bg-green-100 text-green-700 rounded shrink-0">공개</span>
            <% else %>
              <span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-500 rounded shrink-0">비공개</span>
            <% end %>
          </div>
          <p class="text-xs text-gray-500 line-clamp-2 mb-3"><%= course.description %></p>

          <div class="flex items-center justify-between text-xs">
            <% types = { 'online' => '🌐 온라인', 'offline' => '📍 오프라인', 'b2b' => '🏢 B2B' } %>
            <span class="text-gray-500"><%= types[course.course_type] || course.course_type %></span>
            <% if course.price.present? && course.price > 0 %>
              <span class="font-bold text-navy"><%= number_with_delimiter(course.price) %>원</span>
            <% else %>
              <span class="text-green-600 font-bold">무료</span>
            <% end %>
          </div>

          <% if course.external_link.present? %>
            <a href="<%= course.external_link %>" target="_blank" class="text-xs text-blue-600 hover:underline mt-2 block">
              💳 외부 결제 링크 ↗
            </a>
          <% end %>

          <div class="mt-3 pt-3 border-t border-gray-100 flex gap-2">
            <%= link_to "수정", edit_admin_course_path(course), class: "text-xs flex-1 text-center bg-gray-100 text-gray-700 py-1.5 rounded hover:bg-gray-200" %>
            <%= button_to "삭제", admin_course_path(course), method: :delete,
                class: "text-xs text-red-600 hover:text-red-800",
                data: { turbo_confirm: "삭제하시겠습니까?" },
                form: { class: "inline" } %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <!-- 리스트 뷰 -->
  <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b">
        <tr>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">제목</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">유형</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">가격</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">외부 링크</th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">상태</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y">
        <% @courses.each do |course| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3">
              <div class="flex items-center gap-3">
                <% if course.thumbnail_url.present? %>
                  <img src="<%= course.thumbnail_url %>" alt="" class="w-10 h-10 object-cover rounded">
                <% else %>
                  <div class="w-10 h-10 bg-gray-200 rounded flex items-center justify-center text-gray-400 text-xs">📚</div>
                <% end %>
                <span class="font-medium text-navy"><%= course.title %></span>
              </div>
            </td>
            <td class="px-4 py-3 text-gray-600">
              <% types = { 'online' => '온라인', 'offline' => '오프라인', 'b2b' => 'B2B' } %>
              <%= types[course.course_type] || course.course_type %>
            </td>
            <td class="px-4 py-3">
              <% if course.price.present? && course.price > 0 %>
                <span class="font-semibold"><%= number_with_delimiter(course.price) %>원</span>
              <% else %>
                <span class="text-green-600 font-semibold">무료</span>
              <% end %>
            </td>
            <td class="px-4 py-3">
              <% if course.external_link.present? %>
                <a href="<%= course.external_link %>" target="_blank" class="text-xs text-blue-600 hover:underline">결제 링크 ↗</a>
              <% else %>
                <span class="text-gray-300 text-xs">—</span>
              <% end %>
            </td>
            <td class="px-4 py-3">
              <% if course.published? %>
                <span class="text-xs px-2 py-0.5 bg-green-100 text-green-700 rounded-full">공개</span>
              <% else %>
                <span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-500 rounded-full">비공개</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-right space-x-2">
              <%= link_to "수정", edit_admin_course_path(course), class: "text-xs text-primary" %>
              <%= button_to "삭제", admin_course_path(course), method: :delete,
                  class: "text-xs text-red-500",
                  data: { turbo_confirm: "삭제하시겠습니까?" } %>
            </td>
          </tr>
        <% end %>
        <% if @courses.empty? %>
          <tr><td colspan="6" class="px-4 py-12 text-center text-gray-400">등록된 강좌가 없습니다.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
