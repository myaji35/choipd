<%= form_with model: [:admin, post], class: "space-y-4" do |f| %>
  <% if post.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <% post.errors.full_messages.each do |msg| %>
        <p class="text-red-600 text-sm"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "제목", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :title, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
  </div>

  <div>
    <%= f.label :category, "카테고리", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :category, [["공지", "notice"], ["후기", "review"], ["미디어", "media"]], {}, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
  </div>

  <div>
    <%= f.label :content, "내용", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :content, rows: 8, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary resize-none" %>
  </div>

  <div class="flex items-center space-x-2">
    <%= f.check_box :published, class: "rounded border-gray-300 text-primary" %>
    <%= f.label :published, "공개", class: "text-sm font-medium text-gray-700" %>
  </div>

  <div class="flex space-x-3">
    <%= f.submit post.persisted? ? "수정" : "등록", class: "bg-primary text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-blue-600 transition-colors cursor-pointer" %>
    <%= link_to "취소", admin_posts_path, class: "bg-gray-100 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors" %>
  </div>
<% end %>
