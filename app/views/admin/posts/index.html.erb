<% content_for :title, "게시글 관리" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-navy">📝 게시글 관리</h1>
    <p class="text-sm text-gray-500 mt-1">전체 <%= @posts.size %>개 게시글</p>
  </div>
  <div class="flex items-center gap-2">
    <%= form_with url: admin_posts_path, method: :get, class: "flex gap-2" do |f| %>
      <%= f.select :category, [["전체 카테고리", ""], ["공지", "notice"], ["후기", "review"], ["미디어", "media"]],
          { selected: params[:category] }, class: "border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
      <%= f.select :published, [["전체", ""], ["공개", "true"], ["비공개", "false"]],
          { selected: params[:published] }, class: "border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
      <%= f.submit "필터", class: "bg-gray-100 text-gray-700 px-3 py-2 rounded-lg text-sm cursor-pointer" %>
    <% end %>
    <%= link_to "+ 새 게시글", new_admin_post_path,
        class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90" %>
  </div>
</div>

<!-- 카테고리 통계 -->
<div class="grid grid-cols-3 gap-3 mb-4">
  <% [['notice', '공지', 'blue'], ['review', '후기', 'yellow'], ['media', '미디어', 'purple']].each do |cat, label, color| %>
    <div class="bg-white rounded-lg border border-gray-200 p-4 text-center">
      <p class="text-xs text-gray-500"><%= label %></p>
      <p class="text-2xl font-bold text-<%= color %>-600"><%= @posts.where(category: cat).size %></p>
    </div>
  <% end %>
</div>

<div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b">
      <tr>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">제목</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">카테고리</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">미리보기</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">상태</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">등록일</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @posts.each do |post| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium text-navy"><%= post.title %></td>
          <td class="px-4 py-3">
            <% cats = { 'notice' => ['공지', 'blue'], 'review' => ['후기', 'yellow'], 'media' => ['미디어', 'purple'] } %>
            <% label, color = cats[post.category] || [post.category, 'gray'] %>
            <span class="text-xs px-2 py-0.5 bg-<%= color %>-100 text-<%= color %>-700 rounded-full"><%= label %></span>
          </td>
          <td class="px-4 py-3 text-gray-500 text-xs max-w-xs"><%= truncate(post.content.to_s, length: 60) %></td>
          <td class="px-4 py-3">
            <% if post.published? %>
              <span class="bg-green-100 text-green-700 text-xs px-2 py-0.5 rounded-full">공개</span>
            <% else %>
              <span class="bg-gray-100 text-gray-500 text-xs px-2 py-0.5 rounded-full">비공개</span>
            <% end %>
          </td>
          <td class="px-4 py-3 text-gray-400 text-xs"><%= post.created_at.strftime("%Y.%m.%d") %></td>
          <td class="px-4 py-3 text-right space-x-2">
            <%= link_to "수정", edit_admin_post_path(post), class: "text-xs text-primary" %>
            <%= button_to "삭제", admin_post_path(post), method: :delete,
                class: "text-xs text-red-500",
                data: { turbo_confirm: "삭제하시겠습니까?" } %>
          </td>
        </tr>
      <% end %>
      <% if @posts.empty? %>
        <tr><td colspan="6" class="px-4 py-12 text-center text-gray-400">등록된 게시글이 없습니다.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
