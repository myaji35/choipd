<% content_for :title, "소식 관리" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-xl font-bold text-navy">소식 관리</h1>
  <%= link_to "새 소식", new_admin_post_path, class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-600 transition-colors" %>
</div>

<div class="bg-white rounded-lg border border-gray-100 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b">
      <tr>
        <th class="text-left text-xs text-gray-400 uppercase tracking-wider px-4 py-3">제목</th>
        <th class="text-left text-xs text-gray-400 uppercase tracking-wider px-4 py-3">카테고리</th>
        <th class="text-left text-xs text-gray-400 uppercase tracking-wider px-4 py-3">상태</th>
        <th class="text-left text-xs text-gray-400 uppercase tracking-wider px-4 py-3">등록일</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @posts.each do |post| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium text-navy"><%= post.title %></td>
          <td class="px-4 py-3 text-gray-500">
            <% cats = { 'notice' => '공지', 'review' => '후기', 'media' => '미디어' } %>
            <%= cats[post.category] || post.category %>
          </td>
          <td class="px-4 py-3">
            <% if post.published? %>
              <span class="bg-green-100 text-green-700 text-xs px-2 py-0.5 rounded-full">공개</span>
            <% else %>
              <span class="bg-gray-100 text-gray-500 text-xs px-2 py-0.5 rounded-full">비공개</span>
            <% end %>
          </td>
          <td class="px-4 py-3 text-gray-400"><%= post.created_at.strftime("%Y.%m.%d") %></td>
          <td class="px-4 py-3 text-right space-x-2">
            <%= link_to "수정", edit_admin_post_path(post), class: "text-primary text-xs hover:text-blue-700" %>
            <%= button_to "삭제", admin_post_path(post), method: :delete,
                class: "text-red-500 text-xs hover:text-red-700",
                data: { turbo_confirm: "삭제하시겠습니까?" } %>
          </td>
        </tr>
      <% end %>
      <% if @posts.empty? %>
        <tr><td colspan="5" class="px-4 py-8 text-center text-gray-400">등록된 소식이 없습니다.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
