<% content_for :title, "히어로 이미지" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-navy">🖼️ 히어로 이미지</h1>
    <p class="text-sm text-gray-500 mt-1">전체 <%= @hero_images.size %>개 (활성 <%= @hero_images.select(&:is_active?).size %>개)</p>
  </div>
  <%= link_to "+ 이미지 추가", new_admin_hero_image_path,
      class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90" %>
</div>

<% active_imgs = @hero_images.select(&:is_active?).sort_by { |h| h.display_order || 0 } %>
<% if active_imgs.any? %>
  <div class="bg-blue-50 rounded-lg p-3 mb-4 text-sm text-blue-700">
    💡 활성 이미지 <%= active_imgs.size %>개가 메인 페이지 히어로 슬라이드에 표시됩니다.
    표시 순서: <%= active_imgs.map { |h| h.alt_text.presence || "##{h.id}" }.join(" → ") %>
  </div>
<% end %>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
  <% @hero_images.sort_by { |h| [(h.is_active? ? 0 : 1), h.display_order || 0] }.each do |hero| %>
    <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden <%= 'ring-2 ring-green-400' if hero.is_active? %>">
      <div class="h-48 bg-gray-100 overflow-hidden relative">
        <% if hero.url.present? %>
          <img src="<%= hero.url %>" alt="<%= hero.alt_text %>" class="w-full h-full object-cover">
        <% elsif hero.image.attached? %>
          <%= image_tag hero.image, class: "w-full h-full object-cover" %>
        <% else %>
          <div class="w-full h-full flex items-center justify-center text-gray-300 text-5xl">🖼️</div>
        <% end %>
        <% if hero.is_active? %>
          <span class="absolute top-2 left-2 text-xs px-2 py-0.5 bg-green-500 text-white rounded-full font-semibold">활성</span>
        <% else %>
          <span class="absolute top-2 left-2 text-xs px-2 py-0.5 bg-gray-500 text-white rounded-full">비활성</span>
        <% end %>
        <% if hero.display_order %>
          <span class="absolute top-2 right-2 text-xs px-2 py-0.5 bg-black/60 text-white rounded">#<%= hero.display_order %></span>
        <% end %>
      </div>
      <div class="p-3">
        <p class="text-sm font-medium text-navy"><%= hero.alt_text.presence || "이미지 ##{hero.id}" %></p>
        <% if hero.filename.present? %>
          <p class="text-xs text-gray-500 mt-1 font-mono truncate"><%= hero.filename %></p>
        <% end %>
        <% if hero.width && hero.height %>
          <p class="text-xs text-gray-400 mt-1">📐 <%= hero.width %>×<%= hero.height %><% if hero.file_size %> · <%= number_to_human_size(hero.file_size) %><% end %></p>
        <% end %>
        <div class="mt-3 pt-3 border-t border-gray-100 flex justify-between items-center text-xs">
          <%= link_to "수정", edit_admin_hero_image_path(hero), class: "text-primary" %>
          <%= button_to "삭제", admin_hero_image_path(hero), method: :delete,
              class: "text-red-500 hover:text-red-700",
              data: { turbo_confirm: "삭제하시겠습니까?" } %>
        </div>
      </div>
    </div>
  <% end %>
  <% if @hero_images.empty? %>
    <div class="col-span-3 py-16 text-center text-gray-400 bg-white rounded-lg border border-dashed border-gray-300">
      <p>등록된 히어로 이미지가 없습니다.</p>
      <p class="text-xs mt-2">위 "이미지 추가" 버튼을 눌러주세요.</p>
    </div>
  <% end %>
</div>
