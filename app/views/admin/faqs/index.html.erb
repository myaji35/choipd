<% content_for :title, "FAQ 지식베이스" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <%= link_to "← AI 도구", admin_ai_path, class: "text-primary text-sm" %>
    <h1 class="text-2xl font-bold text-navy mt-2">📚 FAQ 지식베이스</h1>
    <p class="text-sm text-gray-500 mt-1">챗봇이 답하는 자주 묻는 질문 (<%= @faqs.size %>개)</p>
  </div>
  <%= link_to "+ 새 FAQ", new_admin_faq_path, class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90" %>
</div>

<div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b">
      <tr>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">카테고리</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">질문</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">매칭</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">도움됨</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">상태</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @faqs.each do |f| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3"><span class="text-xs px-2 py-0.5 bg-purple-100 text-purple-700 rounded"><%= f.category %></span></td>
          <td class="px-4 py-3 font-medium text-navy"><%= f.question %></td>
          <td class="px-4 py-3 text-xs"><%= f.match_count %></td>
          <td class="px-4 py-3 text-xs"><%= f.helpful_rate %>%</td>
          <td class="px-4 py-3"><% if f.is_active? %><span class="text-xs px-2 py-0.5 bg-green-100 text-green-700 rounded">활성</span><% else %><span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-600 rounded">비활성</span><% end %></td>
          <td class="px-4 py-3 text-right"><%= link_to "보기", admin_faq_path(f), class: "text-xs text-primary" %></td>
        </tr>
      <% end %>
      <% if @faqs.empty? %>
        <tr><td colspan="6" class="px-4 py-12 text-center text-gray-400">FAQ가 없습니다.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
