<% content_for :title, "웹훅" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-navy">🪝 웹훅</h1>
    <p class="text-sm text-gray-500 mt-1">전체 <%= @webhooks.size %>개</p>
  </div>
  <%= link_to "+ 웹훅 추가", new_admin_webhook_path,
      class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90" %>
</div>

<div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b">
      <tr>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">이름</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">URL</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">이벤트</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">성공/실패</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">상태</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @webhooks.each do |w| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium text-navy"><%= w.name %></td>
          <td class="px-4 py-3 text-xs text-gray-500 font-mono truncate max-w-xs"><%= w.url %></td>
          <td class="px-4 py-3 text-xs"><%= w.events_list.join(", ") %></td>
          <td class="px-4 py-3 text-xs"><span class="text-green-600 font-bold"><%= w.success_count %></span> / <span class="text-red-600 font-bold"><%= w.failure_count %></span></td>
          <td class="px-4 py-3">
            <% if w.is_active? %><span class="text-xs px-2 py-0.5 bg-green-100 text-green-700 rounded">활성</span>
            <% else %><span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-600 rounded">비활성</span><% end %>
          </td>
          <td class="px-4 py-3 text-right"><%= link_to "보기", admin_webhook_path(w), class: "text-xs text-primary" %></td>
        </tr>
      <% end %>
      <% if @webhooks.empty? %>
        <tr><td colspan="6" class="px-4 py-12 text-center text-gray-400">등록된 웹훅이 없습니다.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
