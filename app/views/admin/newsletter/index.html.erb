<% content_for :title, "뉴스레터 구독자" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-navy">📧 뉴스레터 구독자</h1>
    <p class="text-sm text-gray-500 mt-1">총 <%= @leads.count %>명</p>
  </div>
  <div class="flex gap-2">
    <%= form_with url: admin_newsletter_index_path, method: :get, class: "flex gap-2" do |f| %>
      <%= f.text_field :q, value: params[:q], placeholder: "이메일 검색",
          class: "border border-gray-300 rounded-lg px-3 py-2 text-sm w-56" %>
      <%= f.submit "검색", class: "bg-gray-100 text-gray-700 px-3 py-2 rounded-lg text-sm cursor-pointer" %>
    <% end %>
    <%= link_to "📥 CSV 내보내기", admin_newsletter_index_path(format: :csv),
        class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90" %>
  </div>
</div>

<!-- 통계 카드 -->
<div class="grid grid-cols-3 gap-3 mb-4">
  <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
    <p class="text-xs text-gray-500">전체</p>
    <p class="text-2xl font-bold text-navy"><%= @leads.count %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
    <p class="text-xs text-gray-500">이번 주</p>
    <p class="text-2xl font-bold text-blue-600"><%= @leads.where("subscribed_at > ?", 7.days.ago).count %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
    <p class="text-xs text-gray-500">이번 달</p>
    <p class="text-2xl font-bold text-emerald-600"><%= @leads.where("subscribed_at > ?", 30.days.ago).count %></p>
  </div>
</div>

<div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b">
      <tr>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">이메일</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">구독일</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @leads.each do |lead| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 text-navy"><%= lead.email %></td>
          <td class="px-4 py-3 text-gray-500 text-xs"><%= (lead.subscribed_at || lead.created_at).strftime("%Y.%m.%d %H:%M") %></td>
          <td class="px-4 py-3 text-right">
            <%= mail_to lead.email, "✉️", class: "text-xs text-primary" %>
          </td>
        </tr>
      <% end %>
      <% if @leads.empty? %>
        <tr><td colspan="3" class="px-4 py-12 text-center text-gray-400">구독자가 없습니다.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
