<% content_for :title, "문의 관리" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-navy">💬 문의 관리</h1>
    <p class="text-sm text-gray-500 mt-1">전체 <%= @inquiries.size %>건</p>
  </div>
  <%= form_with url: admin_inquiries_path, method: :get, class: "flex gap-2" do |f| %>
    <%= f.text_field :q, value: params[:q], placeholder: "이름/이메일 검색",
        class: "border border-gray-300 rounded-lg px-3 py-2 text-sm w-48" %>
    <%= f.select :status, [["전체 상태", ""], ["미처리", "pending"], ["연락완료", "contacted"], ["종료", "closed"]],
        { selected: params[:status] }, class: "border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
    <%= f.select :type, [["전체 유형", ""], ["B2B", "b2b"], ["일반", "contact"]],
        { selected: params[:type] }, class: "border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
    <%= f.submit "검색", class: "bg-primary text-white px-3 py-2 rounded-lg text-sm cursor-pointer" %>
  <% end %>
</div>

<!-- 통계 카드 -->
<div class="grid grid-cols-3 gap-3 mb-4">
  <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 text-center">
    <p class="text-xs text-gray-600">⏳ 미처리</p>
    <p class="text-2xl font-bold text-yellow-700"><%= @inquiries.where(status: 'pending').size %></p>
  </div>
  <div class="bg-green-50 border border-green-200 rounded-lg p-4 text-center">
    <p class="text-xs text-gray-600">✓ 연락완료</p>
    <p class="text-2xl font-bold text-green-700"><%= @inquiries.where(status: 'contacted').size %></p>
  </div>
  <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 text-center">
    <p class="text-xs text-gray-600">📁 종료</p>
    <p class="text-2xl font-bold text-gray-700"><%= @inquiries.where(status: 'closed').size %></p>
  </div>
</div>

<div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b">
      <tr>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">이름</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">이메일</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">유형</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">메시지</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">상태</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">등록일</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @inquiries.each do |inq| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium text-navy"><%= inq.name %></td>
          <td class="px-4 py-3 text-gray-500 text-xs"><%= inq.email %></td>
          <td class="px-4 py-3">
            <% if inq.inquiry_type == 'b2b' %>
              <span class="text-xs px-2 py-0.5 bg-blue-100 text-blue-700 rounded">🏢 B2B</span>
            <% else %>
              <span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-700 rounded">일반</span>
            <% end %>
          </td>
          <td class="px-4 py-3 text-gray-500 text-xs max-w-xs truncate"><%= inq.message %></td>
          <td class="px-4 py-3">
            <% scolor = case inq.status; when 'pending' then 'yellow'; when 'contacted' then 'green'; when 'closed' then 'gray'; else 'gray'; end %>
            <% slabel = case inq.status; when 'pending' then '미처리'; when 'contacted' then '연락완료'; when 'closed' then '종료'; else inq.status; end %>
            <span class="text-xs px-2 py-0.5 bg-<%= scolor %>-100 text-<%= scolor %>-700 rounded-full"><%= slabel %></span>
          </td>
          <td class="px-4 py-3 text-gray-400 text-xs"><%= inq.created_at.strftime("%Y.%m.%d") %></td>
          <td class="px-4 py-3 text-right space-x-1">
            <% if inq.status == 'pending' %>
              <%= button_to "→ 연락완료", admin_inquiry_path(inq, inquiry: { status: 'contacted' }), method: :patch,
                  class: "text-xs text-green-600 hover:text-green-800" %>
            <% end %>
            <%= link_to "보기", admin_inquiry_path(inq), class: "text-xs text-primary" %>
          </td>
        </tr>
      <% end %>
      <% if @inquiries.empty? %>
        <tr><td colspan="7" class="px-4 py-12 text-center text-gray-400">문의가 없습니다.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
