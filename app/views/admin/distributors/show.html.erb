<% content_for :title, @distributor.name %>

<div class="mb-6 flex items-center justify-between">
  <div>
    <%= link_to "← 유통사 목록", admin_distributors_path, class: "text-primary text-sm hover:text-primary-dark" %>
    <h1 class="text-xl font-bold text-navy mt-2"><%= @distributor.name %></h1>
  </div>
  <div class="flex space-x-2">
    <%= link_to "수정", edit_admin_distributor_path(@distributor), class: "bg-gray-100 text-gray-700 px-4 py-2 rounded-lg text-sm hover:bg-gray-200 transition-colors" %>
    <%= button_to "삭제", admin_distributor_path(@distributor), method: :delete,
        class: "bg-red-50 text-red-600 px-4 py-2 rounded-lg text-sm hover:bg-red-100 transition-colors",
        data: { turbo_confirm: "정말 삭제하시겠습니까?" } %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- 기본 정보 -->
  <div class="lg:col-span-2 space-y-4">
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-5">
      <h2 class="font-semibold text-navy mb-4">기본 정보</h2>
      <dl class="grid grid-cols-2 gap-4 text-sm">
        <div>
          <dt class="text-gray-400 text-xs uppercase tracking-wider mb-1">이름</dt>
          <dd class="text-navy font-medium"><%= @distributor.name %></dd>
        </div>
        <div>
          <dt class="text-gray-400 text-xs uppercase tracking-wider mb-1">이메일</dt>
          <dd class="text-navy"><%= @distributor.email %></dd>
        </div>
        <div>
          <dt class="text-gray-400 text-xs uppercase tracking-wider mb-1">업종</dt>
          <dd class="text-navy"><%= @distributor.business_type || '-' %></dd>
        </div>
        <div>
          <dt class="text-gray-400 text-xs uppercase tracking-wider mb-1">지역</dt>
          <dd class="text-navy"><%= @distributor.region || '-' %></dd>
        </div>
        <div>
          <dt class="text-gray-400 text-xs uppercase tracking-wider mb-1">플랜</dt>
          <dd class="text-navy"><%= @distributor.subscription_plan || '-' %></dd>
        </div>
        <div>
          <dt class="text-gray-400 text-xs uppercase tracking-wider mb-1">총 매출</dt>
          <dd class="text-navy font-bold">₩<%= number_with_delimiter(@distributor.total_revenue.to_i) %></dd>
        </div>
      </dl>
    </div>

    <!-- 활동 로그 -->
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-5">
      <h2 class="font-semibold text-navy mb-4">활동 로그</h2>
      <% if @activity_logs.any? %>
        <div class="space-y-3">
          <% @activity_logs.each do |log| %>
            <div class="flex items-start space-x-3 text-sm">
              <div class="w-1.5 h-1.5 rounded-full bg-primary mt-2 flex-shrink-0"></div>
              <div>
                <p class="text-navy"><%= log.description %></p>
                <p class="text-xs text-gray-400 mt-0.5"><%= log.created_at.strftime("%Y.%m.%d %H:%M") %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-400 text-sm">활동 기록이 없습니다.</p>
      <% end %>
    </div>
  </div>

  <!-- 상태 패널 -->
  <div class="space-y-4">
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-5">
      <h2 class="font-semibold text-navy mb-4">상태</h2>
      <div class="mb-4">
        <%= render "status_badge", distributor: @distributor %>
      </div>
      <% if @distributor.pending? %>
        <div class="space-y-2">
          <%= button_to "승인", approve_admin_distributor_path(@distributor),
              class: "w-full bg-green-500 text-white py-2 rounded-lg text-sm font-medium hover:bg-green-600 transition-colors" %>
          <%= button_to "거부", reject_admin_distributor_path(@distributor),
              class: "w-full bg-red-500 text-white py-2 rounded-lg text-sm font-medium hover:bg-red-600 transition-colors" %>
        </div>
      <% end %>
    </div>
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-5">
      <h2 class="font-semibold text-navy mb-3 text-sm">등록 정보</h2>
      <p class="text-xs text-gray-400">등록일: <%= @distributor.created_at.strftime("%Y.%m.%d") %></p>
      <p class="text-xs text-gray-400 mt-1">수정일: <%= @distributor.updated_at.strftime("%Y.%m.%d") %></p>
    </div>
  </div>
</div>
