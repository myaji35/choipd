<%# Identity uploader — Next.js DistributorIdentityUploader.tsx (324줄) 포팅 %>
<div class="bg-white rounded-lg border border-gray-200 shadow-sm p-5"
     data-controller="identity-uploader"
     data-identity-uploader-distributor-id-value="<%= distributor.id %>"
     data-identity-uploader-show-url-value="<%= admin_distributor_identity_path(distributor, format: :json) %>"
     data-identity-uploader-update-url-value="<%= admin_distributor_identity_path(distributor, format: :json) %>"
     data-identity-uploader-delete-url-value="<%= admin_distributor_identity_path(distributor, format: :json) %>"
     data-identity-uploader-csrf-value="<%= form_authenticity_token %>">

  <div class="flex items-start justify-between mb-2">
    <div>
      <h2 class="font-semibold text-navy text-base">📝 회원 아이덴티티 (identity.md)</h2>
      <p class="text-xs text-gray-500 mt-1">브랜드/톤/아젠다를 정의하는 .md 파일을 업로드하면 회원의 콘텐츠/홈페이지에 반영됩니다.</p>
    </div>
    <span data-identity-uploader-target="status" class="text-xs text-gray-400"></span>
  </div>

  <!-- Drop zone -->
  <label class="block mt-3 border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:border-primary cursor-pointer transition-colors"
         data-identity-uploader-target="dropzone"
         data-action="dragover->identity-uploader#dragover dragleave->identity-uploader#dragleave drop->identity-uploader#drop">
    <p class="text-sm text-gray-600">
      📂 .md 파일을 끌어다 놓거나 클릭해서 업로드
    </p>
    <p class="text-xs text-gray-400 mt-1">
      허용 확장자: .md · .markdown · .txt &nbsp;|&nbsp; 최대 512KB
    </p>
    <input type="file" class="hidden" accept=".md,.markdown,.txt"
           data-identity-uploader-target="fileInput"
           data-action="change->identity-uploader#fileSelected">
  </label>

  <!-- Filename + content -->
  <div class="mt-4 space-y-3">
    <div>
      <label class="block text-xs font-semibold text-gray-600 mb-1.5">파일명</label>
      <input type="text" placeholder="identity.md"
             data-identity-uploader-target="filename"
             class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary">
    </div>
    <div>
      <label class="block text-xs font-semibold text-gray-600 mb-1.5">본문 (markdown)</label>
      <textarea rows="12" placeholder="# 브랜드명&#10;&#10;## 아젠다&#10;..."
                data-identity-uploader-target="content"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"></textarea>
    </div>
  </div>

  <!-- Error / actions -->
  <div data-identity-uploader-target="error" class="hidden mt-3 px-3 py-2 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700"></div>

  <div class="mt-4 flex items-center justify-between">
    <p data-identity-uploader-target="meta" class="text-xs text-gray-400"></p>
    <div class="flex space-x-2">
      <button type="button"
              data-identity-uploader-target="deleteBtn"
              data-action="identity-uploader#deleteIdentity"
              class="hidden text-xs text-red-600 hover:text-red-700">삭제</button>
      <button type="button"
              data-action="identity-uploader#save"
              class="bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90">저장</button>
    </div>
  </div>
</div>
