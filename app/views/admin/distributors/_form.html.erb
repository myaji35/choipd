<%= form_with model: [:admin, distributor], class: "space-y-5" do |f| %>
  <% if distributor.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <% distributor.errors.full_messages.each do |msg| %>
        <p class="text-red-600 text-sm"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <div>
      <%= f.label :name, "유통사명", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
    </div>
    <div>
      <%= f.label :email, "이메일", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email, class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
    </div>
    <div>
      <%= f.label :business_type, "업종", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :business_type, placeholder: "소매업, 교육업 등", class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
    </div>
    <div>
      <%= f.label :region, "지역", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :region, placeholder: "서울, 경기 등", class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
    </div>
    <div>
      <%= f.label :subscription_plan, "구독 플랜", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :subscription_plan, [["선택", ""], ["Basic", "basic"], ["Standard", "standard"], ["Premium", "premium"]],
          {},
          class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
    </div>
    <div>
      <%= f.label :status, "상태", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :status, [["대기", "pending"], ["승인", "approved"], ["거부", "rejected"], ["정지", "suspended"]],
          {},
          class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
    </div>
    <div>
      <%= f.label :phone, "연락처", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.telephone_field :phone, placeholder: "010-1234-5678",
          class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
    </div>
    <div>
      <%= f.label :slug, "공개 URL ID (slug)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <div class="flex items-stretch">
        <span class="inline-flex items-center px-3 bg-gray-100 border border-r-0 border-gray-300 rounded-l-lg text-xs text-gray-500 font-mono">/</span>
        <%= f.text_field :slug, placeholder: "byjreporter",
            class: "flex-1 border border-gray-300 rounded-r-lg px-3 py-2.5 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary",
            pattern: "[a-z0-9][a-z0-9-]{1,28}[a-z0-9]",
            title: "영문 소문자/숫자/하이픈, 3~30자, 양끝 하이픈 금지" %>
      </div>
      <p class="text-xs text-gray-400 mt-1">팔로워가 보는 공개 페이지 주소입니다 (영문/숫자/하이픈, 3~30자)</p>
    </div>
  </div>

  <div class="flex space-x-3">
    <%= f.submit distributor.new_record? ? "유통사 등록" : "정보 수정",
        class: "bg-primary text-white px-6 py-2.5 rounded-lg font-medium hover:bg-primary-dark transition-colors cursor-pointer" %>
    <%= link_to "취소", admin_distributors_path, class: "text-gray-500 px-6 py-2.5 rounded-lg font-medium hover:text-gray-700 transition-colors" %>
  </div>
<% end %>
