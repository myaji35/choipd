<% content_for :title, "유통사 관리" %>

<!-- 상단 액션 바 -->
<div class="flex items-center justify-between mb-6">
  <div class="flex items-center space-x-3">
    <!-- 검색 -->
    <%= form_with url: admin_distributors_path, method: :get, class: "flex items-center space-x-2" do |f| %>
      <%= f.text_field :q, value: params[:q], placeholder: "이름 또는 이메일 검색",
          class: "border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary w-48" %>
      <%= f.select :status, [["전체 상태", ""], ["대기", "pending"], ["승인", "approved"], ["거부", "rejected"]],
          { selected: params[:status] },
          class: "border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
      <%= f.select :plan, [["전체 플랜", ""], ["Basic", "basic"], ["Standard", "standard"], ["Premium", "premium"]],
          { selected: params[:plan] },
          class: "border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
      <%= f.submit "검색", class: "bg-primary text-white px-4 py-2 rounded-lg text-sm hover:bg-primary-dark cursor-pointer" %>
    <% end %>
  </div>
  <%= link_to "유통사 등록", new_admin_distributor_path, class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-primary-dark transition-colors" %>
</div>

<!-- 유통사 테이블 -->
<div class="bg-white rounded-lg border border-gray-100 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-surface border-b">
      <tr>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">유통사</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">업종</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">지역</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">플랜</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">상태</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">등록일</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @distributors.each do |d| %>
        <tr class="hover:bg-gray-50 cursor-pointer" onclick="if(!event.target.closest('a,button,form'))location.href='<%= admin_distributor_path(d) %>'">
          <td class="px-4 py-3">
            <div>
              <p class="font-medium text-navy"><%= d.name %></p>
              <p class="text-xs text-gray-400"><%= d.email %></p>
              <% if d.slug.present? %>
                <p class="text-xs text-gray-300 mt-0.5">/<%= d.slug %></p>
              <% end %>
            </div>
          </td>
          <td class="px-4 py-3 text-gray-600"><%= d.business_type %></td>
          <td class="px-4 py-3 text-gray-600"><%= d.region %></td>
          <td class="px-4 py-3">
            <span class="text-xs px-2 py-0.5 rounded bg-gray-100 text-gray-600"><%= d.subscription_plan || '-' %></span>
          </td>
          <td class="px-4 py-3" id="distributor-<%= d.id %>-status">
            <%= render "status_badge", distributor: d %>
          </td>
          <td class="px-4 py-3 text-gray-400 text-xs"><%= d.created_at.strftime("%Y.%m.%d") %></td>
          <td class="px-4 py-3">
            <div class="flex items-center space-x-2">
              <% if d.pending? %>
                <%= button_to "승인", approve_admin_distributor_path(d),
                    class: "text-xs bg-green-100 text-green-700 px-2 py-1 rounded hover:bg-green-200 transition-colors",
                    data: { turbo_stream: true } %>
                <%= button_to "거부", reject_admin_distributor_path(d),
                    class: "text-xs bg-red-100 text-red-700 px-2 py-1 rounded hover:bg-red-200 transition-colors",
                    data: { turbo_stream: true } %>
              <% end %>
              <% if d.slug.present? %>
                <%= link_to "홍보페이지 ↗", "/#{d.slug}",
                    target: "_blank", rel: "noopener noreferrer",
                    class: "text-xs text-blue-600 hover:text-blue-800 font-medium",
                    title: "/#{d.slug} 새 탭에서 열기" %>
              <% end %>
              <%= link_to "보기", admin_distributor_path(d), class: "text-xs text-primary hover:text-primary-dark" %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @distributors.empty? %>
        <tr><td colspan="7" class="text-center py-12 text-gray-400">등록된 유통사가 없습니다.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<!-- 페이지네이션 -->
<% if @pagy.pages > 1 %>
  <div class="mt-4 flex justify-center">
    <%== pagy_nav(@pagy) %>
  </div>
<% end %>
