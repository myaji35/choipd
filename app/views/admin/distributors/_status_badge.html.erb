<span class="text-xs px-2 py-0.5 rounded-full font-medium
  <%= distributor.approved? ? 'bg-green-100 text-green-700' :
      distributor.pending? ? 'bg-yellow-100 text-yellow-700' :
      distributor.rejected? ? 'bg-red-100 text-red-700' : 'bg-gray-100 text-gray-600' %>">
  <%= distributor.approved? ? '승인' :
      distributor.pending? ? '대기' :
      distributor.rejected? ? '거부' : '정지' %>
</span>
