<% content_for :title, "이벤트 로그" %>

<div class="mb-6">
  <%= link_to "← 분석 대시보드", admin_analytics_path, class: "text-primary text-sm" %>
  <h1 class="text-2xl font-bold text-navy mt-2">📜 이벤트 로그</h1>
</div>

<%= form_with url: admin_analytics_events_path, method: :get, class: "flex gap-2 mb-4" do |f| %>
  <%= f.text_field :event_name, value: params[:event_name], placeholder: "이벤트명",
      class: "border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
  <%= f.text_field :category, value: params[:category], placeholder: "카테고리",
      class: "border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
  <%= f.text_field :user_id, value: params[:user_id], placeholder: "사용자 ID",
      class: "border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
  <%= f.submit "필터", class: "bg-primary text-white px-3 py-2 rounded-lg text-sm cursor-pointer" %>
<% end %>

<div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b">
      <tr>
        <th class="text-left px-4 py-2 text-xs font-semibold text-gray-600 uppercase">시간</th>
        <th class="text-left px-4 py-2 text-xs font-semibold text-gray-600 uppercase">이벤트</th>
        <th class="text-left px-4 py-2 text-xs font-semibold text-gray-600 uppercase">카테고리</th>
        <th class="text-left px-4 py-2 text-xs font-semibold text-gray-600 uppercase">사용자</th>
        <th class="text-left px-4 py-2 text-xs font-semibold text-gray-600 uppercase">페이지</th>
        <th class="text-left px-4 py-2 text-xs font-semibold text-gray-600 uppercase">디바이스</th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @events.each do |e| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-2 text-xs text-gray-500"><%= e.created_at.strftime("%Y-%m-%d %H:%M:%S") %></td>
          <td class="px-4 py-2 text-xs font-mono"><%= e.event_name %></td>
          <td class="px-4 py-2 text-xs text-gray-600"><%= e.event_category %></td>
          <td class="px-4 py-2 text-xs text-gray-600"><%= e.user_id || '익명' %></td>
          <td class="px-4 py-2 text-xs text-gray-500 truncate max-w-xs"><%= e.page_path %></td>
          <td class="px-4 py-2 text-xs text-gray-500"><%= e.device_type %></td>
        </tr>
      <% end %>
      <% if @events.empty? %>
        <tr><td colspan="6" class="px-4 py-12 text-center text-gray-400">조건에 맞는 이벤트가 없습니다.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
