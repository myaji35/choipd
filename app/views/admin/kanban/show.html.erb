<% content_for :title, @project.title %>

<div class="mb-4 flex items-center justify-between">
  <div>
    <%= link_to "← 모든 프로젝트", admin_kanban_path, class: "text-sm text-primary" %>
    <h1 class="text-2xl font-bold text-navy mt-2"><%= @project.title %></h1>
    <% if @project.description.present? %>
      <p class="text-sm text-gray-500 mt-1"><%= @project.description %></p>
    <% end %>
  </div>
  <%= button_to "프로젝트 삭제", admin_kanban_project_path(@project), method: :delete,
      class: "text-xs text-red-600 hover:text-red-800",
      data: { turbo_confirm: "정말 삭제하시겠습니까?" } %>
</div>

<div class="kanban-board flex gap-4 overflow-x-auto pb-4"
     data-controller="kanban"
     data-kanban-project-id-value="<%= @project.id %>"
     data-kanban-csrf-value="<%= form_authenticity_token %>"
     data-kanban-move-url-value="<%= "/admin/kanban/projects/#{@project.id}/tasks/__ID__/move" %>"
     data-kanban-create-task-url-value="/admin/kanban/projects/<%= @project.id %>/tasks"
     data-kanban-delete-task-url-value="/admin/kanban/projects/<%= @project.id %>/tasks/__ID__"
     data-kanban-create-column-url-value="/admin/kanban/projects/<%= @project.id %>/columns">

  <% @columns.each do |col| %>
    <div class="kanban-column flex-shrink-0 w-72 bg-gray-100 rounded-lg p-3"
         data-column-id="<%= col.id %>">
      <div class="flex items-center justify-between mb-3">
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full" style="background: <%= col.color || '#6b7280' %>"></span>
          <h3 class="font-semibold text-navy text-sm"><%= col.title %></h3>
          <span class="text-xs text-gray-400">(<%= col.kanban_tasks.size %>)</span>
        </div>
      </div>

      <div class="kanban-tasks space-y-2 min-h-[100px]" data-column-id="<%= col.id %>">
        <% col.kanban_tasks.ordered.each do |t| %>
          <div class="kanban-card bg-white rounded shadow-sm p-3 cursor-move hover:shadow-md transition-shadow"
               data-task-id="<%= t.id %>"
               draggable="true">
            <div class="flex items-start justify-between gap-2">
              <p class="text-sm font-medium text-navy flex-1 <%= 'line-through text-gray-400' if t.is_completed %>">
                <%= t.title %>
              </p>
              <% if t.priority %>
                <% pcolor = case t.priority; when 'urgent' then 'red'; when 'high' then 'orange'; when 'medium' then 'blue'; else 'gray'; end %>
                <span class="text-xs px-1.5 py-0.5 rounded bg-<%= pcolor %>-100 text-<%= pcolor %>-700"><%= t.priority %></span>
              <% end %>
            </div>
            <% if t.description.present? %>
              <p class="text-xs text-gray-500 mt-1 line-clamp-2"><%= t.description %></p>
            <% end %>
            <div class="flex items-center justify-between mt-2 text-xs text-gray-400">
              <% if t.due_date %>
                <span class="<%= 'text-red-500' if t.due_date < Date.today && !t.is_completed %>">📅 <%= t.due_date.strftime("%m/%d") %></span>
              <% else %>
                <span></span>
              <% end %>
              <% if t.assignee.present? %>
                <span>👤 <%= t.assignee %></span>
              <% end %>
            </div>
            <div class="mt-2 flex gap-1.5">
              <% unless t.is_completed %>
                <button data-action="kanban#completeTask" data-task-id="<%= t.id %>" class="text-xs text-emerald-600 hover:text-emerald-800">✓ 완료</button>
              <% else %>
                <button data-action="kanban#reopenTask" data-task-id="<%= t.id %>" class="text-xs text-blue-600 hover:text-blue-800">↻ 재개</button>
              <% end %>
              <button data-action="kanban#deleteTask" data-task-id="<%= t.id %>" class="text-xs text-red-600 hover:text-red-800 ml-auto">삭제</button>
            </div>
          </div>
        <% end %>
      </div>

      <button type="button"
              data-action="kanban#openCreateTask"
              data-column-id="<%= col.id %>"
              class="w-full mt-3 text-xs text-gray-500 hover:text-primary border border-dashed border-gray-300 hover:border-primary rounded p-2">
        + 카드 추가
      </button>
    </div>
  <% end %>

  <!-- 새 컬럼 추가 -->
  <div class="flex-shrink-0 w-72">
    <button type="button"
            data-action="kanban#openCreateColumn"
            class="w-full bg-white border-2 border-dashed border-gray-300 hover:border-primary text-gray-500 hover:text-primary rounded-lg p-4 text-sm">
      + 컬럼 추가
    </button>
  </div>
</div>

<style>
  .kanban-card.dragging { opacity: 0.5; }
  .kanban-tasks.drag-over { background: rgba(59, 130, 246, 0.05); border: 2px dashed #3b82f6; border-radius: 8px; }
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>
