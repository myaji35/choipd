<%= form_with model: [:admin, member], class: "space-y-5" do |f| %>
  <% if member.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <% member.errors.full_messages.each do |msg| %>
        <p class="text-red-600 text-sm"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <div>
      <%= f.label :name, "이름", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.text_field :name, class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
    </div>
    <div>
      <%= f.label :email, "이메일", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.email_field :email, class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
    </div>
    <div>
      <%= f.label :phone, "전화", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.telephone_field :phone, class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm" %>
    </div>
    <div>
      <%= f.label :slug, "공개 URL ID (slug)", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <div class="flex items-stretch">
        <span class="inline-flex items-center px-3 bg-gray-100 border border-r-0 border-gray-300 rounded-l-lg text-xs text-gray-500 font-mono">/</span>
        <%= f.text_field :slug, placeholder: "username", class: "flex-1 border border-gray-300 rounded-r-lg px-3 py-2.5 text-sm font-mono" %>
      </div>
    </div>
    <div>
      <%= f.label :profession, "직업", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.select :profession, [["선택", ""]] + Member::PROFESSIONS.map { |p| [p, p] }, {}, class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm" %>
    </div>
    <div>
      <%= f.label :region, "지역", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.text_field :region, class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm" %>
    </div>
    <div>
      <%= f.label :business_type, "사업 유형", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.select :business_type, [["선택", ""]] + Member::BUSINESS_TYPES.map { |b| [b, b] }, {}, class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm" %>
    </div>
    <div>
      <%= f.label :status, "상태", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.select :status, Member::STATUSES.map { |s| [s, s] }, {}, class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm" %>
    </div>
    <div>
      <%= f.label :impd_status, "IMPD 상태", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.select :impd_status, Member::IMPD_STATUSES.map { |s| [s, s] }, {}, class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm" %>
    </div>
    <div>
      <%= f.label :subscription_plan, "구독 플랜", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.select :subscription_plan, [["basic", "basic"], ["premium", "premium"], ["enterprise", "enterprise"]], {}, class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm" %>
    </div>
    <div class="md:col-span-2">
      <%= f.label :bio, "자기소개", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.text_area :bio, rows: 4, class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm" %>
    </div>
    <div>
      <%= f.label :profile_image, "프로필 이미지 URL", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.url_field :profile_image, class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm" %>
    </div>
    <div>
      <%= f.label :cover_image, "커버 이미지 URL", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.url_field :cover_image, class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm" %>
    </div>
  </div>

  <div class="flex space-x-3">
    <%= f.submit member.new_record? ? "회원 등록" : "정보 수정",
        class: "bg-primary text-white px-6 py-2.5 rounded-lg font-medium hover:opacity-90 cursor-pointer" %>
    <%= link_to "취소", admin_members_path, class: "text-gray-500 px-6 py-2.5 rounded-lg font-medium hover:text-gray-700" %>
  </div>
<% end %>
