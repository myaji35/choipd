<% content_for :title, @member.name %>

<div class="mb-6 flex items-center justify-between">
  <div>
    <%= link_to "← 회원 목록", admin_members_path, class: "text-primary text-sm hover:text-primary-dark" %>
    <h1 class="text-2xl font-bold text-navy mt-2"><%= @member.name %></h1>
    <% if @member.slug.present? %>
      <p class="text-sm text-gray-500 mt-1">
        공개 URL: <%= link_to "/#{@member.slug}", "/#{@member.slug}", target: "_blank", class: "text-primary hover:underline font-mono" %>
      </p>
    <% end %>
  </div>
  <div class="flex space-x-2">
    <%= link_to "수정", edit_admin_member_path(@member), class: "bg-gray-100 text-gray-700 px-4 py-2 rounded-lg text-sm hover:bg-gray-200" %>
    <%= button_to "삭제", admin_member_path(@member), method: :delete,
        class: "bg-red-50 text-red-600 px-4 py-2 rounded-lg text-sm hover:bg-red-100",
        data: { turbo_confirm: "정말 삭제하시겠습니까?" } %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-4">
    <!-- 기본 정보 -->
    <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-5">
      <h2 class="font-semibold text-navy mb-4">기본 정보</h2>
      <div class="flex items-start gap-5 mb-4">
        <% if @member.profile_image.present? %>
          <img src="<%= @member.profile_image %>" alt="" class="w-20 h-20 rounded-full object-cover border-2 border-gray-200">
        <% else %>
          <div class="w-20 h-20 rounded-full bg-gradient-to-br from-blue-400 to-purple-500 flex items-center justify-center text-white font-bold text-2xl">
            <%= @member.name[0] %>
          </div>
        <% end %>
        <div class="flex-1">
          <h3 class="text-lg font-bold text-navy"><%= @member.name %></h3>
          <p class="text-sm text-gray-500"><%= @member.email %></p>
          <% if @member.bio.present? %>
            <p class="text-sm text-gray-700 mt-2"><%= @member.bio %></p>
          <% end %>
        </div>
      </div>
      <dl class="grid grid-cols-2 gap-4 text-sm">
        <div><dt class="text-xs font-semibold text-gray-600">전화</dt><dd class="text-navy"><%= @member.phone || '-' %></dd></div>
        <div><dt class="text-xs font-semibold text-gray-600">직업</dt><dd class="text-navy"><%= @member.profession || '-' %></dd></div>
        <div><dt class="text-xs font-semibold text-gray-600">지역</dt><dd class="text-navy"><%= @member.region || '-' %></dd></div>
        <div><dt class="text-xs font-semibold text-gray-600">사업 유형</dt><dd class="text-navy"><%= @member.business_type || '-' %></dd></div>
        <div><dt class="text-xs font-semibold text-gray-600">슬러그</dt><dd class="text-navy font-mono">/<%= @member.slug %></dd></div>
        <div><dt class="text-xs font-semibold text-gray-600">구독 플랜</dt><dd class="text-navy"><%= @member.subscription_plan %></dd></div>
      </dl>
    </div>

    <!-- 통계 카드 4개 -->
    <div class="grid grid-cols-4 gap-3">
      <div class="bg-white rounded-lg border border-gray-200 p-4 text-center">
        <p class="text-xs text-gray-500 mb-1">포트폴리오</p>
        <p class="text-2xl font-bold text-navy"><%= @portfolio_count %></p>
      </div>
      <div class="bg-white rounded-lg border border-gray-200 p-4 text-center">
        <p class="text-xs text-gray-500 mb-1">서비스</p>
        <p class="text-2xl font-bold text-navy"><%= @services_count %></p>
      </div>
      <div class="bg-white rounded-lg border border-gray-200 p-4 text-center">
        <p class="text-xs text-gray-500 mb-1">포스트</p>
        <p class="text-2xl font-bold text-navy"><%= @posts_count %></p>
      </div>
      <div class="bg-white rounded-lg border border-gray-200 p-4 text-center">
        <p class="text-xs text-gray-500 mb-1">달란트</p>
        <p class="text-2xl font-bold text-navy"><%= @skills.size %></p>
      </div>
    </div>

    <!-- 문서 업로드 -->
    <%= render "document_uploader", member: @member, documents: @documents %>

    <!-- 추출된 달란트 -->
    <%= render "skills_panel", member: @member, skills: @skills %>

    <!-- 갭 리포트 -->
    <%= render "gap_report_panel", member: @member, report: @gap_report %>

    <!-- 후기 -->
    <% if @reviews.any? %>
      <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-5">
        <h2 class="font-semibold text-navy mb-4">최근 후기 (<%= @reviews.size %>)</h2>
        <div class="space-y-3">
          <% @reviews.each do |r| %>
            <div class="border-l-4 border-yellow-400 pl-3 py-1">
              <p class="text-sm">
                <span class="font-medium text-navy"><%= r.reviewer_name %></span>
                <span class="text-yellow-500 ml-2"><%= '★' * r.rating %></span>
              </p>
              <% if r.content.present? %>
                <p class="text-xs text-gray-600 mt-1"><%= r.content %></p>
              <% end %>
              <p class="text-xs text-gray-400 mt-1"><%= r.created_at.strftime("%Y.%m.%d") %> · <span class="font-mono"><%= r.status %></span></p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- 최근 문의 -->
    <% if @inquiries.any? %>
      <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-5">
        <h2 class="font-semibold text-navy mb-4">최근 문의 (<%= @inquiries.size %>)</h2>
        <div class="space-y-3">
          <% @inquiries.each do |i| %>
            <div class="text-sm">
              <p>
                <span class="font-medium text-navy"><%= i.sender_name %></span>
                <span class="text-xs text-gray-500"><%= i.sender_email %></span>
                <% unless i.is_read.to_i.positive? %>
                  <span class="text-xs px-1.5 py-0.5 bg-blue-100 text-blue-700 rounded ml-2">신규</span>
                <% end %>
              </p>
              <p class="text-gray-600 mt-1"><%= truncate(i.message, length: 120) %></p>
              <p class="text-xs text-gray-400 mt-1"><%= i.created_at.strftime("%Y.%m.%d %H:%M") %></p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="space-y-4">
    <!-- 상태 -->
    <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-5">
      <h2 class="font-semibold text-navy mb-4">상태</h2>
      <div class="mb-3">
        <% color = case @member.status; when 'approved' then 'green'; when 'pending_approval' then 'yellow'; when 'rejected' then 'red'; when 'suspended' then 'gray'; else 'gray'; end %>
        <span class="text-sm px-3 py-1 rounded-full bg-<%= color %>-100 text-<%= color %>-700 font-semibold"><%= @member.status %></span>
      </div>
      <% if @member.pending? %>
        <div class="space-y-2">
          <%= button_to "✓ 승인 (소소한 활동 허용)", approve_admin_member_path(@member), class: "w-full bg-green-500 text-white py-2 rounded-lg text-sm font-medium hover:bg-green-600" %>
          <p class="text-[11px] text-gray-500 leading-relaxed">본인 페이지 편집·사진 업로드 등 기본 활동을 허용합니다. Townin 파트너 연결은 우측 "Townin 파트너" 카드에서 별도 관리.</p>
          <%= button_to "✗ 거부", reject_admin_member_path(@member), class: "w-full bg-red-500 text-white py-2 rounded-lg text-sm font-medium hover:bg-red-600" %>
        </div>
      <% elsif @member.approved? %>
        <%= button_to "정지", suspend_admin_member_path(@member), class: "w-full bg-orange-500 text-white py-2 rounded-lg text-sm font-medium hover:bg-orange-600", data: { turbo_confirm: "정지하시겠습니까?" } %>
      <% elsif @member.status == "suspended" %>
        <%= button_to "재활성화", activate_admin_member_path(@member), class: "w-full bg-blue-500 text-white py-2 rounded-lg text-sm font-medium hover:bg-blue-600" %>
      <% end %>
    </div>

    <!-- IMPD 검증 -->
    <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-5">
      <h2 class="font-semibold text-navy mb-3 text-sm">IMPD 검증 (의지 필터)</h2>
      <% icolor = case @member.impd_status; when 'completed' then 'green'; when 'in_progress' then 'blue'; when 'rejected' then 'red'; else 'gray'; end %>
      <div class="mb-2">
        <span class="text-xs px-2 py-0.5 rounded bg-<%= icolor %>-100 text-<%= icolor %>-700"><%= @member.impd_status %></span>
      </div>
      <% if @member.impd_started_at %>
        <p class="text-xs text-gray-500">시작: <%= @member.impd_started_at.strftime("%Y.%m.%d") %></p>
      <% end %>
      <% if @member.impd_completed_at %>
        <p class="text-xs text-gray-500">완료: <%= @member.impd_completed_at.strftime("%Y.%m.%d") %></p>
      <% end %>
    </div>

    <!-- 소셜 로그인 연결 -->
    <% if @member.oauth_connected? %>
      <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold text-navy text-sm flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 48 48" aria-hidden="true">
              <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
              <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
              <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
              <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
            </svg>
            소셜 로그인
          </h2>
          <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded font-medium">연결됨</span>
        </div>
        <p class="text-xs text-gray-600">Provider: <span class="font-mono"><%= @member.provider %></span></p>
        <p class="text-xs text-gray-600 mt-1">UID: <span class="font-mono text-[11px]"><%= @member.uid %></span></p>
        <% if @member.oauth_email_verified.to_i == 1 %>
          <p class="text-xs text-green-600 mt-1">✓ 이메일 인증 완료</p>
        <% end %>
        <% if @member.oauth_connected_at %>
          <p class="text-xs text-gray-400 mt-1">연결일: <%= @member.oauth_connected_at.strftime("%y.%m.%d %H:%M") %></p>
        <% end %>
        <%= button_to "소셜 연결 해제",
              unlink_oauth_admin_member_path(@member),
              method: :post,
              data: { turbo_confirm: "정말 소셜 연결을 해제하시겠습니까? 회원은 비밀번호 재설정 후 로그인해야 합니다." },
              class: "mt-3 w-full text-xs px-3 py-2 border border-red-300 text-red-600 hover:bg-red-50 rounded" %>
      </div>
    <% else %>
      <div class="bg-gray-50 rounded-lg border border-dashed border-gray-300 p-5 text-center">
        <p class="text-xs text-gray-500">소셜 로그인 연결 없음</p>
        <p class="text-xs text-gray-400 mt-1">회원이 Google로 로그인하면 자동 연결됩니다</p>
      </div>
    <% end %>

    <!-- Townin 파트너 연결 -->
    <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-semibold text-navy text-sm flex items-center gap-2">
          🔗 Townin 파트너
        </h2>
        <% case @member.partner_status
           when "active" %>
          <span class="text-xs bg-purple-100 text-purple-700 px-2 py-0.5 rounded font-medium">⭐ 파트너</span>
        <% when "pending" %>
          <span class="text-xs bg-amber-100 text-amber-700 px-2 py-0.5 rounded font-medium">검증 대기</span>
        <% when "suspended" %>
          <span class="text-xs bg-red-100 text-red-700 px-2 py-0.5 rounded font-medium">자격 중지</span>
        <% else %>
          <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded">미연결</span>
        <% end %>
      </div>

      <% if @member.partner_connected? %>
        <p class="text-xs text-gray-600">User ID: <span class="font-mono"><%= @member.towningraph_user_id %></span></p>
        <% if @member.townin_name.present? %>
          <p class="text-xs text-gray-600 mt-1">이름: <%= @member.townin_name %></p>
        <% end %>
        <% if @member.townin_email.present? %>
          <p class="text-xs text-gray-600 mt-1">이메일: <%= @member.townin_email %></p>
        <% end %>
        <% if @member.townin_role.present? %>
          <p class="text-xs text-gray-600 mt-1">역할: <%= @member.townin_role %></p>
        <% end %>
        <% if @member.partner_promoted_at %>
          <p class="text-xs text-purple-600 mt-1">승급일: <%= @member.partner_promoted_at.strftime("%y.%m.%d %H:%M") %></p>
        <% end %>
        <% if @member.partner_notes.present? %>
          <p class="text-xs text-gray-500 mt-1 whitespace-pre-wrap"><%= @member.partner_notes %></p>
        <% end %>

        <%# 액션 버튼 %>
        <div class="mt-3 flex flex-col gap-2">
          <% unless @member.partner_active? %>
            <%= button_to "⭐ 파트너로 승급",
                  promote_partner_admin_member_path(@member),
                  method: :post,
                  class: "w-full text-xs px-3 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded font-medium" %>
          <% end %>
          <% if @member.partner_active? %>
            <%= button_to "파트너 자격 중지",
                  suspend_partner_admin_member_path(@member),
                  method: :post,
                  data: { turbo_confirm: "파트너 자격을 중지하시겠습니까? 공개 페이지의 파트너 섹션이 숨겨집니다." },
                  class: "w-full text-xs px-3 py-2 border border-amber-300 text-amber-700 hover:bg-amber-50 rounded" %>
          <% end %>
          <%= button_to "Townin 연결 해제",
                unlink_townin_admin_member_path(@member),
                method: :post,
                data: { turbo_confirm: "Townin 연결을 완전히 해제하시겠습니까?" },
                class: "w-full text-xs px-3 py-2 border border-red-300 text-red-600 hover:bg-red-50 rounded" %>
        </div>
      <% else %>
        <p class="text-xs text-gray-500 mb-3">Townin 계정을 연결하면 회원을 파트너로 승급할 수 있습니다.</p>
      <% end %>

      <%# 등록/수정 폼 — 토글 %>
      <details class="mt-3" <%= "open" unless @member.partner_connected? %> data-member-id="<%= @member.id %>">
        <summary class="text-xs text-gray-600 cursor-pointer hover:text-navy">
          <%= @member.partner_connected? ? "✏️ Townin 정보 수정" : "➕ Townin 정보 등록" %>
        </summary>

        <%# ISS-321: 이메일로 Townin 계정 자동 조회 %>
        <div class="mt-3 mb-3 p-3 bg-blue-50 border border-blue-200 rounded text-[11px]">
          <div class="flex items-end gap-2">
            <div class="flex-1">
              <label class="block text-[10px] font-semibold text-blue-700 uppercase tracking-wide mb-1">이메일로 조회</label>
              <input type="email" id="townin-lookup-email" placeholder="partner@townin.kr"
                     value="<%= @member.townin_email || @member.email %>"
                     class="w-full text-xs px-2 py-1.5 border border-blue-300 rounded">
            </div>
            <button type="button" id="townin-lookup-btn"
                    data-lookup-url="<%= lookup_townin_admin_member_path(@member) %>"
                    class="text-xs px-3 py-1.5 bg-blue-600 text-white rounded font-medium hover:bg-blue-700 cursor-pointer">
              조회
            </button>
          </div>
          <p id="townin-lookup-status" class="mt-1.5 text-[10px] text-blue-600 hidden"></p>
        </div>

        <%= form_with url: link_townin_admin_member_path(@member), method: :post, local: true, class: "mt-3 space-y-2" do %>
          <div>
            <label class="block text-[10px] font-semibold text-gray-500 uppercase tracking-wide mb-1">User ID</label>
            <input type="text" name="towningraph_user_id" id="townin-user-id" value="<%= @member.towningraph_user_id %>"
                   placeholder="townin-user-123"
                   class="w-full text-xs px-2 py-1.5 border border-gray-300 rounded">
          </div>
          <div>
            <label class="block text-[10px] font-semibold text-gray-500 uppercase tracking-wide mb-1">이메일</label>
            <input type="email" name="townin_email" id="townin-email" value="<%= @member.townin_email %>"
                   placeholder="user@example.com"
                   class="w-full text-xs px-2 py-1.5 border border-gray-300 rounded">
          </div>
          <div>
            <label class="block text-[10px] font-semibold text-gray-500 uppercase tracking-wide mb-1">이름</label>
            <input type="text" name="townin_name" id="townin-name" value="<%= @member.townin_name %>"
                   placeholder="Townin에서 사용하는 이름"
                   class="w-full text-xs px-2 py-1.5 border border-gray-300 rounded">
          </div>
          <div>
            <label class="block text-[10px] font-semibold text-gray-500 uppercase tracking-wide mb-1">역할 (Townin enum)</label>
            <input type="text" name="townin_role" id="townin-role" value="<%= @member.townin_role %>"
                   placeholder="user / merchant / partner / fp / municipality"
                   class="w-full text-xs px-2 py-1.5 border border-gray-300 rounded">
          </div>
          <%= submit_tag "저장", class: "w-full text-xs px-3 py-2 bg-navy hover:bg-navy/90 text-white rounded font-medium cursor-pointer" %>
        <% end %>

        <script>
          (function() {
            const btn = document.getElementById("townin-lookup-btn");
            if (!btn) return;
            btn.addEventListener("click", async function() {
              const email = document.getElementById("townin-lookup-email").value.trim();
              const status = document.getElementById("townin-lookup-status");
              status.classList.remove("hidden");
              status.textContent = "Townin에 조회 중...";
              status.className = "mt-1.5 text-[10px] text-blue-600";
              if (!email || !email.includes("@")) {
                status.textContent = "이메일 형식이 올바르지 않습니다.";
                status.className = "mt-1.5 text-[10px] text-red-600";
                return;
              }
              try {
                const url = btn.dataset.lookupUrl + "?email=" + encodeURIComponent(email);
                const res = await fetch(url, {
                  headers: { "Accept": "application/json", "X-Requested-With": "XMLHttpRequest" }
                });
                const body = await res.json();
                if (!res.ok || !body.found) {
                  status.textContent = body.error || "Townin에서 해당 이메일의 계정을 찾지 못했습니다.";
                  status.className = "mt-1.5 text-[10px] text-amber-600";
                  return;
                }
                const u = body.user;
                document.getElementById("townin-user-id").value = u.id || "";
                document.getElementById("townin-email").value = u.email || "";
                document.getElementById("townin-name").value = u.displayName || "";
                document.getElementById("townin-role").value = u.role || "";
                const partnerMsg = u.partnerId ? ` (이미 파트너: ${u.partnerId})` : "";
                status.textContent = `✓ ${u.displayName || u.email} 자동 채움 완료${partnerMsg}. "저장" 눌러 연결.`;
                status.className = "mt-1.5 text-[10px] text-green-700";
              } catch (e) {
                status.textContent = "조회 실패: " + e.message;
                status.className = "mt-1.5 text-[10px] text-red-600";
              }
            });
          })();
        </script>
      </details>
    </div>

    <!-- 등록 정보 -->
    <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-5">
      <h2 class="font-semibold text-navy mb-3 text-sm">등록 정보</h2>
      <p class="text-xs text-gray-500">등록일: <%= @member.created_at.strftime("%Y.%m.%d") %></p>
      <p class="text-xs text-gray-500 mt-1">수정일: <%= @member.updated_at.strftime("%Y.%m.%d") %></p>
      <p class="text-xs text-gray-400 mt-2 font-mono">#<%= @member.id.to_s.rjust(4, '0') %></p>
    </div>
  </div>
</div>
