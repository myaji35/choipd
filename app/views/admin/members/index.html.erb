<% content_for :title, "회원 관리" %>

<div class="mb-6 flex items-center justify-between">
  <div class="flex items-center space-x-3">
    <%= form_with url: admin_members_path, method: :get, class: "flex items-center space-x-2" do |f| %>
      <%= f.text_field :q, value: params[:q], placeholder: "이름/이메일/슬러그 검색",
          class: "border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary w-56" %>
      <%= f.select :status, [["전체 상태", ""], ["승인 대기", "pending_approval"], ["승인", "approved"], ["거부", "rejected"], ["정지", "suspended"]],
          { selected: params[:status] }, class: "border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
      <%= f.select :impd, [["전체 IMPD", ""], ["없음", "none"], ["진행 중", "in_progress"], ["완료", "completed"], ["거부", "rejected"]],
          { selected: params[:impd] }, class: "border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
      <%= f.select :profession, [["전체 직업", ""], ["보험설계사", "insurance_agent"], ["공인중개사", "realtor"], ["교육자", "educator"], ["저자", "author"], ["사장님", "shopowner"], ["프리랜서", "freelancer"], ["기타", "custom"]],
          { selected: params[:profession] }, class: "border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
      <%= f.submit "검색", class: "bg-primary text-white px-4 py-2 rounded-lg text-sm cursor-pointer" %>
    <% end %>
  </div>
  <%= link_to "+ 회원 추가", new_admin_member_path,
      class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90" %>
</div>

<div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
  <table class="w-full">
    <thead class="bg-gray-50 border-b">
      <tr>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">회원</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">직업</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">지역</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">상태</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">IMPD</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-600 uppercase">등록일</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @members.each do |m| %>
        <tr class="hover:bg-gray-50 cursor-pointer"
            onclick="if(!event.target.closest('a,button,form'))location.href='<%= admin_member_path(m) %>'">
          <td class="px-4 py-3">
            <div class="flex items-center gap-3">
              <% if m.profile_image.present? %>
                <img src="<%= m.profile_image %>" alt="" class="w-10 h-10 rounded-full object-cover">
              <% else %>
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-400 to-purple-500 flex items-center justify-center text-white font-bold text-sm">
                  <%= m.name[0] %>
                </div>
              <% end %>
              <div>
                <p class="font-medium text-navy flex items-center gap-2">
                  <%= m.name %>
                  <% if m.partner_active? %>
                    <span class="text-[10px] px-1.5 py-0.5 bg-purple-100 text-purple-700 rounded font-semibold" title="Townin 검증 파트너">⭐ 파트너</span>
                  <% elsif m.partner_pending? %>
                    <span class="text-[10px] px-1.5 py-0.5 bg-amber-100 text-amber-700 rounded font-semibold" title="Townin 연결됨 · 검증 대기">검증 대기</span>
                  <% end %>
                </p>
                <p class="text-xs text-gray-500"><%= m.email %></p>
                <p class="text-xs text-gray-400 mt-0.5">/<%= m.slug %></p>
              </div>
            </div>
          </td>
          <td class="px-4 py-3 text-sm text-gray-600"><%= m.profession || '-' %></td>
          <td class="px-4 py-3 text-sm text-gray-600"><%= m.region || '-' %></td>
          <td class="px-4 py-3">
            <% color = case m.status; when 'approved' then 'green'; when 'pending_approval' then 'yellow'; when 'rejected' then 'red'; when 'suspended' then 'gray'; else 'gray'; end %>
            <span class="text-xs px-2 py-0.5 rounded-full bg-<%= color %>-100 text-<%= color %>-700"><%= m.status %></span>
          </td>
          <td class="px-4 py-3">
            <% icolor = case m.impd_status; when 'completed' then 'green'; when 'in_progress' then 'blue'; when 'rejected' then 'red'; else 'gray'; end %>
            <span class="text-xs px-2 py-0.5 rounded bg-<%= icolor %>-100 text-<%= icolor %>-700"><%= m.impd_status %></span>
          </td>
          <td class="px-4 py-3 text-xs text-gray-400"><%= m.created_at.strftime("%Y.%m.%d") %></td>
          <td class="px-4 py-3 text-right">
            <div class="inline-flex items-center gap-1.5">
              <% if m.slug.present? %>
                <%= link_to "/#{m.slug}",
                    target: "_blank", rel: "noopener noreferrer",
                    title: "#{m.name}님의 공개 페이지를 새 탭에서 열기",
                    class: "inline-flex items-center gap-1 px-2.5 py-1 rounded-full border border-green-700 text-green-700 hover:bg-green-700 hover:text-white text-xs font-semibold transition" do %>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  공개 페이지
                <% end %>
                <%= link_to "/#{m.slug}/card",
                    target: "_blank", rel: "noopener noreferrer",
                    title: "#{m.name}님의 명함 상세 페이지",
                    class: "inline-flex items-center gap-1 px-2.5 py-1 rounded-full border border-gray-400 text-gray-700 hover:bg-gray-900 hover:text-white text-xs font-semibold transition" do %>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M6 10h6M6 14h4M16 10h2v4h-2z"/></svg>
                  명함
                <% end %>
              <% end %>
              <%= link_to "보기", admin_member_path(m),
                  class: "inline-flex items-center px-2.5 py-1 rounded-full bg-primary text-white text-xs font-semibold hover:opacity-90 transition" %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @members.empty? %>
        <tr><td colspan="7" class="text-center py-12 text-gray-400">조건에 맞는 회원이 없습니다.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<p class="text-xs text-gray-400 mt-4 text-right">전체 <%= @members.respond_to?(:total_count) ? @members.total_count : @members.size %>명</p>
