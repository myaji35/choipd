<div class="bg-white rounded-lg border border-gray-200 shadow-sm p-5">
  <div class="flex items-start justify-between mb-3">
    <div>
      <h2 class="font-semibold text-navy text-base">📊 갭 리포트</h2>
      <p class="text-xs text-gray-500 mt-1">동일 직종 중앙값/상위 10% 대비 현재 위치</p>
    </div>
    <%= button_to "리포트 생성", generate_admin_member_gap_report_path(member, format: :json),
        class: "text-xs bg-primary text-white px-3 py-1.5 rounded hover:opacity-90 cursor-pointer",
        method: :post,
        form: { class: "inline" } %>
  </div>

  <% if report %>
    <div class="grid grid-cols-3 gap-3 mb-4">
      <div class="text-center bg-blue-50 rounded p-3">
        <p class="text-xs text-gray-500">완성도</p>
        <p class="text-2xl font-bold text-navy"><%= report.completeness_score %>%</p>
      </div>
      <div class="text-center bg-orange-50 rounded p-3">
        <p class="text-xs text-gray-500">갭</p>
        <p class="text-2xl font-bold text-navy"><%= report.gaps.size %></p>
      </div>
      <div class="text-center bg-purple-50 rounded p-3">
        <p class="text-xs text-gray-500">peer</p>
        <p class="text-2xl font-bold text-navy"><%= report.peer_sample_size %></p>
      </div>
    </div>

    <% radar = report.radar_self_data %>
    <% median = report.radar_median_data %>
    <% top10 = report.radar_top10_data %>
    <div class="space-y-2">
      <% radar.each do |axis, val| %>
        <div>
          <div class="flex items-center justify-between text-xs mb-1">
            <span class="font-medium text-navy"><%= axis %></span>
            <span class="text-gray-500">
              나 <span class="font-bold text-blue-600"><%= val %></span>
              | 중앙 <%= median[axis.to_s] %>
              | 상위10% <%= top10[axis.to_s] %>
            </span>
          </div>
          <div class="relative h-2 bg-gray-200 rounded">
            <div class="absolute h-full bg-blue-500 rounded" style="width: <%= val %>%"></div>
            <div class="absolute h-full w-0.5 bg-yellow-500" style="left: <%= median[axis.to_s] %>%" title="중앙값"></div>
            <div class="absolute h-full w-0.5 bg-red-500" style="left: <%= top10[axis.to_s] %>%" title="상위 10%"></div>
          </div>
        </div>
      <% end %>
    </div>

    <% if report.gaps.any? %>
      <div class="mt-4 border-t border-gray-100 pt-4">
        <h3 class="text-xs font-semibold text-gray-600 mb-2">개선 권고</h3>
        <div class="space-y-2">
          <% report.gaps.each do |g| %>
            <div class="text-xs px-3 py-2 bg-amber-50 border-l-4 border-amber-400 rounded">
              <span class="font-semibold"><%= g["axis"] %></span>
              · 현재 <%= g["current"] %> → 목표 <%= g["target"] %>
              <span class="ml-2 text-amber-700"><%= g["recommendation"] %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <p class="text-xs text-gray-400 mt-3 text-right">생성: <%= report.generated_at.strftime("%Y.%m.%d %H:%M") %></p>
  <% else %>
    <p class="text-center text-sm text-gray-400 py-6">
      아직 갭 리포트가 없습니다.<br>
      <span class="text-xs">위 "리포트 생성" 버튼을 눌러주세요.</span>
    </p>
  <% end %>
</div>
