<% content_for :title, "imPD를 쓰는 사람들" %>
<% content_for :description, "직업군과 지역으로 imPD의 공개 프로필을 찾아보세요." %>
<% content_for :head do %>
  <link rel="canonical" href="<%= public_base_url %><%= explore_path %>">
<% end %>

<style>
  .explore-wrap { width: min(1120px, calc(100% - 48px)); margin: 0 auto; padding: 72px 0 96px; }
  .explore-title { color: var(--impd-green); font-size: clamp(36px, 6vw, 64px); word-break: keep-all; }
  .explore-subtitle { margin-top: 14px; color: var(--impd-muted); font-size: 17px; line-height: 1.7; }
  .explore-filters { margin-top: 44px; padding: 24px; background: var(--impd-card); border-radius: 12px; box-shadow: var(--impd-shadow-card); }
  .explore-filter-row { display: flex; align-items: flex-start; gap: 18px; }
  .explore-filter-row + .explore-filter-row { margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--impd-rule); }
  .explore-filter-label { flex: 0 0 58px; padding-top: 8px; color: var(--impd-muted); font-size: 12px; font-weight: 700; }
  .explore-chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .explore-chip { display: inline-flex; align-items: center; min-height: 34px; padding: 7px 14px; border: 1px solid var(--impd-rule); border-radius: 50px; background: var(--impd-card); color: var(--impd-ink2); font-size: 13px; font-weight: 600; }
  .explore-chip:hover { border-color: var(--impd-green-accent); color: var(--impd-green-accent); }
  .explore-chip.is-active { border-color: var(--impd-green-accent); background: var(--impd-green-accent); color: var(--impd-on-dark); }
  .explore-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18px; margin-top: 34px; }
  .explore-card { min-height: 310px; overflow: hidden; background: var(--impd-card); border-radius: 12px; box-shadow: var(--impd-shadow-card); transition: transform .2s ease, box-shadow .2s ease; }
  .explore-card:hover { transform: translateY(-3px); box-shadow: var(--impd-shadow-frap); }
  .explore-card-image { width: 100%; aspect-ratio: 16 / 10; display: block; object-fit: cover; background: var(--impd-green-mint); }
  .explore-card-placeholder { display: flex; align-items: center; justify-content: center; color: var(--impd-green); font-family: var(--impd-font-display); font-size: 44px; font-weight: 800; }
  .explore-card-body { padding: 20px; }
  .explore-card-name { font-size: 22px; line-height: 1.3; word-break: keep-all; }
  .explore-card-meta { margin-top: 8px; color: var(--impd-muted); font-size: 14px; line-height: 1.6; }
  .explore-badge { display: inline-flex; margin-top: 16px; padding: 5px 9px; border-radius: 3px; background: var(--impd-green-house); color: var(--impd-on-dark); font-size: 12px; font-weight: 700; }
  .explore-empty { grid-column: 1 / -1; padding: 64px 24px; background: var(--impd-card); border-radius: 12px; color: var(--impd-muted); font-size: 16px; text-align: center; box-shadow: var(--impd-shadow-card); }
  @media (max-width: 820px) { .explore-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 560px) {
    .explore-wrap { width: min(100% - 32px, 1120px); padding: 48px 0 72px; }
    .explore-filters { padding: 18px; }
    .explore-filter-row { display: block; }
    .explore-filter-label { display: block; padding: 0 0 10px; }
    .explore-grid { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) { .explore-card { transition: none; } }
</style>

<section class="explore-wrap">
  <header>
    <p class="impd-label">MEMBER DIRECTORY</p>
    <h1 class="impd-display explore-title">imPD를 쓰는 사람들</h1>
    <p class="explore-subtitle">직업군·지역으로 찾아보세요</p>
  </header>

  <div class="explore-filters" aria-label="회원 필터">
    <div class="explore-filter-row">
      <span class="explore-filter-label">직업군</span>
      <div class="explore-chips">
        <%= link_to "전체", explore_path(region: @current_region.presence), class: ["explore-chip", ("is-active" if @current_profession.blank?)] %>
        <% @professions.each do |profession| %>
          <%= link_to ProfessionPreset.label(profession), explore_path(profession: profession, region: @current_region.presence), class: ["explore-chip", ("is-active" if @current_profession == profession)] %>
        <% end %>
      </div>
    </div>
    <div class="explore-filter-row">
      <span class="explore-filter-label">지역</span>
      <div class="explore-chips">
        <%= link_to "전체", explore_path(profession: @current_profession.presence), class: ["explore-chip", ("is-active" if @current_region.blank?)] %>
        <% @regions.each do |region| %>
          <%= link_to region, explore_path(profession: @current_profession.presence, region: region), class: ["explore-chip", ("is-active" if @current_region == region)] %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="explore-grid">
    <% if @members.any? %>
      <% @members.each do |member| %>
        <%= link_to public_profile_path(member.slug), class: "explore-card", aria: { label: "#{member.name} 공개 프로필 보기" } do %>
          <% if member.profile_image.present? %>
            <%= image_tag member.profile_image, class: "explore-card-image", alt: "#{member.name} 프로필 사진", loading: "lazy" %>
          <% else %>
            <div class="explore-card-image explore-card-placeholder" aria-hidden="true"><%= member.name.to_s.first %></div>
          <% end %>
          <div class="explore-card-body">
            <h2 class="impd-display explore-card-name"><%= member.name %></h2>
            <p class="explore-card-meta"><%= member.profession_label %><%= " · #{member.region}" if member.region.present? %></p>
            <% if member.is_featured? %><span class="explore-badge">추천 회원</span><% end %>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <p class="explore-empty">조건에 맞는 회원이 없어요. 필터를 바꿔보세요.</p>
    <% end %>
  </div>
</section>
