<% content_for :title, "프로필 관리" %>

<div class="max-w-lg">
  <h1 class="text-xl font-bold text-navy mb-6">프로필 관리</h1>

  <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-6">
    <%= form_with model: current_admin_user, url: pd_profile_path, method: :patch, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :email, "이메일", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary bg-gray-50", disabled: true %>
        <p class="text-xs text-gray-400 mt-1">이메일은 변경할 수 없습니다.</p>
      </div>

      <div>
        <p class="block text-sm font-medium text-gray-700 mb-3">비밀번호 변경</p>
        <div class="space-y-3">
          <div>
            <%= f.label :current_password, "현재 비밀번호", class: "block text-xs text-gray-500 mb-1" %>
            <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
          </div>
          <div>
            <%= f.label :password, "새 비밀번호", class: "block text-xs text-gray-500 mb-1" %>
            <%= f.password_field :password, autocomplete: "new-password", class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
          </div>
          <div>
            <%= f.label :password_confirmation, "새 비밀번호 확인", class: "block text-xs text-gray-500 mb-1" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
          </div>
        </div>
      </div>

      <%= f.submit "저장", class: "bg-primary text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-blue-600 transition-colors cursor-pointer" %>
    <% end %>
  </div>
</div>
