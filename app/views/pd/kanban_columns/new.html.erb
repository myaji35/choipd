<% content_for :title, "컬럼 추가" %>
<div class="max-w-lg">
  <div class="mb-6">
    <%= link_to "← #{@project.title}", pd_kanban_project_path(@project), class: "text-primary text-sm hover:text-primary-dark" %>
    <h1 class="text-xl font-bold text-navy mt-2">컬럼 추가</h1>
  </div>
  <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-6">
    <%= form_with model: [:pd, @project, @column], class: "space-y-4" do |f| %>
      <div>
        <%= f.label :title, "컬럼명", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :title, placeholder: "예: To Do, In Progress, Done", class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
      </div>
      <div class="flex space-x-3">
        <%= f.submit "추가", class: "bg-primary text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-blue-600 transition-colors cursor-pointer" %>
        <%= link_to "취소", pd_kanban_project_path(@project), class: "bg-gray-100 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
