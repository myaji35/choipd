<%= form_with model: [:pd, hero_image], multipart: true, class: "space-y-4" do |f| %>
  <% if hero_image.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <% hero_image.errors.full_messages.each do |msg| %>
        <p class="text-red-600 text-sm"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <% if hero_image.image.attached? %>
    <div class="mb-4">
      <p class="text-sm text-gray-500 mb-2">현재 이미지</p>
      <%= image_tag hero_image.image, class: "w-full h-40 object-cover rounded-lg" %>
    </div>
  <% end %>

  <div>
    <%= f.label :image, "이미지 파일", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.file_field :image, accept: "image/*", class: "w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-primary/10 file:text-primary hover:file:bg-primary/20" %>
  </div>

  <div>
    <%= f.label :alt_text, "대체 텍스트 (설명)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :alt_text, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
  </div>

  <div class="flex items-center space-x-2">
    <%= f.check_box :is_active, class: "rounded border-gray-300 text-primary" %>
    <%= f.label :is_active, "활성화 (홈페이지에 표시)", class: "text-sm font-medium text-gray-700" %>
  </div>

  <div class="flex space-x-3">
    <%= f.submit hero_image.persisted? ? "수정" : "업로드", class: "bg-primary text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-blue-600 transition-colors cursor-pointer" %>
    <%= link_to "취소", pd_hero_images_path, class: "bg-gray-100 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors" %>
  </div>
<% end %>
