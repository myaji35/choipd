<% content_for :title, "히어로 이미지 관리" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-xl font-bold text-navy">히어로 이미지</h1>
  <%= link_to "이미지 추가", new_pd_hero_image_path, class: "bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-600 transition-colors" %>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
  <% @hero_images.each do |hero| %>
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm overflow-hidden">
      <div class="h-40 bg-gray-100 overflow-hidden">
        <% if hero.image.attached? %>
          <%= image_tag hero.image, class: "w-full h-full object-cover" %>
        <% else %>
          <div class="w-full h-full flex items-center justify-center">
            <svg class="w-10 h-10 text-gray-300" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="1.5">
              <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
        <% end %>
      </div>
      <div class="p-4">
        <div class="flex items-center justify-between mb-2">
          <p class="text-sm font-medium text-navy truncate"><%= hero.alt_text.presence || "이미지 #{hero.id}" %></p>
          <% if hero.is_active? %>
            <span class="bg-green-100 text-green-700 text-xs px-2 py-0.5 rounded-full ml-2 whitespace-nowrap">활성</span>
          <% else %>
            <span class="bg-gray-100 text-gray-500 text-xs px-2 py-0.5 rounded-full ml-2 whitespace-nowrap">비활성</span>
          <% end %>
        </div>
        <div class="flex space-x-2">
          <%= link_to "수정", edit_pd_hero_image_path(hero), class: "text-primary text-xs hover:text-blue-700" %>
          <%= button_to "삭제", pd_hero_image_path(hero), method: :delete,
              class: "text-red-500 text-xs hover:text-red-700",
              data: { turbo_confirm: "삭제하시겠습니까?" } %>
        </div>
      </div>
    </div>
  <% end %>
  <% if @hero_images.empty? %>
    <div class="col-span-3 py-12 text-center text-gray-400 bg-white rounded-lg border border-gray-100">
      등록된 히어로 이미지가 없습니다.
    </div>
  <% end %>
</div>
