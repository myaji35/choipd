<%= form_with model: [:pd, sns_account], class: "space-y-4" do |f| %>
  <% if sns_account.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <% sns_account.errors.full_messages.each do |msg| %>
        <p class="text-red-600 text-sm"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :platform, "플랫폼", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :platform, SnsAccount::PLATFORMS.map { |p| [p.upcase, p] }, {}, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
  </div>

  <div>
    <%= f.label :account_name, "계정명", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :account_name, placeholder: "@username", class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" %>
  </div>

  <div>
    <%= f.label :access_token, "액세스 토큰", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :access_token, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary font-mono" %>
    <p class="text-xs text-gray-400 mt-1">저장 시 암호화됩니다.</p>
  </div>

  <div class="flex items-center space-x-2">
    <%= f.check_box :is_active, class: "rounded border-gray-300 text-primary" %>
    <%= f.label :is_active, "활성화", class: "text-sm font-medium text-gray-700" %>
  </div>

  <div class="flex space-x-3">
    <%= f.submit sns_account.persisted? ? "수정" : "추가", class: "bg-primary text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-blue-600 transition-colors cursor-pointer" %>
    <%= link_to "취소", pd_sns_accounts_path, class: "bg-gray-100 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors" %>
  </div>
<% end %>
