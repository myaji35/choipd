<% content_for :title, "로그인 · imPD" %>

<style>
  body { margin: 0; background: var(--impd-paper, #efece4); color: var(--impd-ink, #0f0d0b); font-family: var(--impd-font-sans, 'Pretendard Variable', 'Pretendard', system-ui, sans-serif); min-height: 100vh; }

  .auth-shell {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    align-items: stretch;
  }
  @media (max-width: 860px) {
    .auth-shell { grid-template-columns: 1fr; }
    .auth-poster { min-height: 220px; }
  }

  /* ── 좌측 폼 ─────────────────────────── */
  .auth-form-col {
    display: flex;
    flex-direction: column;
    padding: 48px 56px;
    background: var(--impd-paper, #efece4);
    position: relative;
  }
  .auth-form-col::before {
    content: "";
    position: absolute; inset: 0;
    background-image:
      linear-gradient(to right, rgba(15,13,11,0.06) 1px, transparent 1px);
    background-size: 80px 100%;
    pointer-events: none;
    opacity: 0.5;
  }
  .auth-brand {
    font-family: var(--impd-font-display, 'Inter Tight', system-ui);
    font-weight: 800; font-size: 36px; letter-spacing: -1.6px;
    color: var(--impd-ink, #0f0d0b);
    margin: 0;
    position: relative;
  }
  .auth-brand .dot { color: var(--impd-accent, #3a2af0); }
  .auth-strap {
    font-family: var(--impd-font-mono, 'JetBrains Mono', monospace);
    font-size: 10px; letter-spacing: 1.4px; text-transform: uppercase;
    color: var(--impd-accent, #3a2af0);
    margin-top: 4px;
    position: relative;
  }

  .auth-form-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 440px;
    width: 100%;
    position: relative;
    padding-top: 48px;
  }

  .auth-head {
    border-top: 1px solid var(--impd-ink, #0f0d0b);
    padding-top: 20px;
    margin-bottom: 32px;
  }
  .auth-section {
    font-family: var(--impd-font-mono, 'JetBrains Mono', monospace);
    font-size: 11px; letter-spacing: 1.4px; text-transform: uppercase;
    color: var(--impd-accent, #3a2af0);
    margin-bottom: 8px;
  }
  .auth-headline {
    font-family: var(--impd-font-display, 'Inter Tight');
    font-weight: 800;
    font-size: 44px;
    letter-spacing: -1.8px;
    line-height: 1.02;
    margin: 0;
  }
  .auth-headline .serif {
    font-family: var(--impd-font-serif, 'Noto Serif KR', serif);
    font-style: italic;
    font-weight: 400;
    color: var(--impd-accent, #3a2af0);
  }
  .auth-sub {
    margin-top: 16px;
    font-size: 14px;
    color: rgba(15,13,11,0.65);
    line-height: 1.6;
  }

  .auth-field { margin-bottom: 16px; }
  .auth-field label {
    display: block;
    font-family: var(--impd-font-mono, 'JetBrains Mono', monospace);
    font-size: 10px; letter-spacing: 1.2px; text-transform: uppercase;
    color: rgba(15,13,11,0.55);
    margin-bottom: 6px;
  }
  .auth-field input[type="email"],
  .auth-field input[type="password"] {
    width: 100%;
    padding: 12px 14px;
    background: #fff;
    border: 1px solid var(--impd-ink, #0f0d0b);
    border-radius: 0;
    color: var(--impd-ink, #0f0d0b);
    font-size: 15px;
    font-family: var(--impd-font-mono, 'JetBrains Mono', monospace);
    box-sizing: border-box;
    transition: background 150ms ease, border-color 150ms ease;
  }
  .auth-field input:focus {
    outline: none;
    border-color: var(--impd-accent, #3a2af0);
    background: #fcfaf4;
    box-shadow: 0 0 0 3px rgba(58,42,240,0.1);
  }

  .auth-remember {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
    color: rgba(15,13,11,0.65);
    font-size: 13px;
  }
  .auth-remember input[type="checkbox"] {
    width: 16px; height: 16px;
    accent-color: var(--impd-accent, #3a2af0);
    cursor: pointer;
  }

  .auth-submit {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 0 22px;
    height: 52px;
    background: var(--impd-ink, #0f0d0b);
    color: var(--impd-paper, #efece4);
    border: 0;
    border-radius: 0;
    font-family: var(--impd-font-sans, 'Pretendard Variable');
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -0.2px;
    cursor: pointer;
    transition: background 150ms ease;
  }
  .auth-submit:hover { background: var(--impd-accent, #3a2af0); }

  .auth-alert {
    background: rgba(255,90,31,0.08);
    border-left: 2px solid var(--impd-accent-2, #ff5a1f);
    color: var(--impd-accent-2, #ff5a1f);
    padding: 10px 14px;
    font-size: 13px;
    margin-bottom: 16px;
  }

  .auth-demo {
    margin-top: 28px;
    padding: 14px 16px;
    background: #fff;
    border: 1px solid var(--impd-rule, rgba(15,13,11,0.15));
    font-family: var(--impd-font-mono, 'JetBrains Mono', monospace);
    font-size: 11px;
    color: rgba(15,13,11,0.75);
    line-height: 1.7;
  }
  .auth-demo strong { color: var(--impd-ink, #0f0d0b); font-weight: 700; }

  .auth-foot {
    margin-top: auto;
    padding-top: 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--impd-font-mono, 'JetBrains Mono', monospace);
    font-size: 10px; letter-spacing: 1.2px; text-transform: uppercase;
    color: rgba(15,13,11,0.45);
    position: relative;
  }
  .auth-foot a { color: inherit; text-decoration: none; }
  .auth-foot a:hover { color: var(--impd-accent, #3a2af0); }

  /* ── 우측 포스터 ──────────────────────── */
  .auth-poster {
    background: var(--impd-ink, #0f0d0b);
    color: var(--impd-paper, #efece4);
    padding: 56px 48px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
  }
  .auth-poster::before {
    content: "";
    position: absolute; inset: 0;
    background-image: repeating-linear-gradient(135deg, rgba(255,255,255,0.04) 0 3px, transparent 3px 10px);
    pointer-events: none;
  }
  .auth-poster-label {
    font-family: var(--impd-font-mono, 'JetBrains Mono', monospace);
    font-size: 10px; letter-spacing: 1.6px; text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    position: relative;
  }
  .auth-poster-title {
    font-family: var(--impd-font-display, 'Inter Tight');
    font-weight: 800;
    font-size: clamp(44px, 5.5vw, 72px);
    letter-spacing: -2.6px;
    line-height: 0.95;
    position: relative;
    margin-top: 40px;
  }
  .auth-poster-title .serif {
    font-family: var(--impd-font-serif, 'Noto Serif KR', serif);
    font-style: italic;
    font-weight: 400;
    color: var(--impd-accent-2, #ff5a1f);
  }
  .auth-poster-sub {
    margin-top: 20px;
    font-family: var(--impd-font-serif, 'Noto Serif KR', serif);
    font-style: italic;
    font-size: 18px;
    line-height: 1.5;
    color: rgba(255,255,255,0.75);
    max-width: 32ch;
    position: relative;
  }
  .auth-poster-meta {
    font-family: var(--impd-font-mono, 'JetBrains Mono', monospace);
    font-size: 10px; letter-spacing: 1.2px; text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    display: flex;
    justify-content: space-between;
    position: relative;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.15);
  }
</style>

<main class="auth-shell">
  <!-- 좌측: 폼 -->
  <section class="auth-form-col">
    <div style="position: relative;">
      <h1 class="auth-brand">imPD<span class="dot">.</span></h1>
      <p class="auth-strap">EST. 2026 · SEOUL</p>
    </div>

    <div class="auth-form-wrap">
      <div class="auth-head">
        <div class="auth-section">§ LOGIN · 운영자 전용</div>
        <h2 class="auth-headline">
          돌아오신 걸<br>
          <span class="serif">환영합니다.</span>
        </h2>
        <p class="auth-sub">
          관리자 · PD 계정으로 접속해 주세요. 회원 계정은 회원 페이지 전용 링크를 이용하세요.
        </p>
      </div>

      <% if alert.present? %>
        <div class="auth-alert"><%= alert %></div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="auth-field">
          <%= f.label :email, "이메일" %>
          <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                placeholder: "name@example.com" %>
        </div>

        <div class="auth-field">
          <%= f.label :password, "비밀번호" %>
          <%= f.password_field :password,
                autocomplete: "current-password",
                placeholder: "비밀번호 입력" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="auth-remember">
            <%= f.check_box :remember_me %>
            <%= f.label :remember_me, "로그인 유지" %>
          </div>
        <% end %>

        <%= f.submit "로그인 →", class: "auth-submit" %>
      <% end %>

      <%# 구분선 — 회원용 OAuth 진입 %>
      <div style="display: flex; align-items: center; gap: 12px; margin: 32px 0 20px; color: rgba(15,13,11,0.4); font-family: var(--impd-font-mono); font-size: 10px; letter-spacing: 1.4px; text-transform: uppercase;">
        <span style="flex: 1; height: 1px; background: var(--impd-rule);"></span>
        <span>또는 · 회원이신가요</span>
        <span style="flex: 1; height: 1px; background: var(--impd-rule);"></span>
      </div>

      <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false },
            class: "",
            style: "display: inline-flex; align-items: center; justify-content: center; gap: 10px; width: 100%; padding: 0 22px; height: 48px; background: #fff; color: var(--impd-ink); border: 1px solid var(--impd-ink); border-radius: 0; font-family: var(--impd-font-sans); font-size: 14px; font-weight: 600; letter-spacing: -0.2px; cursor: pointer; transition: background 150ms ease;" do %>
        <svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true">
          <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
          <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
          <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
        </svg>
        <span>Google로 시작하기</span>
      <% end %>

      <p style="margin-top: 10px; font-size: 11px; color: var(--impd-muted); line-height: 1.5;">
        Google 계정으로 처음 로그인하시면 자동으로 회원 페이지가 생성됩니다. 관리자 승인 후 편집할 수 있습니다.
      </p>

      <div class="auth-foot">
        <%= link_to "← 메인으로", root_path %>
        <span>VOL. 1 · ISSUE 04</span>
      </div>
    </div>
  </section>

  <!-- 우측: 에디토리얼 포스터 -->
  <aside class="auth-poster" aria-hidden="true">
    <div class="auth-poster-label">§ MANIFESTO — OUR QUIET PROMISE</div>
    <div>
      <h3 class="auth-poster-title">
        업로드만<br>
        하세요.<br>
        <span class="serif">나머지는<br>저희가.</span>
      </h3>
      <p class="auth-poster-sub">
        사진 몇 장, 수료증 하나, 이력 한 줄. 정리되지 않아도 괜찮습니다. imPD가 당신의 페이지로 만들어 드립니다.
      </p>
    </div>
    <div class="auth-poster-meta">
      <span>2026 · 봄호</span>
      <span>AUTH · /login</span>
    </div>
  </aside>
</main>
