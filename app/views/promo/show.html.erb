  <script>
    // ─── 타임코드 & 리플레이 ──────────────────────
    const DURATION = 30_000; // ms
    const start = performance.now();
    const tc = document.getElementById('timecode');
    const replay = document.getElementById('replay');

    function fmt(sec) {
      const s = Math.max(0, Math.floor(sec));
      const m = Math.floor(s / 60).toString().padStart(2, '0');
      const r = (s % 60).toString().padStart(2, '0');
      return m + ':' + r;
    }

    let finished = false;
    function tick(now) {
      const elapsed = (now - start) / 1000;
      if (tc) tc.textContent = fmt(elapsed) + ' / 00:30';
      if (elapsed >= 30 && !finished) {
        finished = true;
        setTimeout(() => replay && replay.classList.add('show'), 400);
      }
      if (elapsed < 31) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);

    // ─── S5 카운트업 ───────────────────────────────
    const S5_START = 22_000; // ms
    const S5_DUR = 1_800;
    const counters = document.querySelectorAll('[data-counter]');
    let counted = false;
    function runCounters() {
      counters.forEach(el => {
        const target = parseFloat(el.dataset.counter);
        const divide = parseFloat(el.dataset.divide || '1');
        const prefix = el.dataset.prefix || '';
        const suffix = el.dataset.suffix || '';
        const startTs = performance.now();
        function step(now) {
          const p = Math.min(1, (now - startTs) / S5_DUR);
          const ease = 1 - Math.pow(1 - p, 3);
          const cur = target * ease;
          const display = divide > 1
            ? (cur / divide).toFixed(1)
            : Math.floor(cur).toLocaleString();
          el.textContent = prefix + display + suffix;
          if (p < 1) requestAnimationFrame(step);
          else {
            const final = divide > 1 ? (target / divide).toFixed(1) : target.toLocaleString();
            el.textContent = prefix + final + suffix;
          }
        }
        requestAnimationFrame(step);
      });
    }
    function watchS5(now) {
      const elapsed = now - start;
      if (!counted && elapsed >= S5_START) {
        counted = true;
        runCounters();
      }
      if (elapsed < 30_000) requestAnimationFrame(watchS5);
    }
    requestAnimationFrame(watchS5);

    // ─── 단축키: 1~6 씬 점프, SPACE 일시정지, R 리플레이 ──
    const sceneOffsets = { '1': 0, '2': 5, '3': 10, '4': 15, '5': 22, '6': 27 };
    let paused = false;
    document.addEventListener('keydown', (e) => {
      if (e.key === 'r' || e.key === 'R') {
        window.location.reload();
      } else if (e.key === ' ') {
        e.preventDefault();
        paused = !paused;
        document.querySelectorAll('.scene, .progress > i, .chip, .black-hole, .url-slug, .url-caret, .mockup, .stacked .card, .metric, .logo, .h1-dark, .cta, .tagline, .eyebrow-live, .eyebrow, .h1, .h2, .subline').forEach(el => {
          el.style.animationPlayState = paused ? 'paused' : 'running';
        });
      } else if (sceneOffsets.hasOwnProperty(e.key)) {
        // 씬 점프: 모든 애니메이션의 animation-delay 를 음수로 shift
        const offsetSec = sceneOffsets[e.key];
        document.querySelectorAll('.scene, .progress > i').forEach(el => {
          el.style.animationDelay = `-${offsetSec}s`;
        });
      }
    });
  </script>
</body>
</html>
