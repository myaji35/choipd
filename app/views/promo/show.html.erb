<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>imPD — 내 일의 PD가 됩니다</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Noto+Serif+KR:wght@600;700&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet">
  <style>
    /* ═══════════════════════════════════════════════════════════════
       imPD Promo — 30초 시네마틱
       씬 타임라인:
         S1  0.0 –  5.0s : 다섯 개의 로그인 창 (플랫폼 조각 drift)
         S2  5.0 – 10.0s : 흩어진 내 일 (조각 수렴)
         S3 10.0 – 15.0s : 하나의 주소로 (impd.me/demo 타이핑)
         S4 15.0 – 22.0s : 한 사람의 모든 화면 (3D 플립 목업)
         S5 22.0 – 27.0s : 진짜 일하고 있다는 증거 (LIVE 카운터)
         S6 27.0 – 30.0s : 내 일의 PD가 됩니다 (종이 페이드)
    ═══════════════════════════════════════════════════════════════ */

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --hero: #00A1E0;
      --hero-soft: rgba(0, 161, 224, 0.35);
      --hero-glow: 0 0 30px rgba(34, 211, 238, 0.35);
      --ink: #0f172a;
      --ink-deeper: #060b18;
      --paper: #efece4;
      --ink-paper: #1a1a1a;
      --muted: rgba(255, 255, 255, 0.6);
      --muted-strong: rgba(255, 255, 255, 0.8);
      --chip-border: rgba(255, 255, 255, 0.12);

      --font-body: 'Inter', -apple-system, 'Noto Sans KR', sans-serif;
      --font-serif: 'Noto Serif KR', serif;
      --font-mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;

      --duration: 30s;
    }

    html, body {
      width: 100%;
      height: 100%;
      background: #000;
      color: #fff;
      font-family: var(--font-body);
      overflow: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* 16:9 고정 스테이지. 뷰포트보다 크면 object-fit 느낌으로 스케일 */
    .stage {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: 100vh;
      overflow: hidden;
      background: var(--ink);
    }

    /* ─── 씬 공통 ─────────────────────────────────── */
    .scene {
      position: absolute;
      inset: 0;
      opacity: 0;
      visibility: hidden;
    }
    .scene.running { animation-play-state: running; }
    .scene.paused  { animation-play-state: paused; }

    /* scene 타이밍은 개별 @keyframes 로 제어 — 각 씬별 start/end */
    .s1 { animation: showS1 var(--duration) linear forwards; }
    .s2 { animation: showS2 var(--duration) linear forwards; }
    .s3 { animation: showS3 var(--duration) linear forwards; }
    .s4 { animation: showS4 var(--duration) linear forwards; }
    .s5 { animation: showS5 var(--duration) linear forwards; }
    .s6 { animation: showS6 var(--duration) linear forwards; }

    /* 각 씬 visibility on/off. %는 초 단위 기반 (30s 기준):
       5s=16.667%, 10s=33.333%, 15s=50%, 22s=73.333%, 27s=90%, 30s=100% */
    @keyframes showS1 {
      0%       { opacity: 0; visibility: visible; }
      1%       { opacity: 1; }
      15%      { opacity: 1; }
      16.667%  { opacity: 0; visibility: hidden; }
      100%     { opacity: 0; visibility: hidden; }
    }
    @keyframes showS2 {
      0%, 15%     { opacity: 0; visibility: hidden; }
      16.666%     { opacity: 0; visibility: visible; }
      17.5%       { opacity: 1; }
      32%         { opacity: 1; }
      33.333%     { opacity: 0; visibility: hidden; }
      100%        { opacity: 0; visibility: hidden; }
    }
    @keyframes showS3 {
      0%, 32%     { opacity: 0; visibility: hidden; }
      33.333%     { opacity: 0; visibility: visible; }
      34.5%       { opacity: 1; }
      48%         { opacity: 1; }
      50%         { opacity: 0; visibility: hidden; }
      100%        { opacity: 0; visibility: hidden; }
    }
    @keyframes showS4 {
      0%, 48%     { opacity: 0; visibility: hidden; }
      50%         { opacity: 0; visibility: visible; }
      51.5%       { opacity: 1; }
      71%         { opacity: 1; }
      73.333%     { opacity: 0; visibility: hidden; }
      100%        { opacity: 0; visibility: hidden; }
    }
    @keyframes showS5 {
      0%, 71%     { opacity: 0; visibility: hidden; }
      73.333%     { opacity: 0; visibility: visible; }
      74.5%       { opacity: 1; }
      88%         { opacity: 1; }
      90%         { opacity: 0; visibility: hidden; }
      100%        { opacity: 0; visibility: hidden; }
    }
    @keyframes showS6 {
      0%, 88%     { opacity: 0; visibility: hidden; }
      90%         { opacity: 0; visibility: visible; }
      91.5%       { opacity: 1; }
      100%        { opacity: 1; }
    }

    /* ─── 공통 타이포 ─────────────────────────────── */
    .eyebrow {
      font-family: var(--font-mono);
      font-size: clamp(11px, 0.95vw, 14px);
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--hero);
      margin-bottom: 1.2rem;
      opacity: 0.9;
    }
    .h1 {
      font-family: var(--font-body);
      font-weight: 800;
      font-size: clamp(44px, 6.2vw, 108px);
      line-height: 1.02;
      letter-spacing: -0.02em;
    }
    .h1 .serif {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 700;
    }
    .h2 {
      font-family: var(--font-body);
      font-weight: 700;
      font-size: clamp(28px, 3.6vw, 60px);
      line-height: 1.1;
      letter-spacing: -0.015em;
    }
    .subline {
      font-family: var(--font-body);
      font-size: clamp(15px, 1.2vw, 20px);
      color: var(--muted-strong);
      margin-top: 1rem;
      font-weight: 500;
    }

    /* ─── 레코딩 인디케이터 ──────────────────────── */
    .rec {
      position: absolute;
      top: 28px;
      left: 32px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      color: rgba(255, 255, 255, 0.55);
      z-index: 50;
      text-transform: uppercase;
    }
    .rec::before {
      content: '';
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: #ef4444;
      animation: blink 1.2s ease-in-out infinite;
      box-shadow: 0 0 8px rgba(239, 68, 68, 0.6);
    }
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.25; }
    }

    /* ─── 프로그레스 바 ──────────────────────────── */
    .progress {
      position: absolute;
      left: 32px;
      right: 32px;
      bottom: 28px;
      height: 3px;
      background: rgba(255, 255, 255, 0.08);
      border-radius: 999px;
      overflow: hidden;
      z-index: 50;
    }
    .progress > i {
      display: block;
      width: 0%;
      height: 100%;
      background: linear-gradient(90deg, var(--hero), #67e8f9);
      animation: progressGrow var(--duration) linear forwards;
    }
    @keyframes progressGrow {
      to { width: 100%; }
    }

    .timecode {
      position: absolute;
      bottom: 40px;
      right: 32px;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      color: rgba(255, 255, 255, 0.45);
      z-index: 50;
    }

    /* ═══════════════════════════════════════════════
       씬 1 — 다섯 개의 로그인 창
       ═══════════════════════════════════════════════ */
    .s1 {
      background: radial-gradient(ellipse at center, #0f172a 0%, #060b18 70%);
    }
    .s1 .center {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      padding: 0 8vw;
      z-index: 3;
    }

    .chip {
      position: absolute;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      border: 1px solid var(--chip-border);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.04);
      backdrop-filter: blur(8px);
      font-family: var(--font-mono);
      font-size: 13px;
      color: rgba(255, 255, 255, 0.82);
      white-space: nowrap;
      will-change: transform;
    }
    .chip .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--hero);
      box-shadow: 0 0 8px var(--hero);
    }
    .chip--warn .dot { background: #f59e0b; box-shadow: 0 0 8px #f59e0b; }
    .chip--pink .dot { background: #ec4899; box-shadow: 0 0 8px #ec4899; }
    .chip--green .dot { background: #10b981; box-shadow: 0 0 8px #10b981; }
    .chip--violet .dot { background: #a78bfa; box-shadow: 0 0 8px #a78bfa; }

    /* 각 칩: 드리프트 → 수렴 */
    .chip-1 { top: 18%; left: 8%;  animation: drift1 var(--duration) ease-in-out forwards; }
    .chip-2 { top: 28%; right: 12%; animation: drift2 var(--duration) ease-in-out forwards; }
    .chip-3 { top: 62%; left: 14%;  animation: drift3 var(--duration) ease-in-out forwards; }
    .chip-4 { top: 72%; right: 18%; animation: drift4 var(--duration) ease-in-out forwards; }
    .chip-5 { top: 44%; left: 42%;  animation: drift5 var(--duration) ease-in-out forwards; }

    @keyframes drift1 {
      0%    { transform: translate(0, 0) rotate(-6deg); opacity: 0; }
      2%    { opacity: 1; }
      14%   { transform: translate(-20px, 14px) rotate(-8deg); opacity: 1; }
      17%   { opacity: 0; }
      /* 씬 2 수렴 */
      18%   { transform: translate(40vw, 32vh) rotate(-8deg) scale(0.6); opacity: 1; }
      32%   { transform: translate(46vw, 42vh) rotate(-12deg) scale(0); opacity: 0; }
      100%  { transform: translate(46vw, 42vh) rotate(-12deg) scale(0); opacity: 0; }
    }
    @keyframes drift2 {
      0%    { transform: translate(0, 0) rotate(4deg); opacity: 0; }
      3%    { opacity: 1; }
      14%   { transform: translate(16px, -12px) rotate(6deg); opacity: 1; }
      17%   { opacity: 0; }
      18%   { transform: translate(-34vw, 30vh) rotate(6deg) scale(0.6); opacity: 1; }
      32%   { transform: translate(-40vw, 38vh) rotate(12deg) scale(0); opacity: 0; }
      100%  { transform: translate(-40vw, 38vh) scale(0); opacity: 0; }
    }
    @keyframes drift3 {
      0%    { transform: translate(0, 0) rotate(-3deg); opacity: 0; }
      4%    { opacity: 1; }
      14%   { transform: translate(12px, -18px) rotate(-5deg); opacity: 1; }
      17%   { opacity: 0; }
      18%   { transform: translate(34vw, -10vh) rotate(-5deg) scale(0.6); opacity: 1; }
      32%   { transform: translate(40vw, -14vh) rotate(-10deg) scale(0); opacity: 0; }
      100%  { transform: translate(40vw, -14vh) scale(0); opacity: 0; }
    }
    @keyframes drift4 {
      0%    { transform: translate(0, 0) rotate(5deg); opacity: 0; }
      5%    { opacity: 1; }
      14%   { transform: translate(-14px, -10px) rotate(7deg); opacity: 1; }
      17%   { opacity: 0; }
      18%   { transform: translate(-26vw, -14vh) rotate(7deg) scale(0.6); opacity: 1; }
      32%   { transform: translate(-32vw, -18vh) rotate(14deg) scale(0); opacity: 0; }
      100%  { transform: translate(-32vw, -18vh) scale(0); opacity: 0; }
    }
    @keyframes drift5 {
      0%    { transform: translate(0, 0) rotate(2deg); opacity: 0; }
      6%    { opacity: 1; }
      14%   { transform: translate(6px, 18px) rotate(-2deg); opacity: 1; }
      17%   { opacity: 0; }
      18%   { transform: translate(0, 6vh) rotate(-2deg) scale(0.6); opacity: 1; }
      32%   { transform: translate(0, 10vh) rotate(-6deg) scale(0); opacity: 0; }
      100%  { transform: translate(0, 10vh) scale(0); opacity: 0; }
    }

    .s1 .eyebrow,
    .s1 .h1 {
      animation: fadeUp 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) 0.6s both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ═══════════════════════════════════════════════
       씬 2 — 흩어진 내 일 (중앙 수렴)
       ═══════════════════════════════════════════════ */
    .s2 {
      background: radial-gradient(ellipse at center, #0f172a 0%, #060b18 80%);
    }
    .s2 .center {
      position: absolute;
      inset: 0;
      display: flex;
      justify-content: center;
      align-items: center;
      z-index: 3;
    }
    .s2 .black-hole {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: var(--hero);
      transform: translate(-50%, -50%);
      box-shadow:
        0 0 40px var(--hero),
        0 0 80px var(--hero-soft),
        0 0 140px var(--hero-soft);
      animation: pulse 2s ease-in-out infinite;
      opacity: 0.9;
    }
    @keyframes pulse {
      0%, 100% { transform: translate(-50%, -50%) scale(1); }
      50%      { transform: translate(-50%, -50%) scale(1.4); }
    }
    .s2 .h1 {
      position: relative;
      text-align: center;
      animation: fadeUp 1.4s cubic-bezier(0.2, 0.8, 0.2, 1) 0.8s both;
    }

    /* ═══════════════════════════════════════════════
       씬 3 — impd.me/demo 타이핑
       ═══════════════════════════════════════════════ */
    .s3 {
      background: #000;
    }
    .s3::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, rgba(0, 161, 224, 0.12) 0%, transparent 60%);
    }
    .s3 .center {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      z-index: 3;
      padding: 0 4vw;
    }
    .url-box {
      display: inline-flex;
      align-items: baseline;
      gap: 0;
      font-family: var(--font-mono);
      font-size: clamp(36px, 6vw, 96px);
      font-weight: 600;
      letter-spacing: -0.02em;
      margin-bottom: 2.5rem;
      padding: 1.2rem 2rem;
      border: 1px solid rgba(0, 161, 224, 0.25);
      border-radius: 16px;
      background: rgba(0, 161, 224, 0.04);
      box-shadow: var(--hero-glow);
    }
    .url-fixed { color: rgba(255, 255, 255, 0.55); }
    .url-slug {
      color: var(--hero);
      text-shadow: 0 0 20px rgba(0, 161, 224, 0.5);
      overflow: hidden;
      white-space: nowrap;
      display: inline-block;
      max-width: 0;
      animation: typeSlug 1.4s steps(4, end) forwards;
      animation-delay: calc(var(--duration) * 0.355);
    }
    .url-caret {
      display: inline-block;
      width: 3px;
      height: 0.9em;
      background: var(--hero);
      margin-left: 4px;
      transform: translateY(0.08em);
      animation: caretBlink 0.7s steps(2) infinite;
    }
    @keyframes typeSlug {
      from { max-width: 0; }
      to   { max-width: 8ch; }
    }
    @keyframes caretBlink {
      50% { opacity: 0; }
    }
    .s3 .h1,
    .s3 .subline {
      animation: fadeUp 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
      opacity: 0;
    }
    .s3 .h1 { animation-delay: calc(var(--duration) * 0.345); }
    .s3 .subline { animation-delay: calc(var(--duration) * 0.40); }

    /* ═══════════════════════════════════════════════
       씬 4 — 3D 플립 목업 카드
       ═══════════════════════════════════════════════ */
    .s4 {
      background:
        radial-gradient(ellipse at 20% 30%, rgba(0, 161, 224, 0.10) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 70%, rgba(0, 161, 224, 0.06) 0%, transparent 50%),
        #0a1222;
      perspective: 1800px;
    }
    .s4 .eyebrow-wrap {
      position: absolute;
      top: 14vh;
      left: 0;
      right: 0;
      text-align: center;
      z-index: 2;
    }
    .s4 .eyebrow {
      font-size: clamp(13px, 1.1vw, 17px);
      margin: 0;
    }
    .s4 .h2 {
      text-align: center;
      margin-top: 0.8rem;
    }
    .mockup-stage {
      position: absolute;
      inset: 0;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 3vw;
      padding-top: 4vh;
      transform-style: preserve-3d;
    }
    .mockup {
      position: relative;
      width: 22vw;
      min-width: 280px;
      max-width: 420px;
      aspect-ratio: 3 / 4;
      border-radius: 18px;
      background: linear-gradient(155deg, #0f1e36 0%, #081123 100%);
      border: 1px solid rgba(0, 161, 224, 0.22);
      box-shadow:
        0 30px 80px rgba(0, 0, 0, 0.6),
        0 0 0 1px rgba(255, 255, 255, 0.04) inset,
        var(--hero-glow);
      transform: rotateY(90deg);
      opacity: 0;
      padding: 24px;
      overflow: hidden;
    }
    .mockup-1 {
      animation: flipIn 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
      animation-delay: calc(var(--duration) * 0.52);
    }
    .mockup-2 {
      animation: flipIn 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
      animation-delay: calc(var(--duration) * 0.56);
    }
    .mockup-3 {
      animation: flipIn 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
      animation-delay: calc(var(--duration) * 0.60);
    }
    @keyframes flipIn {
      from { transform: rotateY(90deg) translateY(30px); opacity: 0; }
      to   { transform: rotateY(0deg) translateY(0); opacity: 1; }
    }

    .mockup-label {
      position: absolute;
      top: 20px;
      left: 24px;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      color: var(--hero);
      text-transform: uppercase;
    }
    .mockup-title {
      position: absolute;
      top: 44px;
      left: 24px;
      font-size: 22px;
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.01em;
    }
    .mock-bar {
      position: absolute;
      left: 24px;
      right: 24px;
      height: 10px;
      background: rgba(255, 255, 255, 0.06);
      border-radius: 6px;
      overflow: hidden;
    }
    .mock-bar > i {
      display: block;
      height: 100%;
      background: var(--hero);
      border-radius: 6px;
    }
    .mock-kpi {
      position: absolute;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 10px;
      padding: 10px 12px;
      color: #fff;
    }
    .mock-kpi .label {
      font-family: var(--font-mono);
      font-size: 9px;
      letter-spacing: 0.2em;
      color: rgba(255, 255, 255, 0.5);
      text-transform: uppercase;
    }
    .mock-kpi .value {
      font-size: 20px;
      font-weight: 700;
      margin-top: 4px;
      color: var(--hero);
    }

    /* 목업 1 — 공개 프로필 */
    .m1-avatar {
      position: absolute;
      top: 90px;
      left: 24px;
      width: 54px;
      height: 54px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--hero), #67e8f9);
    }
    .m1-name {
      position: absolute;
      top: 96px;
      left: 90px;
      font-size: 15px;
      font-weight: 600;
    }
    .m1-handle {
      position: absolute;
      top: 118px;
      left: 90px;
      font-family: var(--font-mono);
      font-size: 11px;
      color: rgba(255, 255, 255, 0.5);
    }
    .m1-btn {
      position: absolute;
      left: 24px;
      right: 24px;
      height: 34px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: 600;
    }
    .m1-btn.primary {
      top: 168px;
      background: var(--hero);
      color: #05161f;
    }
    .m1-btn.ghost {
      top: 212px;
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.12);
      color: rgba(255, 255, 255, 0.7);
    }
    .m1-row {
      position: absolute;
      left: 24px;
      right: 24px;
      height: 38px;
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .m1-r1 { top: 262px; }
    .m1-r2 { top: 306px; }
    .m1-r3 { top: 350px; }

    /* 목업 2 — 어드민 대시보드 */
    .m2-kpi-1 { top: 84px;  left: 24px; width: calc(50% - 28px); }
    .m2-kpi-2 { top: 84px;  right: 24px; width: calc(50% - 28px); }
    .m2-bar-1 { top: 170px; }
    .m2-bar-2 { top: 190px; width: 60%; }
    .m2-bar-3 { top: 210px; width: 80%; }
    .m2-chart {
      position: absolute;
