<% content_for :title, "#{@member.name} | imPD" %>
<% content_for :description, @member.bio.to_s.first(160) %>

<%# OG/Twitter 카드 — 카톡/페북/슬랙 공유 시 디지털 명함 이미지 노출. %>
<% content_for :head do %>
  <%
    card_url  = "#{public_base_url}/card/#{@member.slug}.svg"
    share_url = "#{public_base_url}/#{@member.slug}"
  %>
  <meta property="og:type" content="profile">
  <meta property="og:title" content="<%= @member.name %> — imPD">
  <meta property="og:description" content="<%= @member.bio.to_s.first(160).presence || '흩어진 내 일, 하나의 주소로.' %>">
  <meta property="og:url" content="<%= share_url %>">
  <meta property="og:image" content="<%= card_url %>">
  <meta property="og:image:type" content="image/svg+xml">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= @member.name %> — imPD">
  <meta name="twitter:description" content="<%= @member.bio.to_s.first(160).presence || '흩어진 내 일, 하나의 주소로.' %>">
  <meta name="twitter:image" content="<%= card_url %>">
  <%
    social_urls = case (social = @member.social)
    when Hash
      social.values
    when Array
      social.map { |entry| entry.is_a?(Hash) ? (entry["url"] || entry[:url]) : entry }
    else
      []
    end.filter_map { |value| value.to_s.presence }

    person_schema = {
      "@context" => "https://schema.org",
      "@type" => "Person",
      "name" => @member.name,
      "url" => share_url,
      "jobTitle" => @member.profession_label,
      "description" => @member.bio.presence,
      "image" => @member.profile_image.presence,
      "address" => (@member.region.present? ? {
        "@type" => "PostalAddress",
        "addressLocality" => @member.region
      } : nil),
      "sameAs" => social_urls.presence
    }.compact
    person_schema_json = person_schema.to_json.gsub("</", "<\\/").html_safe
  %>
  <script type="application/ld+json"><%= person_schema_json %></script>
  <% if @faqs.any? %>
    <%
      faq_schema = {
        "@context" => "https://schema.org",
        "@type" => "FAQPage",
        "mainEntity" => @faqs.map do |faq|
          {
            "@type" => "Question",
            "name" => faq.question,
            "acceptedAnswer" => {
              "@type" => "Answer",
              "text" => faq.answer
            }
          }
        end
      }
      faq_schema_json = faq_schema.to_json.gsub("</", "<\\/").html_safe
    %>
    <script type="application/ld+json"><%= faq_schema_json %></script>
  <% end %>
<% end %>

<style>
  .impd-wrap { max-width: 1200px; margin: 0 auto; padding-inline: 40px; }
  .impd-section { padding-block: 40px; }  /* 64 → 40: 섹션간 세로 여백 축소 */
  .impd-section-header { margin-bottom: 20px; }
  .impd-section-header .impd-display, h2.impd-display, h3.impd-display, h4.impd-display { word-break: keep-all; }
  @media (max-width: 768px) { .impd-wrap { padding-inline: 20px; } .impd-section { padding-block: 28px; } }
</style>

<!-- ── Masthead (3컬럼) ───────────────────────── -->
<section class="impd-wrap impd-section">
  <div style="display: grid; grid-template-columns: 1.3fr 1fr 0.9fr; gap: 40px; align-items: start;" class="masthead-grid">
    <!-- 좌: 이름 -->
    <div>
      <div class="impd-label">§A · imPD 검증 회원</div>
      <h1 style="font-family: var(--impd-font-display); font-weight: 800; font-size: clamp(64px, 10vw, 128px); line-height: 0.88; letter-spacing: -4px; margin-top: 16px;">
        <%= @member.name %>
        <% if @member.profession.present? %>
          <br><span style="color: var(--impd-accent); font-style: italic; word-break: keep-all;"><%= @member.profession_label %>.</span>
        <% end %>
      </h1>
      <% if @member.bio.present? %>
        <p class="impd-serif" style="font-size: 22px; line-height: 1.45; margin-top: 24px; color: var(--impd-ink2); max-width: 480px;">
          "<%= @member.bio %>"
        </p>
      <% end %>
    </div>

    <!-- 중: Polaroid Stack (업로드된 사진 우선, 없으면 더미) -->
    <div style="display: flex; justify-content: center;">
      <%
        fallback_colors = [ "#ff5a1f", "#3a2af0", "#2a9d8f", "#e4b230", "#1a1a1a" ]
        fallback_items = [
          { kind: "최근 활동", date: "이번 달", caption: "현장 사진." },
          { kind: "수료증",    date: "검증 완료", caption: "공인 자격." },
          { kind: "포트폴리오", date: "오늘",     caption: "최신 작업물." },
          { kind: "후기",      date: "별점 5",   caption: "고객의 칭찬." },
          { kind: "인터뷰",    date: "최근",     caption: "미디어 출연기." }
        ]
        # 일상 사진 상위 5장을 폴라로이드로 (업로드된 것 있으면 우선)
        recent_photos = @moments&.first(5) || []
        polaroid_items = fallback_items.each_with_index.map do |item, i|
          photo = recent_photos[i]
          if photo && photo.image.attached?
            {
              color: fallback_colors[i],
              kind: photo.category.to_s.upcase,
              date: photo.uploaded_at&.strftime("%y.%m.%d") || item[:date],
              caption: photo.caption.presence || item[:caption],
              image_url: photo.video? ? nil : (photo.thumbnail_url || photo.display_url),
              video_url: photo.video? ? photo.display_url : nil,
            }
          else
            { color: fallback_colors[i] }.merge(item)
          end
        end
      %>
      <%= render "shared/polaroid_stack", width: 300, height: 360, items: polaroid_items %>
    </div>

    <!-- 우: 직함·지역·CTA -->
    <div>
      <% is_owner_view = viewing_as_owner?(@member) %>

      <% if is_owner_view %>
        <%# 본인만 보이는 진입 CTA — 이메일 기반 AI 자동 채우기 위자드 %>
        <%= link_to "/welcome/probe", title: "imPD가 이메일을 바탕으로 공개 정보를 찾아 페이지를 자동으로 채워드려요",
            style: "display: flex; align-items: center; gap: 10px; padding: 14px 16px; background: var(--impd-green-house); color: var(--impd-on-dark); border-radius: 12px; margin-bottom: 14px; text-decoration: none; box-shadow: var(--impd-shadow-card); transition: transform .2s ease, background .2s ease;",
            onmouseover: "this.style.background='var(--impd-green)'",
            onmouseout: "this.style.background='var(--impd-green-house)'" do %>
          <div style="width: 36px; height: 36px; border-radius: 50%; background: var(--impd-gold); color: var(--impd-green-house); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l2 4 4 2-4 2-2 4-2-4-4-2 4-2z"/><path d="M19 14l1 2 2 1-2 1-1 2-1-2-2-1 2-1z"/></svg>
          </div>
          <div style="flex: 1; min-width: 0;">
            <div style="font-family: var(--impd-font-mono); font-size: 12px; letter-spacing: 1.2px; text-transform: uppercase; color: var(--impd-gold); margin-bottom: 2px;">imPD AI · 본인 전용</div>
            <div style="font-size: 14px; font-weight: 700; letter-spacing: -0.01em; line-height: 1.3;">이메일로 자동 채우기 →</div>
          </div>
        <% end %>
      <% end %>

      <% if @member.partner_active? %>
        <%# Townin 파트너 배지 — 히어로 상단 %>
        <a href="#partner" style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; background: var(--impd-accent-2); color: #fff; font-family: var(--impd-font-sans); font-weight: 600; font-size: 12px; letter-spacing: -0.2px; margin-bottom: 14px; text-decoration: none;">
          ⭐ Townin <%= @member.partner_display_role || "파트너" %>
        </a>
      <% end %>
      <dl style="border-top: 1px solid var(--impd-ink); padding-top: 16px;">
        <% if @member.profession.present? %>
          <div style="margin-bottom: 8px;"><dt class="impd-label-muted">직함</dt><dd style="font-family: var(--impd-font-display); font-size: 20px; margin-top: 4px;"><%= @member.profession_label %></dd></div>
        <% end %>
        <% if @member.region.present? %>
          <div style="margin-bottom: 8px;"><dt class="impd-label-muted">지역</dt><dd style="font-family: var(--impd-font-display); font-size: 20px; margin-top: 4px;"><%= @member.region %></dd></div>
        <% end %>
        <% if @services.any? %>
          <div style="margin-bottom: 8px;"><dt class="impd-label-muted">서비스</dt><dd style="font-family: var(--impd-font-display); font-size: 20px; margin-top: 4px;"><%= @services.first.title %></dd></div>
        <% end %>
      </dl>
      <a href="#contact" class="impd-btn impd-btn-primary" style="width: 100%; justify-content: center; margin-top: 14px;">문의하기 →</a>
      <a href="#classes" class="impd-btn impd-btn-secondary" style="width: 100%; justify-content: center; margin-top: 6px;">서비스 보기</a>

      <%# 빠른 연결 — 한국 프리랜서가 바로 연락받을 수 있는 채널. 값 있는 것만 노출. %>
      <%
        social = @member.social
        kakao_ch = social["kakao_channel"].presence
        quick_links = []
        quick_links << { label: "전화",   href: "tel:#{@member.phone}",        emoji: "☎" } if @member.phone.present?
        quick_links << { label: "이메일", href: "mailto:#{@member.email}",     emoji: "✉" } if @member.email.present?
        quick_links << { label: "카톡",   href: kakao_ch,                      emoji: "💬" } if kakao_ch
      %>
      <% if quick_links.any? %>
        <div style="margin-top: 10px; padding-top: 10px; border-top: 1px dashed var(--impd-rule);">
          <div class="impd-label-muted" style="margin-bottom: 6px; font-size: 12px;">바로 연결</div>
          <div style="display: grid; grid-template-columns: repeat(<%= quick_links.size %>, 1fr); gap: 6px;">
            <% quick_links.each do |q| %>
              <a href="<%= q[:href] %>"
                 style="display: inline-flex; flex-direction: column; align-items: center; gap: 2px; padding: 8px 6px; border: 1px solid var(--impd-rule); background: var(--impd-card); font-size: 12px; color: var(--impd-ink); text-decoration: none; transition: all .15s;"
                 onmouseover="this.style.background='var(--impd-ink)';this.style.color='var(--impd-paper)';"
                 onmouseout="this.style.background='var(--impd-card)';this.style.color='var(--impd-ink)';">
                <span style="font-size: 16px;"><%= q[:emoji] %></span>
                <span style="font-family: var(--impd-font-mono); letter-spacing: 1px;"><%= q[:label] %></span>
              </a>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# 명함 빠른 액션 — QR · 링크 복사 · 상세 보기 (§A-CARD 섹션 대체) %>
      <%
        hero_card_svg_url = "/card/#{@member.slug}.svg"
        hero_qr_svg_url   = "/qr/#{@member.slug}.svg"
        hero_short_link   = ShortLink.resolve_or_create(target_path: "/#{@member.slug}/card", member: @member)
        hero_short_url    = "#{public_base_url}/s/#{hero_short_link&.hash_code}"
      %>
      <div style="margin-top: 10px; padding-top: 10px; border-top: 1px dashed var(--impd-rule);"
           data-controller="card-share"
           data-card-share-short-url-value="<%= hero_short_url %>"
           data-card-share-profile-url-value="<%= public_base_url %>/<%= @member.slug %>">
        <div class="impd-label-muted" style="margin-bottom: 6px; font-size: 12px;">디지털 명함</div>

        <%# QR 실 이미지 — 스캔 가능한 큰 블록 %>
        <a href="<%= hero_qr_svg_url %>" download="<%= @member.slug %>-qr.svg"
           title="QR 저장"
           style="display: block; background: var(--impd-card); border: 1px solid var(--impd-rule); border-radius: 12px; padding: 12px; text-align: center; box-shadow: var(--impd-shadow-card); text-decoration: none;">
          <img src="<%= hero_qr_svg_url %>" alt="<%= @member.name %> QR 코드"
               style="display: block; width: 100%; max-width: 170px; height: auto; aspect-ratio: 1 / 1; margin: 0 auto; background: #fff;">
          <div style="margin-top: 6px; font-family: var(--impd-font-mono); font-size: 12px; letter-spacing: 1.2px; text-transform: uppercase; color: var(--impd-muted);">
            QR · 스캔하여 열기
          </div>
        </a>

        <%# 링크 복사 · 상세 보기 — 2열 pill 버튼 %>
        <div style="margin-top: 6px; display: grid; grid-template-columns: 1fr 1fr; gap: 6px;">
          <button type="button" data-action="click->card-share#copyShort"
                  class="impd-btn impd-btn-secondary impd-btn-sm"
                  style="width: 100%; font-family: var(--impd-font-sans);">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            링크 복사
          </button>
          <%= link_to "/#{@member.slug}/card",
              class: "impd-btn impd-btn-secondary impd-btn-sm",
              style: "width: 100%;" do %>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M6 10h6M6 14h4M16 10h2v4h-2z"/></svg>
            상세 보기
          <% end %>
        </div>

        <div data-card-share-target="flash"
             style="margin-top: 8px; font-size: 12px; color: var(--impd-green-accent); opacity: 0; transition: opacity .2s; text-align: center; font-family: var(--impd-font-mono); letter-spacing: 1px;">
        </div>
      </div>
    </div>
  </div>

  <style>
    @media (max-width: 768px) { .masthead-grid { grid-template-columns: 1fr !important; gap: 32px !important; } }
  </style>
</section>

<!-- ── §A-Card 디지털 명함 ────────────────────────────
     카톡/SNS 공유 시 이 섹션의 SVG 명함이 OG 이미지로 노출되고,
     본인이 "명함 저장" / QR 복사 / 짧은 링크 복사 가능.
     e-name.kr의 '모바일 명함' 개념을 impd 에디토리얼 톤으로 재해석. -->
<%# §A-CARD 섹션은 히어로 우측 3버튼(QR·링크 복사·상세 보기)으로 통합됨.
    디지털 명함 상세 뷰는 /:slug/card 라우트(public_profile#card)에서 계속 제공. %>
<%
  # 갤러리 우선순위:
  #   1) 업로드된 사진·영상 (실제 데이터)
  #   2) 포트폴리오 아이템 중 media_url이 유효한 것
  # 깨진 placeholder를 피하려 실제 사진을 먼저 배치
  gallery_tiles = []

  photo_pool = (@moments || []).to_a
  photo_pool.each do |photo|
    break if gallery_tiles.size >= 8
    next unless photo.image.attached?
    gallery_tiles << {
      kind: :moment,
      title: photo.caption.presence || @member.name + "의 일상",
      category: photo.category.to_s.upcase,
      media_url: photo.video? ? photo.display_url : (photo.thumbnail_url || photo.display_url),
      is_video: photo.video?,
    }
  end

  # 포트폴리오 보강 (8장이 안 채워졌을 때)
  @portfolio.first(8 - gallery_tiles.size).each do |p|
    gallery_tiles << {
      kind: :portfolio,
      title: p.title,
      category: p.category || "WORK",
      media_url: p.media_url,
      is_video: false,
    }
  end
%>
<%# §B 갤러리: §B-2 모먼트와 중복 방지.
    사진이 3장 이상이거나 포트폴리오가 있을 때만 노출.
    1~2장은 §B-2 에디토리얼 그리드에서 충분히 큼직하게 보여줌. %>
<% if gallery_tiles.any? && ((@moments || []).size >= 3 || @portfolio.any?) %>
  <section class="impd-wrap impd-section">
    <div class="impd-section-header">
      <span class="impd-label">§B</span>
      <span class="impd-display" style="font-size: 36px; flex: 1;">갤러리</span>
      <span class="impd-label-muted"><%= gallery_tiles.size %> ITEMS</span>
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px;">
      <% gallery_tiles.each_with_index do |t, i| %>
        <% bg_color = ["#ff5a1f", "#3a2af0", "#2a9d8f", "#e4b230", "#1a1a1a", "#aa2a6a"][i % 6] %>
        <figure style="aspect-ratio: 1 / 1.1; background: <%= bg_color %>; position: relative; overflow: hidden; margin: 0;" class="<%= 'impd-stripe' unless t[:media_url].present? %>">
          <% if t[:media_url].present? %>
            <% if t[:is_video] %>
              <video src="<%= t[:media_url] %>"
                     style="width: 100%; height: 100%; object-fit: cover; display: block; background: #000;"
                     preload="metadata" muted playsinline loop
                     onmouseover="this.play()" onmouseout="this.pause(); this.currentTime=0;"></video>
            <% else %>
              <img src="<%= t[:media_url] %>"
                   alt="<%= t[:title] %>"
                   onerror="this.style.display='none'"
                   style="width: 100%; height: 100%; object-fit: cover; display: block;"
                   loading="lazy">
            <% end %>
            <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 55%);"></div>
          <% end %>
          <figcaption style="position: absolute; bottom: 12px; left: 12px; right: 12px; color: #fff;">
            <p class="impd-label" style="color: rgba(255,255,255,.75);"><%= t[:category] %></p>
            <p style="font-family: var(--impd-font-display); font-size: 18px; margin-top: 4px; text-shadow: 0 1px 3px rgba(0,0,0,0.4);"><%= t[:title] %></p>
          </figcaption>
        </figure>
      <% end %>
    </div>
  </section>
<% end %>

<!-- ── §B-2 Moments (일상 사진·영상) ───────────────────── -->
<% if @moments.present? && @moments.any? %>
  <section class="impd-wrap impd-section" id="moments">
    <div class="impd-section-header">
      <span class="impd-label">§B-2</span>
      <span class="impd-display" style="font-size: 36px; flex: 1;">일상 장면</span>
      <span class="impd-label-muted"><%= @member.member_photos.count %> MOMENTS</span>
    </div>
    <p style="font-family: var(--impd-font-serif); font-size: 17px; color: var(--impd-ink2); line-height: 1.55; max-width: 58ch; margin-bottom: 28px;">
      작업 현장, 수강생의 환한 표정, 손끝의 순간들. 한 장의 사진이 한 줄의 카피보다 많은 것을 전합니다.
    </p>

    <%# 에디토리얼 마소나리.
        사진 1장 = 4/3 풀폭, 2장 = 각 1/1 2열, 3장+ = 마소나리 (첫 크게 + 나머지 정방형) %>
    <% photo_count = (@moments.select { |p| p.image.attached? }.size rescue @moments.size) %>
    <% cols = photo_count == 1 ? "1fr" : (photo_count == 2 ? "1fr 1fr" : "repeat(6, 1fr)") %>
    <div style="display: grid; grid-template-columns: <%= cols %>; gap: 8px;">
      <% @moments.each_with_index do |photo, i| %>
        <% if photo_count == 1
             span = 1; aspect = "16/9"
           elsif photo_count == 2
             span = 1; aspect = "4/3"
           else
             span = (i == 0 ? 3 : (i == 1 || i == 2 ? 2 : 1))
             aspect = (i == 0 ? "4/3" : "1/1")
           end
        %>
        <% next unless photo.image.attached? %>
        <a href="/p/<%= @member.slug %>/<%= photo.id %>"
           title="이 사진 자세히 보기 · 공유"
           style="grid-column: span <%= span %>; display: block; text-decoration: none;">
        <figure style="aspect-ratio: <%= aspect %>; position: relative; overflow: hidden; background: var(--impd-ink); margin: 0; border: 1px solid var(--impd-rule); cursor: pointer;">
          <% if photo.video? %>
            <video src="<%= photo.display_url %>"
                   style="width: 100%; height: 100%; object-fit: cover; display: block; background: #000;"
                   preload="metadata" muted playsinline loop
                   onmouseover="this.play()" onmouseout="this.pause(); this.currentTime=0;"></video>
            <div style="position: absolute; top: 10px; left: 10px; background: rgba(255,255,255,0.9); color: var(--impd-ink); font-family: var(--impd-font-mono); font-size: 12px; letter-spacing: 1.2px; padding: 3px 8px;">▶ VIDEO</div>
          <% else %>
            <img src="<%= photo.thumbnail_url %>"
                 data-fallback="<%= photo.display_url %>"
                 onerror="if(this.dataset.fallback && this.src !== this.dataset.fallback){this.src=this.dataset.fallback;this.dataset.fallback='';}"
                 alt="<%= photo.caption || @member.name %> 일상"
                 style="width: 100%; height: 100%; object-fit: cover; display: block;" loading="lazy">
          <% end %>
          <% if photo.caption.present? %>
            <figcaption style="position: absolute; bottom: 0; left: 0; right: 0; padding: 10px 12px; background: linear-gradient(to top, rgba(15,13,11,0.75), transparent); color: #fff; font-size: 12px; font-family: var(--impd-font-serif);">
              <%= photo.caption %>
            </figcaption>
          <% end %>
          <%# 호버 시 "공유 가능" 시그널 - 클릭 유도 %>
          <div class="photo-hover-hint" style="position: absolute; top: 8px; right: 8px; background: rgba(255,255,255,0.9); color: var(--impd-ink); font-family: var(--impd-font-mono); font-size: 12px; letter-spacing: 1.2px; padding: 4px 8px; opacity: 0; transition: opacity .15s;">
            🔗 공유 →
          </div>
        </figure>
        </a>
      <% end %>
    </div>
    <style>
      a:hover .photo-hover-hint { opacity: 1; }
    </style>
  </section>
<% end %>

<!-- ── §B-3 Townin 파트너 — 지금 일하고 있는 사람 ───── -->
<%#
  설계 의도: 승급일/User ID 같은 정적 메타데이터가 아니라
  "이 사람이 지금 이 순간 진짜 일하고 있다"는 동적 증거를 보여준다.
  다른 회원이 이 페이지를 보고 "나도 이 자리에 있고 싶다"고 느끼게 하는 것이 목표.
  숫자 뽐내기 ❌ / 살아 있는 리듬 ✅
%>
<% if @member.partner_active? %>
  <%
    s = @member.stats
    live = @member.activity_live?
    revenue = @member.revenue_label
    tenure_months = s["tenure_months"].to_i
    tenure_months = ((Time.current - @member.partner_promoted_at) / 1.month).to_i if tenure_months.zero? && @member.partner_promoted_at
    activities = Array(s["recent_activities"]).first(3)
  %>
  <%# §B-3 full-bleed: section 자체를 풀폭 배경으로, 내부 impd-wrap 가 1200px 중앙정렬 %>
  <section id="partner" style="background: var(--impd-card); margin: 28px 0; padding: 40px 0; border-top: 1px solid var(--impd-rule); border-bottom: 1px solid var(--impd-rule);">
    <div class="impd-wrap" style="padding-left: 40px; padding-right: 40px;">
      <!-- 섹션 헤더 -->
      <div class="impd-section-header">
        <span class="impd-label" style="color: var(--impd-accent-2);">§B-3</span>
        <span class="impd-display" style="font-size: 36px; flex: 1; display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap;">
          Townin에서 일하는 중
          <% if live %>
            <span class="impd-live-badge" style="display: inline-flex; align-items: center; gap: 6px; font-family: var(--impd-font-mono); font-size: 12px; letter-spacing: 1.4px; text-transform: uppercase; color: #fff; background: #16a34a; padding: 4px 10px; border-radius: 3px;">
              <span style="width: 7px; height: 7px; background: #fff; border-radius: 50%; display: inline-block; animation: impd-pulse 1.8s ease-in-out infinite;"></span>
              LIVE · 오늘도 활동 중
            </span>
          <% else %>
            <span style="font-family: var(--impd-font-sans); font-weight: 600; font-size: 12px; letter-spacing: -0.1px; color: var(--impd-accent-2); background: rgba(255,90,31,0.1); padding: 4px 10px; border-radius: 3px;">⭐ 검증된 파트너</span>
          <% end %>
        </span>
        <% if tenure_months > 0 %>
          <span class="impd-label-muted"><%= tenure_months %>개월째 활동</span>
        <% elsif @member.partner_promoted_at %>
          <span class="impd-label-muted">SINCE <%= @member.partner_promoted_at.strftime("%Y.%m") %></span>
        <% end %>
      </div>

      <!-- 내러티브 한 줄: 숫자 전에 사람 -->
      <p style="font-family: var(--impd-font-serif); font-size: 19px; color: var(--impd-ink); line-height: 1.55; max-width: 62ch; margin-bottom: 28px;">
        <% if s["customer_count"].to_i > 0 %>
          <strong><%= @member.name %></strong>님은 지금
          <strong style="color: var(--impd-accent);"><%= s["customer_count"] %>명의 고객</strong>을
          Townin에서 돌보고 있습니다.
          <% if s["issues_resolved_week"].to_i > 0 %>
            이번주에만 <strong><%= s["issues_resolved_week"] %>건</strong>의 요청을 해결했습니다.
          <% end %>
        <% else %>
          <strong><%= @member.name %></strong>님은 Townin에서
          <strong>검증된 <%= @member.partner_display_role || "파트너" %></strong>로 활동하고 있습니다.
          <% if @member.partner_promoted_at %>
            <%= @member.partner_promoted_at.strftime("%Y년 %-m월") %>부터 지역 비즈니스를 연결해 왔습니다.
          <% else %>
            지역 비즈니스를 이웃에게 연결하며, 정책·캠페인·광고 기획을 돕고 있습니다.
          <% end %>
        <% end %>
      </p>

      <% if @member.stats_fresh? || s.any? %>
        <!-- KPI 그리드: 수치가 아닌 "리듬"을 보여주는 4장 -->
        <div class="impd-stat-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1px; background: var(--impd-ink); border: 1px solid var(--impd-ink); margin-bottom: 20px;">

          <!-- 매출 카드 -->
          <% if revenue %>
            <div style="background: var(--impd-paper); padding: 28px 24px;">
              <div class="impd-label-muted" style="margin-bottom: 10px; display: flex; align-items: center; gap: 6px;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                이번달 매출
              </div>
              <div class="impd-display" style="font-size: 30px; line-height: 1; color: var(--impd-ink);"><%= revenue %></div>
              <% if s["monthly_revenue_delta_pct"].to_f.abs >= 1 && @member.stats_display_mode != "revenue_hidden" %>
                <% delta = s["monthly_revenue_delta_pct"].to_f %>
                <div style="margin-top: 8px; font-family: var(--impd-font-mono); font-size: 12px; color: <%= delta >= 0 ? '#16a34a' : 'var(--impd-muted)' %>;">
                  <%= delta >= 0 ? '▲' : '▼' %> 전월 대비 <%= delta.abs.round %>%
                </div>
              <% end %>
            </div>
          <% end %>

          <!-- 고객사 카드 -->
          <% if s["customer_count"].to_i > 0 %>
            <div style="background: var(--impd-paper); padding: 28px 24px;">
              <div class="impd-label-muted" style="margin-bottom: 10px; display: flex; align-items: center; gap: 6px;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                돌보는 고객
              </div>
              <div class="impd-display" style="font-size: 30px; line-height: 1; color: var(--impd-ink);"><%= s["customer_count"] %>명</div>
              <% if s["customer_delta"].to_i > 0 %>
                <div style="margin-top: 8px; font-family: var(--impd-font-mono); font-size: 12px; color: #16a34a;">▲ 이번달 +<%= s["customer_delta"] %>명</div>
              <% end %>
            </div>
          <% end %>

          <!-- 이번주 처리 건수 -->
          <% if s["issues_resolved_week"].to_i > 0 %>
            <div style="background: var(--impd-paper); padding: 28px 24px;">
              <div class="impd-label-muted" style="margin-bottom: 10px; display: flex; align-items: center; gap: 6px;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                이번주 처리
              </div>
              <div class="impd-display" style="font-size: 30px; line-height: 1; color: var(--impd-ink);"><%= s["issues_resolved_week"] %>건</div>
              <% if s["active_days_streak"].to_i > 0 %>
                <div style="margin-top: 8px; font-family: var(--impd-font-mono); font-size: 12px; color: var(--impd-ink2);">🔥 <%= s["active_days_streak"] %>일 연속 활동</div>
              <% end %>
            </div>
          <% end %>

          <!-- 평점 카드 -->
          <% if s["rating"].to_f > 0 %>
            <div style="background: var(--impd-paper); padding: 28px 24px;">
              <div class="impd-label-muted" style="margin-bottom: 10px; display: flex; align-items: center; gap: 6px;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                고객 평점
              </div>
              <div class="impd-display" style="font-size: 30px; line-height: 1; color: var(--impd-ink);">
                <%= s["rating"].to_f.round(1) %>
                <span style="color: var(--impd-accent); font-size: 18px;">★</span>
              </div>
              <% if s["review_count"].to_i > 0 %>
                <div style="margin-top: 8px; font-family: var(--impd-font-mono); font-size: 12px; color: var(--impd-ink2);">리뷰 <%= s["review_count"] %>건 기반</div>
              <% end %>
            </div>
          <% end %>
        </div>

        <!-- 최근 활동 타임라인: 진짜 살아있다는 증거 -->
        <% if activities.any? %>
          <div style="background: var(--impd-paper); border: 1px solid var(--impd-ink); padding: 20px 24px;">
            <div class="impd-label-muted" style="margin-bottom: 14px;">최근 활동</div>
            <div>
              <% activities.each_with_index do |act, idx| %>
                <div style="display: grid; grid-template-columns: 90px 1fr; gap: 16px; padding: 10px 0; <%= idx > 0 ? 'border-top: 1px solid var(--impd-rule);' : '' %>">
                  <span class="impd-label-muted">
                    <% begin %>
                      <% t = Time.parse(act["at"].to_s) %>
                      <% delta = Time.current - t %>
                      <% if delta < 1.hour %>방금 전
                      <% elsif delta < 1.day %><%= (delta / 1.hour).to_i %>시간 전
                      <% elsif delta < 7.days %><%= (delta / 1.day).to_i %>일 전
                      <% else %><%= t.strftime("%m.%d") %>
                      <% end %>
                    <% rescue %>
                      최근
                    <% end %>
                  </span>
                  <div>
                    <span style="font-family: var(--impd-font-mono); font-size: 12px; letter-spacing: 1.2px; text-transform: uppercase; color: var(--impd-accent-2); margin-right: 8px;">
                      <%= act["type"].to_s.upcase.presence || "ACTIVITY" %>
                    </span>
                    <span style="font-size: 15px; color: var(--impd-ink);"><%= act["title"] %></span>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <%# 스냅샷 없음: 실수치 대신 "파트너가 하는 일"을 카드 4장으로 소개
            → 빈 박스 대신 지역 비즈니스에서 파트너 역할을 구체화한 풍성한 섹션. %>
        <%
          role_kit = case @member.townin_role.to_s.downcase
          when "merchant"
            [
              { k: "매장 관리",  v: "오늘의 영업·이벤트·쿠폰을 Townin 에서 한 번에 운영" },
              { k: "이웃 연결",  v: "반경 내 이웃에게 자연스러운 광고 노출" },
              { k: "실시간 알림", v: "예약·문의·주문 알림을 앱으로 즉시 수신" },
              { k: "전단·콘텐츠", v: "사진 한 장이면 AI 가 전단·배너까지 생성" },
            ]
          when "fp", "financial_planner"
            [
              { k: "설계 상담",  v: "고객 상황별 맞춤 재무·보장 제안" },
              { k: "구독 리워드", v: "성과 기반 수수료 + 지속 성장 포인트" },
              { k: "네트워크",   v: "지역 자영업자·주민과의 정기 접점" },
              { k: "데이터",     v: "매출·응답·전환 지표 실시간 대시보드" },
            ]
          when "citizen_reporter", "citizen_journalist"
            [
              { k: "동네 취재",  v: "이웃에게 필요한 소식을 현장에서" },
              { k: "콘텐츠 게시", v: "사진·영상·글을 Townin 피드에 직행" },
              { k: "리워드",     v: "좋은 기사는 포인트와 신뢰로 되돌아옴" },
              { k: "공공 이슈",  v: "지역 정책·안전·생활 제안" },
            ]
          else # partner 기본
            [
              { k: "사장님 영입", v: "지역 가게와 파트너 관계를 맺고 온라인화 지원" },
              { k: "광고 제안",   v: "이웃에게 자연스럽게 닿는 제안 설계" },
              { k: "수익 공유",   v: "성과 기반 지속 수수료 + 파트너 리워드" },
              { k: "지역 활성",   v: "캠페인·행사·공공 프로젝트 연결" },
            ]
          end
        %>
        <div style="background: var(--impd-paper); border: 1px solid var(--impd-ink); padding: 24px;">
          <p style="font-family: var(--impd-font-serif); font-size: 15px; color: var(--impd-ink2); line-height: 1.55; margin: 0 0 16px;">
            Townin <strong><%= @member.partner_display_role || "파트너" %></strong>는 이런 일을 합니다.
            <%= @member.name %>님도 같은 방식으로 지역과 연결되어 있습니다.
          </p>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px;">
            <% role_kit.each_with_index do |item, i| %>
              <div style="background: var(--impd-card); border: 1px solid var(--impd-rule); padding: 16px 14px;">
                <div class="impd-label-muted" style="margin-bottom: 6px;">0<%= i + 1 %></div>
                <div class="impd-display" style="font-size: 16px; letter-spacing: -0.2px;"><%= item[:k] %></div>
                <p style="margin-top: 6px; font-size: 12px; color: var(--impd-ink2); line-height: 1.5;"><%= item[:v] %></p>
              </div>
            <% end %>
          </div>
          <p style="margin-top: 12px; font-size: 12px; color: var(--impd-muted); font-family: var(--impd-font-mono); text-align: right;">
            실 매출·고객 수치는 Townin 연동 후 이 자리에 자동 표시됩니다
          </p>
        </div>
      <% end %>

      <!-- 푸터: Townin 공개 프로필 링크 + "나도 파트너 되기" CTA -->
      <div style="margin-top: 20px; display: flex; flex-wrap: wrap; gap: 12px; align-items: center; justify-content: space-between;">
        <div style="display: flex; gap: 16px; align-items: center; flex-wrap: wrap;">
          <% if @member.towningraph_user_id.present? %>
            <a href="https://townin.net/partners/<%= @member.towningraph_user_id %>"
               target="_blank" rel="noopener"
               style="display: inline-flex; align-items: center; gap: 6px; font-family: var(--impd-font-sans); font-size: 12px; letter-spacing: -0.1px; color: var(--impd-accent-2); text-decoration: none; border-bottom: 1px solid currentColor; padding-bottom: 2px;">
              Townin 공개 프로필 보기 →
            </a>
          <% end %>
          <% if @member.stats_synced_at %>
            <span style="font-family: var(--impd-font-mono); font-size: 12px; color: var(--impd-muted);">
              · 마지막 동기화 <%= time_ago_in_words(@member.stats_synced_at) %> 전
            </span>
          <% end %>
        </div>
        <a href="/auth/login"
           style="display: inline-flex; align-items: center; gap: 8px; font-family: var(--impd-font-sans); font-weight: 600; font-size: 13px; letter-spacing: -0.2px; color: var(--impd-ink); background: transparent; border: 1px solid var(--impd-ink); padding: 10px 16px; text-decoration: none; transition: all .15s;"
           onmouseover="this.style.background='var(--impd-ink)'; this.style.color='var(--impd-paper)';"
           onmouseout="this.style.background='transparent'; this.style.color='var(--impd-ink)';">
          나도 imPD 파트너 되기 →
        </a>
      </div>
    </div>
  </section>

  <style>
    @keyframes impd-pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%      { opacity: 0.4; transform: scale(0.6); }
    }
  </style>
<% end %>

<!-- ── §C Services (수업/상품) ───────────────────────── -->
<% if @services.any? %>
  <section class="impd-wrap impd-section" id="classes">
    <div class="impd-section-header">
      <span class="impd-label">§C</span>
      <span class="impd-display" style="font-size: 36px; flex: 1;">서비스 / 수업</span>
      <span class="impd-label-muted"><%= @services.size %> ITEMS</span>
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px;">
      <% @services.first(6).each_with_index do |s, i| %>
        <div style="background: <%= ["#fbf8f1", "#f5f1e7", "#fbf8f1"][i % 3] %>; border: 1px solid var(--impd-rule); padding: 24px; position: relative; min-height: 180px;">
          <span class="impd-label-muted" style="position: absolute; top: 16px; right: 16px;"><%= s.is_active.to_i.positive? ? "신청 가능" : "마감" %></span>
          <h3 class="impd-display" style="font-size: 24px;"><%= s.title %></h3>
          <% if s.description.present? %>
            <p style="margin-top: 12px; font-size: 14px; color: var(--impd-ink2); line-height: 1.5;"><%= truncate(s.description, length: 80) %></p>
          <% end %>
          <p style="margin-top: 16px; font-family: var(--impd-font-mono); font-size: 13px; color: var(--impd-accent);">
            <%= s.price_label.presence || (s.price.present? ? "₩#{s.price}" : "문의") %>
          </p>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

<!-- ── §C-2 FAQ ──────────────────────────────────────── -->
<% if @faqs.any? %>
  <section class="impd-wrap impd-section" id="faq">
    <div class="impd-section-header">
      <span class="impd-label">§C-2</span>
      <h2 class="impd-display" style="font-size: 36px; flex: 1;">자주 묻는 질문</h2>
      <span class="impd-label-muted"><%= @faqs.size %> QUESTIONS</span>
    </div>
    <div style="border-top: 1px solid var(--impd-ink);">
      <% @faqs.each_with_index do |faq, index| %>
        <article style="display: grid; grid-template-columns: minmax(56px, .15fr) minmax(0, 1fr); gap: 24px; padding: 24px 0; border-bottom: 1px solid var(--impd-rule);">
          <span class="impd-label-muted" aria-hidden="true">Q<%= format("%02d", index + 1) %></span>
          <div>
            <h3 class="impd-display" style="font-size: 22px; line-height: 1.45; word-break: keep-all;"><%= faq.question %></h3>
            <p style="margin-top: 10px; color: var(--impd-ink2); font-size: 15px; line-height: 1.8; white-space: pre-line; overflow-wrap: anywhere;"><%= faq.answer %></p>
          </div>
        </article>
      <% end %>
    </div>
  </section>
<% end %>

<!-- ── Testimonial (인용) ───────────────────────── -->
<% if @reviews.any? && @reviews.first.content.present? %>
  <section style="background: var(--impd-ink); color: var(--impd-paper); padding: 80px 0; margin: 64px 0;">
    <div class="impd-wrap" style="text-align: center;">
      <p class="impd-label" style="color: var(--impd-accent);">§Testimonial</p>
      <p class="impd-serif" style="font-size: clamp(28px, 4vw, 40px); line-height: 1.4; margin-top: 24px; max-width: 800px; margin-left: auto; margin-right: auto;">
        "<%= @reviews.first.content %>"
      </p>
      <p class="impd-label-muted" style="color: rgba(239,236,228,.55); margin-top: 24px;">
        — <%= @reviews.first.reviewer_name %> · <%= '★' * @reviews.first.rating %>
      </p>
    </div>
  </section>
<% elsif @member.partner_active? && @member.stats["rating"].to_f > 0 %>
  <%# 대체 신뢰 카드 — 개인 후기 없어도 Townin 평점으로 신뢰 보강 %>
  <% stats = @member.stats %>
  <section style="background: var(--impd-ink); color: var(--impd-paper); padding: 64px 0; margin: 64px 0;">
    <div class="impd-wrap" style="text-align: center;">
      <p class="impd-label" style="color: var(--impd-accent);">§ Trust · Townin 검증</p>
      <p class="impd-serif" style="font-size: clamp(28px, 4vw, 40px); line-height: 1.4; margin-top: 24px; max-width: 800px; margin-left: auto; margin-right: auto;">
        Townin에서 <strong style="color: var(--impd-accent);"><%= stats["rating"].to_f.round(1) %>★</strong> 평점을 유지하는 파트너입니다.
        <% if stats["review_count"].to_i > 0 %>
          <span style="color: rgba(239,236,228,.7); font-size: 0.7em;">(리뷰 <%= stats["review_count"] %>건 기반)</span>
        <% end %>
      </p>
      <p class="impd-label-muted" style="color: rgba(239,236,228,.55); margin-top: 24px;">
        개인 후기는 준비 중 · Townin 공개 프로필에서 전체 리뷰를 확인하세요
      </p>
    </div>
  </section>
<% end %>

<!-- ── §D 활동 연대기 (CV) ───────────────────────── -->
<% if @posts.any? %>
  <section class="impd-wrap impd-section">
    <div class="impd-section-header">
      <span class="impd-label">§D</span>
      <span class="impd-display" style="font-size: 36px; flex: 1;">활동 기록</span>
      <% if @member.activity_live? %>
        <span style="display: inline-flex; align-items: center; gap: 6px; font-family: var(--impd-font-mono); font-size: 12px; letter-spacing: 1.4px; text-transform: uppercase; color: #fff; background: #16a34a; padding: 4px 10px; border-radius: 3px;">
          <span style="width: 7px; height: 7px; background: #fff; border-radius: 50%; display: inline-block; animation: impd-pulse 1.8s ease-in-out infinite;"></span>
          LIVE · 오늘도 활동 중
        </span>
      <% else %>
        <span class="impd-label-muted">CV</span>
      <% end %>
    </div>
    <div>
      <% @posts.each do |p| %>
        <div style="display: grid; grid-template-columns: 120px 1fr; gap: 24px; padding: 20px 0; border-top: 1px solid var(--impd-rule);">
          <span class="impd-label-muted"><%= p.published_at&.strftime("%Y.%m.%d") || p.created_at.strftime("%Y.%m.%d") %></span>
          <div>
            <h4 class="impd-display" style="font-size: 22px;"><%= p.title %></h4>
            <% if p.content.present? %>
              <p style="margin-top: 8px; color: var(--impd-ink2); font-size: 14px;"><%= truncate(p.content.to_s, length: 140) %></p>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

<!-- ── §X "검증된 달란트" — 업로드된 이력·수료증 문서에서 자동 추출된 역량 ─ -->
<%# imPD 핵심 차별점: 회원이 MD/TXT 이력을 올리면 "달란트"가 자동 추출.
    이걸 공개 페이지에 노출해서 "이 사람이 실제로 뭘 잘하는가"를 풍성하게 전달. %>
<% if @skills.present? && @skills.any? %>
  <%
    # category 별 묶기 (hard/soft/tool/domain)
    cat_labels = { "hard" => "전문 기술", "soft" => "협업·태도", "tool" => "사용 도구", "domain" => "전문 분야" }
    by_cat = @skills.group_by { |ms| ms.skill.category.to_s }
    cat_order = %w[hard domain tool soft]
    # source 이모지(한글 fallback 안전성 위해 유니코드 별문자/체크 사용)
    source_tag = {
      "document"  => "문서 추출",
      "admin"     => "운영자 확인",
      "manual"    => "본인 등록",
      "verified"  => "검증 완료",
    }
    # weight top-1 은 "대표 달란트" 강조
    top_skill = @skills.first
  %>
  <section class="impd-wrap impd-section">
    <div class="impd-section-header">
      <span class="impd-label">§X</span>
      <span class="impd-display" style="font-size: 36px; flex: 1;">검증된 달란트</span>
      <span class="impd-label-muted"><%= @skills.size %> TALENTS · <%= @doc_count %> DOCS</span>
    </div>

    <% if @member.bio.present? %>
      <p style="font-family: var(--impd-font-serif); font-size: 17px; color: var(--impd-ink2); line-height: 1.55; max-width: 58ch; margin-bottom: 24px;">
        "<%= truncate(@member.bio.to_s, length: 160) %>"
      </p>
    <% end %>

    <%# 대표 달란트 1개 — C2 house green + gold ceremony %>
    <% if top_skill %>
      <div class="impd-c2-band impd-stripe" style="padding: 44px 32px; margin-bottom: 18px; border-radius: 12px; position: relative; overflow: hidden;">
        <div style="position: relative; max-width: none;">
          <div class="impd-label" style="color: var(--impd-gold);">대표 달란트</div>
          <div class="impd-display" style="font-size: clamp(32px, 5vw, 56px); letter-spacing: -0.03em; line-height: 1.05; margin-top: 10px; color: var(--impd-on-dark);">
            <%= top_skill.skill.canonical_name %>
          </div>
          <div style="margin-top: 14px; display: flex; gap: 14px; flex-wrap: wrap; font-family: var(--impd-font-mono); font-size: 12px; letter-spacing: 1.4px; text-transform: uppercase; color: var(--impd-on-dark-soft);">
            <span>· 가중치 <%= top_skill.weight %>/100</span>
            <span>· <%= cat_labels[top_skill.skill.category.to_s] || top_skill.skill.category %></span>
            <span>· <%= source_tag[top_skill.source] || top_skill.source %></span>
            <% if top_skill.level.present? %><span>· <%= top_skill.level.upcase %></span><% end %>
          </div>
        </div>
      </div>
    <% end %>

    <%# 카테고리별 달란트 그룹 — C2 Reward-tier credential cards %>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px;">
      <%
        tier_map = { 0 => "", 1 => "tier-green", 2 => "tier-house", 3 => "tier-uplift" }
      %>
      <% cat_order.each_with_index do |cat, ci| %>
        <% items = by_cat[cat] %>
        <% next unless items&.any? %>
        <div class="impd-credential-card <%= tier_map[ci % 4] %>">
          <div class="impd-label-muted" style="margin-bottom: 12px;">
            <%= cat_labels[cat] || cat %>
            <span style="opacity: 0.55;">· <%= items.size %></span>
          </div>
          <div style="display: flex; flex-wrap: wrap; gap: 6px;">
            <% items.first(8).each do |ms| %>
              <%
                w = ms.weight.to_i
                chip_bg = w >= 60 ? "var(--impd-green-accent)" : "var(--impd-green-mint)"
                chip_fg = w >= 60 ? "var(--impd-on-dark)" : "var(--impd-green)"
              %>
              <span style="display: inline-flex; align-items: center; gap: 4px; padding: 6px 12px; background: <%= chip_bg %>; color: <%= chip_fg %>; border-radius: 50px; font-size: 12px; font-family: var(--impd-font-sans); font-weight: 500; letter-spacing: -0.01em;">
                <%= ms.skill.canonical_name %>
                <% if w >= 60 %>
                  <span style="font-family: var(--impd-font-mono); font-size: 12px; opacity: 0.85; letter-spacing: 1px;">· <%= w %></span>
                <% end %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <p style="margin-top: 14px; font-size: 12px; color: var(--impd-muted); font-family: var(--impd-font-mono); text-align: right;">
      위 달란트는 업로드된 이력·수료증 <%= @doc_count %>개에서 자동 추출 · 가중치는 빈도·맥락 분석 결과
    </p>
  </section>
<% end %>

<!-- ── §Y "제공 가능한 가치" — 포트폴리오 없어도 자동 생성되는 가치 카드 4종 ─ -->
<%
  # profession 기반 표준 가치 제안 (포트폴리오·서비스 없어도 이 회원이 "뭐 하는 사람"인지 즉시 전달)
  base_kit = ProfessionPreset.value_cards(@member.profession).map { |card| { head: card["head"], desc: card["desc"] } }.presence ||
             ProfessionPreset.value_cards("custom").map { |card| { head: card["head"], desc: card["desc"] } }

  # 개인화: 회원 고유 데이터 우선, 부족분을 직종 fallback 로 채움.
  personal = []
  # 1) bio 첫 문장을 첫 카드로 (35자 이상일 때만)
  if @member.bio.to_s.length > 35
    first_sent = @member.bio.to_s.split(/[.。!?]/).first&.strip
    personal << { head: "나의 방식", desc: first_sent[0, 90] } if first_sent&.length.to_i > 15
  end
  # 2) 포트폴리오 제목들 (최대 2개)
  @portfolio.first(2).each do |p|
    personal << { head: p.title.to_s[0, 30], desc: (p.category.presence || "PORTFOLIO").to_s.upcase }
  end
  # 3) 서비스 제목들 (최대 2개)
  @services.first(2).each do |s|
    personal << { head: s.title.to_s[0, 30], desc: (s.price_label.presence || s.description.to_s[0, 60] || "문의") }
  end
  # 4) 달란트 상위 2개 (skills, 아래 §Skills 섹션에서 풀 노출되므로 여기는 2개만)
  @member.member_skills.includes(:skill).order(weight: :desc).limit(2).each do |ms|
    name = ms.skill&.canonical_name.to_s
    personal << { head: name[0, 20], desc: "검증된 역량 · #{ms.source}" } if name.present?
  end rescue nil

  # 본인 페이지 소유자에게는 편집 독려를 위해 fallback을 보여주되, 외부 방문자에게는
  # 개인 데이터가 없으면 섹션 전체를 숨겨 공용 템플릿으로 인한 AI 주장 모순을 제거한다.
  viewing_as_owner = (defined?(current_member) && current_member&.id == @member.id)
  kit_personalized = personal.any?
  kit = if kit_personalized
          personal.first(4)
        elsif viewing_as_owner
          base_kit.first(4)
        else
          []
        end
%>
<% if kit.any? %>
<section class="impd-wrap impd-section">
  <div class="impd-section-header">
    <span class="impd-label">§Y</span>
    <span class="impd-display" style="font-size: 36px; flex: 1;">이렇게 도와드립니다.</span>
    <span class="impd-label-muted"><%= kit.size %> SERVICES</span>
  </div>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px;">
    <% kit.each_with_index do |item, i| %>
      <div style="background: <%= ["var(--impd-card)", "var(--impd-paper)"][i % 2] %>; border: 1px solid var(--impd-rule); padding: 24px 20px; min-height: 140px;">
        <div class="impd-label-muted" style="margin-bottom: 10px;">0<%= i + 1 %></div>
        <div class="impd-display" style="font-size: 20px; letter-spacing: -0.3px;"><%= item[:head] %></div>
        <p style="margin-top: 8px; font-size: 13px; color: var(--impd-ink2); line-height: 1.5;"><%= item[:desc] %></p>
      </div>
    <% end %>
  </div>
  <p style="margin-top: 14px; font-size: 12px; color: var(--impd-muted); font-family: var(--impd-font-mono); text-align: right;">
    <% if kit_personalized %>
      <%= @member.name %>님의 기록에서 자동 구성 · 상세는 문의 후 상담
    <% else %>
      임시 예시입니다. 회원 편집에서 나만의 서비스를 추가하면 이 섹션이 채워집니다.
    <% end %>
  </p>
</section>
<% end %>

<!-- ── §Z imPD 검증 배지 블록 — 페이지 마무리 + 플랫폼 신뢰 전달 ─ -->
<%
  joined_months = @member.created_at ? ((Time.current - @member.created_at) / 1.month).to_i : 0
  week_visits = AnalyticsEvent.for_tenant.where(
    event_name: "page_view",
    page_path: "/#{@member.slug}",
    user_type: "anonymous"
  ).where(created_at: 1.week.ago..Time.current).count rescue 0
%>
<section class="impd-wrap" style="padding: 40px 0 24px;">
  <div style="background: var(--impd-paper); border-top: 1px solid var(--impd-ink); border-bottom: 1px solid var(--impd-ink); padding: 28px 24px; display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 20px; align-items: center;">
    <div>
      <div class="impd-label-muted">상태</div>
      <div class="impd-display" style="font-size: 22px; margin-top: 4px;">
        <span style="display: inline-flex; align-items: center; gap: 6px;">
          <span style="width: 7px; height: 7px; background: #16a34a; border-radius: 50%; display: inline-block;"></span>
          imPD 검증 회원
        </span>
      </div>
    </div>
    <div>
      <div class="impd-label-muted">활동 기간</div>
      <div class="impd-display" style="font-size: 22px; margin-top: 4px;">
        <%= joined_months > 0 ? "#{joined_months}개월째" : "신규" %>
      </div>
    </div>
    <div>
      <div class="impd-label-muted">이번주 방문</div>
      <div class="impd-display" style="font-size: 22px; margin-top: 4px;"><%= week_visits %>회</div>
    </div>
    <% if @member.partner_active? %>
      <div>
        <div class="impd-label-muted">Townin</div>
        <div class="impd-display" style="font-size: 22px; margin-top: 4px; color: var(--impd-accent-2);">⭐ 검증 파트너</div>
      </div>
    <% end %>
  </div>
</section>

<!-- ── Contact CTA — 3열 그리드, 빈 공간 최소화 ──────── -->
<section class="impd-wrap impd-section" id="contact">
  <%
    social_e = @member.social
    kakao_ch_e = social_e["kakao_channel"].presence
    contact_options = []
    contact_options << { label: "이메일", value: @member.email,              href: "mailto:#{@member.email}" }       if @member.email.present?
    contact_options << { label: "전화",   value: @member.phone,              href: "tel:#{@member.phone}" }          if @member.phone.present?
    contact_options << { label: "카톡 채널", value: "카톡 1:1 문의",          href: kakao_ch_e }                       if kakao_ch_e
  %>
  <div style="background: var(--impd-card); border: 1px solid var(--impd-ink); padding: 36px 32px;">
    <div style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 28px; align-items: center;">
      <div>
        <p class="impd-label">§E · 함께 일하실 분</p>
        <h2 class="impd-display" style="font-size: clamp(28px, 3.8vw, 48px); margin-top: 12px; line-height: 1.1;">
          <%= @member.name %>님께<br>
          <span style="color: var(--impd-accent); font-style: italic;">직접 문의</span>하세요.
        </h2>
        <p style="margin-top: 14px; font-size: 13px; color: var(--impd-ink2); line-height: 1.55; max-width: 32ch;">
          어떤 채널로 연락하셔도 됩니다. 보통 24시간 안에 답장드립니다.
        </p>
      </div>

      <div style="display: flex; flex-direction: column; gap: 8px;">
        <% if @bookings.any? %>
          <div style="margin-bottom: 10px; padding-bottom: 18px; border-bottom: 1px solid var(--impd-rule);">
            <p class="impd-label-muted" style="margin-bottom: 8px;">예약하기</p>
            <div style="display: flex; flex-direction: column; gap: 8px;">
              <% @bookings.each do |booking| %>
                <%= link_to booking.external_url,
                      target: "_blank",
                      rel: "noopener",
                      class: "impd-btn impd-btn-primary",
                      style: "width: 100%; justify-content: space-between; height: 46px; padding: 0 18px; font-size: 14px;" do %>
                  <span style="font-family: var(--impd-font-mono); font-size: 12px; letter-spacing: 1.3px; opacity: 0.65;">예약</span>
                  <span style="font-weight: 600;"><%= booking.booking_type.presence || "예약하기" %> →</span>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>

        <% if contact_options.any? %>
          <% contact_options.each_with_index do |o, i| %>
            <a href="<%= o[:href] %>"
               class="impd-btn <%= i == 0 ? 'impd-btn-primary' : 'impd-btn-secondary' %>"
               style="width: 100%; justify-content: space-between; height: 46px; padding: 0 18px; font-size: 14px;">
              <span style="font-family: var(--impd-font-mono); font-size: 12px; letter-spacing: 1.3px; opacity: 0.65;"><%= o[:label] %></span>
              <span style="font-weight: 600;"><%= o[:value] %> →</span>
            </a>
          <% end %>
        <% else %>
          <p style="font-size: 12px; color: var(--impd-muted);">연락처 준비 중</p>
        <% end %>
      </div>
    </div>

    <div style="border-top: 1px solid var(--impd-rule); margin-top: 28px; padding-top: 28px;">
      <div class="impd-section-header" style="margin-bottom: 20px;">
        <span class="impd-label">문의 보내기</span>
        <span class="impd-label-muted">CONTACT FORM</span>
      </div>
      <%= form_with model: MemberInquiry.new, url: member_inquiries_path(slug: @member.slug), method: :post, class: "contact-inquiry-form" do |form| %>
        <div class="contact-inquiry-fields" style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
          <div>
            <%= form.label :sender_name, "이름", style: "display: block; margin-bottom: 6px; color: var(--impd-muted); font-size: 13px; font-weight: 600;" %>
            <%= form.text_field :sender_name, required: true, autocomplete: "name", style: "width: 100%; border: 1px solid #d1d5db; background: #fff; padding: 10px 12px; color: var(--impd-ink); font-family: var(--impd-font-sans); font-size: 14px;" %>
          </div>
          <div>
            <%= form.label :sender_email, "이메일", style: "display: block; margin-bottom: 6px; color: var(--impd-muted); font-size: 13px; font-weight: 600;" %>
            <%= form.email_field :sender_email, required: true, autocomplete: "email", style: "width: 100%; border: 1px solid #d1d5db; background: #fff; padding: 10px 12px; color: var(--impd-ink); font-family: var(--impd-font-sans); font-size: 14px;" %>
          </div>
        </div>
        <div style="margin-top: 16px;">
          <%= form.label :message, "문의내용", style: "display: block; margin-bottom: 6px; color: var(--impd-muted); font-size: 13px; font-weight: 600;" %>
          <%= form.text_area :message, required: true, minlength: 5, maxlength: 2000, rows: 6, style: "width: 100%; border: 1px solid #d1d5db; background: #fff; padding: 10px 12px; color: var(--impd-ink); font-family: var(--impd-font-sans); font-size: 14px; line-height: 1.65; resize: vertical;" %>
        </div>
        <%= hidden_field_tag :website, "", autocomplete: "off", tabindex: -1 %>
        <%= form.submit "문의 전송", class: "impd-btn impd-btn-primary", style: "margin-top: 16px; min-width: 140px; justify-content: center;" %>
      <% end %>
    </div>
  </div>

  <style>
    @media (max-width: 768px) {
      section#contact > div > div { grid-template-columns: 1fr !important; }
      .contact-inquiry-fields { grid-template-columns: 1fr !important; }
    }
  </style>
</section>

<!-- Footer -->
<footer style="border-top: 1px solid var(--impd-rule); padding: 32px 40px; display: flex; gap: 32px; flex-wrap: wrap; align-items: center; font-family: var(--impd-font-mono); font-size: 12px; letter-spacing: 1.2px; text-transform: uppercase; color: var(--impd-muted);">
  <span class="impd-display" style="font-size: 16px; text-transform: none; color: var(--impd-ink);">imPD<span style="color: var(--impd-accent);">.</span></span>
