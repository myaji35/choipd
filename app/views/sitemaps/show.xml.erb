<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
<% @static_paths.each do |path| %>
  <url>
    <loc><%= "#{@base}#{path}" %></loc>
  </url>
<% end %>
<% @members.each do |member| %>
  <url>
    <loc><%= "#{@base}/#{member.slug}" %></loc>
    <lastmod><%= member.updated_at.iso8601 %></lastmod>
  </url>
<% end %>
</urlset>
