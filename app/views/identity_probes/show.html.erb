<% content_for :title, "공개 페이지 준비 중" %>
<% content_for :description, "imPD가 당신을 대신 찾아드리는 중입니다. 잠시만 기다려주세요." %>

<style>
  .probe-shell {
    min-height: calc(100vh - 68px);
    background: var(--impd-paper);
    padding: 32px 20px 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .probe-hud {
    width: 100%;
    max-width: 640px;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .probe-hud-label {
    font-family: var(--impd-font-mono);
    font-size: 11px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--impd-accent);
    white-space: nowrap;
  }
  .probe-hud-progress {
    flex: 1;
    height: 4px;
    background: rgba(15,13,11,0.08);
    border-radius: 2px;
    overflow: hidden;
    position: relative;
  }
  .probe-hud-progress::after {
    content: "";
    position: absolute; left: 0; top: 0; bottom: 0;
    width: <%= @progress_pct %>%;
    background: var(--impd-accent);
    transition: width 400ms ease;
  }
  .probe-hud-skip {
    font-family: var(--impd-font-mono);
    font-size: 11px;
    color: var(--impd-soft-muted);
    text-decoration: underline;
    white-space: nowrap;
  }
  .probe-hud-skip:hover { color: var(--impd-muted); }

  .probe-card {
    width: 100%;
    max-width: 640px;
    background: var(--impd-card);
    border: 1px solid var(--impd-rule);
    border-radius: 8px;
    padding: 40px 32px;
  }

  .probe-eyebrow {
    font-family: var(--impd-font-mono);
    font-size: 11px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--impd-accent);
    margin-bottom: 12px;
  }
  .probe-title {
    font-family: var(--impd-font-display);
    font-weight: 800;
    font-size: 28px;
    line-height: 1.2;
    letter-spacing: -0.8px;
    color: var(--impd-ink);
    margin-bottom: 10px;
  }
  .probe-subtitle {
    font-size: 14px;
    color: var(--impd-muted);
    line-height: 1.55;
    margin-bottom: 28px;
  }

  .probe-nav {
    width: 100%;
    max-width: 640px;
    margin-top: 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .probe-nav-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 20px;
    font-size: 14px;
    font-weight: 600;
    border-radius: 6px;
    cursor: pointer;
    border: 1px solid var(--impd-ink);
    background: transparent;
    color: var(--impd-ink);
    transition: all 150ms ease;
    text-decoration: none;
  }
  .probe-nav-btn:hover:not(:disabled) { background: var(--impd-ink); color: var(--impd-paper); }
  .probe-nav-btn[disabled], .probe-nav-btn.is-disabled {
    opacity: 0.35;
    cursor: not-allowed;
    pointer-events: none;
  }
  .probe-nav-btn.is-primary {
    background: var(--impd-ink);
    color: var(--impd-paper);
  }
  .probe-nav-btn.is-primary:hover:not(:disabled) { background: var(--impd-accent); border-color: var(--impd-accent); }
  .probe-nav-btn.is-celebrate {
    background: var(--impd-accent);
    color: #fff;
    border-color: var(--impd-accent);
    min-height: 56px;
    padding: 0 28px;
    font-size: 15px;
  }
  .probe-nav-btn.is-celebrate:hover:not(:disabled) { filter: brightness(1.08); }

  .probe-skip-mid { font-size: 12px; color: var(--impd-muted); text-decoration: underline; cursor: pointer; }

  /* 카드/칩 공용 */
  .probe-candidate {
    display: flex;
    gap: 16px;
    padding: 16px;
    border: 1px solid var(--impd-rule);
    border-radius: 6px;
    background: #fff;
    cursor: pointer;
    transition: all 150ms ease;
    align-items: center;
    min-height: 72px;
  }
  .probe-candidate:hover { border-color: rgba(15,13,11,0.4); }
  .probe-candidate.is-selected {
    border: 2px solid #10B981;
    padding: 15px;
    box-shadow: 0 0 0 4px rgba(16,185,129,0.1);
  }
  .probe-candidate-avatar {
    width: 48px; height: 48px;
    border-radius: 50%;
    background: var(--impd-accent);
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 18px;
    flex-shrink: 0;
  }
  .probe-candidate-body { flex: 1; min-width: 0; }
  .probe-candidate-name { font-weight: 700; font-size: 15px; color: var(--impd-ink); margin-bottom: 2px; }
  .probe-candidate-meta { font-size: 12px; color: var(--impd-muted); line-height: 1.4; }
  .probe-candidate-confidence {
    font-family: var(--impd-font-mono);
    font-size: 11px;
    color: var(--impd-ink);
    background: rgba(58,42,240,0.1);
    padding: 4px 8px;
    border-radius: 4px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .probe-chip {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    min-width: 44px;
    padding: 0 16px;
    border: 1px solid var(--impd-rule);
    border-radius: 22px;
    background: #fff;
    color: var(--impd-ink);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 120ms ease;
    user-select: none;
  }
  .probe-chip:hover { border-color: rgba(15,13,11,0.4); }
  .probe-chip.is-selected {
    background: var(--impd-ink);
    color: var(--impd-paper);
    border-color: var(--impd-ink);
  }

  .probe-chip-group { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }

  .probe-quote {
    font-family: var(--impd-font-serif);
    font-style: italic;
    font-size: 11px;
    color: var(--impd-muted);
    margin-top: 4px;
    padding-left: 10px;
    border-left: 2px solid var(--impd-rule);
    line-height: 1.4;
  }

  .probe-text-input, .probe-text-area {
    width: 100%;
    min-height: 44px;
    padding: 10px 14px;
    border: 1px solid var(--impd-rule);
    border-radius: 6px;
    background: #fff;
    font-size: 14px;
    color: var(--impd-ink);
    font-family: inherit;
  }
  .probe-text-area { min-height: 96px; resize: vertical; line-height: 1.5; }
  .probe-text-input:focus, .probe-text-area:focus {
    outline: 2px solid rgba(0,161,224,0.5);
    border-color: var(--impd-accent);
  }

  .probe-check-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border: 1px solid var(--impd-rule);
    border-radius: 6px;
    background: #fff;
    cursor: pointer;
    margin-bottom: 10px;
    min-height: 56px;
    transition: border-color 120ms ease;
  }
  .probe-check-row:hover { border-color: rgba(15,13,11,0.4); }
  .probe-check-row.is-low-trust { background: rgba(15,13,11,0.04); }
  .probe-check-box {
    width: 22px; height: 22px;
    border-radius: 4px;
    border: 2px solid var(--impd-rule);
    background: #fff;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: all 120ms ease;
  }
  .probe-check-row.is-checked .probe-check-box {
    background: var(--impd-accent);
    border-color: var(--impd-accent);
  }
  .probe-check-row.is-checked .probe-check-box svg { opacity: 1; }
  .probe-check-box svg { opacity: 0; color: #fff; }
  .probe-check-body { flex: 1; min-width: 0; }
  .probe-check-title { font-size: 14px; color: var(--impd-ink); font-weight: 500; }
  .probe-check-url { font-size: 12px; color: var(--impd-muted); margin-top: 2px; word-break: break-all; }

  .probe-avatar-card {
    border: 1px solid var(--impd-rule);
    border-radius: 8px;
    background: #fff;
    padding: 16px;
    cursor: pointer;
    text-align: center;
    transition: all 150ms ease;
    min-height: 120px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .probe-avatar-card:hover { border-color: rgba(15,13,11,0.4); }
  .probe-avatar-card.is-selected {
    border: 2px solid #10B981;
    padding: 15px;
    box-shadow: 0 0 0 4px rgba(16,185,129,0.08);
  }
  .probe-avatar-preview {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: var(--impd-accent);
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 22px;
    margin-bottom: 10px;
  }
  .probe-avatar-label {
    font-size: 12px;
    color: var(--impd-muted);
    font-weight: 500;
  }

  /* 모바일 */
  @media (max-width: 640px) {
    .probe-shell { padding: 20px 12px 80px; }
    .probe-card { padding: 28px 20px; border-radius: 6px; }
    .probe-title { font-size: 22px; }
    .probe-nav-btn { min-height: 56px; padding: 0 18px; font-size: 15px; }
    .probe-nav-btn.is-celebrate { min-height: 60px; font-size: 16px; }
    .probe-candidate { padding: 12px; }
  }

  /* 로딩 점 애니메이션 */
  @keyframes probeDot { 0%, 20% { opacity: 0.2; transform: scale(1); } 50% { opacity: 1; transform: scale(1.2); } 80%, 100% { opacity: 0.2; transform: scale(1); } }
  .probe-loading-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--impd-accent); margin: 0 3px; animation: probeDot 1.4s infinite; }
  .probe-loading-dot:nth-child(2) { animation-delay: 0.2s; }
  .probe-loading-dot:nth-child(3) { animation-delay: 0.4s; }

  .probe-error-banner {
    background: rgba(255,90,31,0.08);
    border: 1px solid var(--impd-accent-2);
    color: var(--impd-accent-2);
    padding: 10px 14px;
    border-radius: 6px;
    font-size: 13px;
    margin-bottom: 16px;
  }
</style>

<div class="probe-shell"
     data-controller="probe-wizard"
     data-probe-wizard-current-step-value="<%= @current_step %>"
     data-probe-wizard-total-steps-value="<%= @total_steps %>"
     data-probe-wizard-poll-url-value="<%= probe_wizard_status_path %>"
     data-probe-wizard-rewrite-bio-url-value="<%= probe_wizard_rewrite_bio_path %>"
     data-probe-wizard-slug-value="<%= current_member.slug %>">

  <!-- HUD -->
  <div class="probe-hud">
    <% if @current_step == 0 %>
      <span class="probe-hud-label">§ PROBE · 준비 중</span>
    <% else %>
      <span class="probe-hud-label">§ PROBE · <%= sprintf("%02d", @current_step) %> / <%= sprintf("%02d", @total_steps) %></span>
    <% end %>
    <div class="probe-hud-progress"></div>
    <%= button_to "건너뛰기", probe_wizard_skip_path,
          method: :post,
          form: { data: { turbo_confirm: "프로필 자동 채우기를 건너뛰고 바로 내 페이지로 이동할까요?" }, style: "display:inline; margin:0;" },
          class: "probe-hud-skip",
          style: "background: transparent; border: none; cursor: pointer;" %>
  </div>

  <% if params[:error].present? %>
    <div style="width: 100%; max-width: 640px;">
      <div class="probe-error-banner">
        필수 동의 항목 2개를 체크해주세요.
      </div>
    </div>
  <% end %>

  <!-- 본체 카드 -->
  <%= turbo_frame_tag "probe_step_frame" do %>
    <div class="probe-card" data-probe-wizard-target="card">
      <% case @current_step %>
      <% when 0 %>
        <%= render "identity_probes/steps/s0_loading", probe: @probe %>
      <% when 1 %>
        <%= render "identity_probes/steps/s1_person_match", identity: @identity %>
      <% when 2 %>
        <%= render "identity_probes/steps/s2_profession_region", identity: @identity %>
      <% when 3 %>
        <%= render "identity_probes/steps/s3_sns_links", identity: @identity %>
      <% when 4 %>
        <%= render "identity_probes/steps/s4_bio_draft", identity: @identity %>
      <% when 5 %>
        <%= render "identity_probes/steps/s5_avatar", identity: @identity, member: current_member %>
      <% when 6 %>
        <%= render "identity_probes/steps/s6_final", identity: @identity, member: current_member %>
      <% end %>
    </div>
  <% end %>

  <!-- 네비게이션 (S0/S6 제외) -->
  <% if @current_step >= 1 && @current_step <= 5 %>
    <%= render "identity_probes/nav", current_step: @current_step, total: @total_steps %>
  <% end %>
</div>
