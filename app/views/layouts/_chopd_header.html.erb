<header id="nav" data-controller="mobile-menu" style="position:fixed;top:0;left:0;right:0;z-index:1000;display:flex;align-items:center;justify-content:space-between;padding:22px 48px;transition:all .3s;">
  <style>
    #nav.scrolled {
      background: rgba(10,14,26,0.9);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      padding-top: 14px;
      padding-bottom: 14px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .nav-logo { font-family: 'Black Han Sans', sans-serif; font-size: 24px; color: #f5f4f0; text-decoration: none; }
    .nav-logo .accent { color: #ff4d1c; }
    .nav-link { font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.55); text-decoration: none; transition: color .2s; position: relative; }
    .nav-link:hover { color: #fff; }
    .nav-link::after { content:''; position:absolute; bottom:-4px; left:0; right:0; height:1px; background:#ff4d1c; transform:scaleX(0); transition:transform .25s; }
    .nav-link:hover::after { transform:scaleX(1); }
    .nav-cta {
      background: #ff4d1c; color: #fff; padding: 9px 22px;
      border-radius: 999px; font-size: 13px; font-weight: 700;
      text-decoration: none; transition: all .2s;
      display: inline-flex; align-items: center; gap: 6px;
    }
    .nav-cta:hover { background: #ff7850; transform: translateY(-1px); }
    @media (max-width: 768px) {
      #nav { padding: 16px 20px; }
      .nav-links-desktop, .nav-cta-wrap { display: none !important; }
      .nav-mobile-btn { display: flex !important; }
    }
    @media (min-width: 769px) { .nav-mobile-btn { display: none; } }
    /* 회원 세션 영역 — 로그인/가입/내페이지/로그아웃 */
    .nav-session { display: inline-flex; align-items: center; gap: 10px; }
    .nav-session-name { font-family: 'Noto Sans KR', sans-serif; font-size: 11px; letter-spacing: .6px; text-transform: uppercase; color: rgba(255,255,255,0.55); white-space: nowrap; }
    .nav-session-link {
      font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.85);
      text-decoration: none; padding: 7px 12px; border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.2); background: rgba(255,255,255,0.04);
      transition: all .2s; white-space: nowrap;
    }
    .nav-session-link:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.4); color: #fff; }
    .nav-session-form { display: inline-flex; margin: 0; padding: 0; }
    .nav-session-btn {
      font: inherit; cursor: pointer;
      font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.85);
      padding: 7px 12px; border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.2); background: rgba(255,255,255,0.04);
      transition: all .2s; white-space: nowrap;
    }
    .nav-session-btn:hover { background: #ff4d1c; border-color: #ff4d1c; color: #fff; }
    .nav-signup { font-size: 12px; font-weight: 500; color: rgba(255,255,255,0.55); text-decoration: none; transition: color .2s; white-space: nowrap; }
    .nav-signup:hover { color: #fff; }
    .mobile-menu {
      display: none; position: fixed; inset: 0; top: 60px;
      background: rgba(10,14,26,0.97); backdrop-filter: blur(20px);
      z-index: 999; flex-direction: column; gap: 8px; padding: 32px 24px;
    }
    .mobile-menu.open { display: flex; }
    .mobile-nav-link { font-size: 18px; font-weight: 500; color: rgba(255,255,255,.7); text-decoration: none; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,.06); }
    .mobile-nav-link:hover { color: #fff; }
  </style>

  <!-- 로고 -->
  <%= link_to root_path, class: "nav-logo" do %>
    imPD<span class="accent">.</span>
  <% end %>

  <!-- 데스크탑 네비 -->
  <nav class="nav-links-desktop" style="display:flex;gap:36px;">
    <%= link_to "소개", "#identity", class: "nav-link" %>
    <%= link_to "교육", education_path, class: "nav-link" %>
    <%= link_to "미디어", media_path, class: "nav-link" %>
    <%= link_to "작품", works_path, class: "nav-link" %>
    <%= link_to "커뮤니티", community_path, class: "nav-link" %>
  </nav>

  <!-- CTA + 회원 세션 -->
  <div class="nav-cta-wrap" style="display: inline-flex; align-items: center; gap: 14px;">
    <% if member_signed_in? %>
      <div class="nav-session">
        <span class="nav-session-name"><%= truncate(current_member.name.to_s, length: 12) %></span>
        <%= link_to "내 페이지", "/#{current_member.slug}", class: "nav-session-link" %>
        <%= button_to member_logout_path,
              method: :delete,
              form: { class: "nav-session-form", data: { turbo_confirm: "로그아웃하시겠습니까?" } },
              class: "nav-session-btn" do %>
          로그아웃
        <% end %>
      </div>
    <% else %>
      <div class="nav-session">
        <%= link_to "회원가입", member_signup_path, class: "nav-signup" %>
        <%= link_to "로그인", member_login_path, class: "nav-session-link" %>
      </div>
    <% end %>
    <%= link_to new_inquiry_path, class: "nav-cta" do %>
      <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
      강좌 문의
    <% end %>
  </div>

  <!-- 모바일 햄버거 -->
  <button class="nav-mobile-btn" data-action="click->mobile-menu#toggle" aria-label="메뉴"
    style="background:none;border:none;cursor:pointer;padding:6px;display:none;">
    <svg width="22" height="22" viewBox="0 0 24 24" stroke="#f5f4f0" fill="none" stroke-width="2" stroke-linecap="round">
      <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
  </button>
</header>

<!-- 모바일 메뉴 -->
<div id="mobile-nav" class="mobile-menu" data-mobile-menu-target="menu">
  <%= link_to "소개", "#identity", class: "mobile-nav-link" %>
  <%= link_to "교육", education_path, class: "mobile-nav-link" %>
  <%= link_to "미디어", media_path, class: "mobile-nav-link" %>
  <%= link_to "작품", works_path, class: "mobile-nav-link" %>
  <%= link_to "커뮤니티", community_path, class: "mobile-nav-link" %>
  <% if member_signed_in? %>
    <div class="mobile-nav-link" style="color: rgba(255,255,255,.5); font-size: 12px; letter-spacing: 1px; text-transform: uppercase;">
      <%= truncate(current_member.name.to_s, length: 20) %>
    </div>
    <%= link_to "내 페이지", "/#{current_member.slug}", class: "mobile-nav-link" %>
    <%= button_to member_logout_path,
          method: :delete,
          form: { data: { turbo_confirm: "로그아웃하시겠습니까?" }, style: "display: block; margin: 0;" },
          class: "mobile-nav-link",
          style: "width: 100%; text-align: left; background: none; border: none; border-bottom: 1px solid rgba(255,255,255,.06); cursor: pointer; font-family: inherit;" do %>
      로그아웃 →
    <% end %>
  <% else %>
    <%= link_to "회원가입", member_signup_path, class: "mobile-nav-link" %>
    <%= link_to "로그인", member_login_path, class: "mobile-nav-link" %>
  <% end %>
  <%= link_to "강좌 문의", new_inquiry_path, class: "nav-cta", style: "margin-top:16px;justify-content:center;" %>
</div>

<script>
  // 스크롤 시 nav 배경
  window.addEventListener('scroll', () => {
    const nav = document.getElementById('nav');
    if (!nav) return;
    nav.classList.toggle('scrolled', window.scrollY > 40);
  });
  // 모바일 메뉴 토글
  document.querySelector('[data-action="click->mobile-menu#toggle"]')?.addEventListener('click', () => {
    document.getElementById('mobile-nav')?.classList.toggle('open');
  });
</script>
