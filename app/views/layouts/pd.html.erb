<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= content_for?(:title) ? yield(:title) + " | PD 대시보드" : "imPD Dashboard" %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: '#00A1E0',
              'primary-dark': '#0078A8',
              navy: '#16325C',
              surface: '#F3F2F2',
            }
          }
        }
      }
    </script>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-surface min-h-screen flex">
    <!-- 사이드바 -->
    <aside class="w-60 bg-white border-r text-gray-700 flex-shrink-0 fixed top-0 left-0 h-full overflow-y-auto z-40 shadow-sm">
      <div class="p-4 border-b">
        <a href="<%= pd_root_path %>" class="flex items-center space-x-2">
          <div class="w-8 h-8 bg-primary rounded-full flex items-center justify-center">
            <span class="text-white font-bold text-xs">최</span>
          </div>
          <span class="font-bold text-navy text-sm">PD 대시보드</span>
        </a>
      </div>

      <nav class="p-3 space-y-1">
        <%= link_to pd_root_path, class: "flex items-center space-x-2 px-3 py-2 rounded text-sm transition-colors #{request.path == pd_root_path ? 'bg-primary/10 text-primary font-medium' : 'text-gray-500 hover:text-navy hover:bg-gray-50'}" do %>
          <svg class="w-4 h-4" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
          <span>홈</span>
        <% end %>
        <%= link_to edit_pd_profile_path, class: "flex items-center space-x-2 px-3 py-2 rounded text-sm transition-colors #{request.path.include?('/pd/profile') ? 'bg-primary/10 text-primary font-medium' : 'text-gray-500 hover:text-navy hover:bg-gray-50'}" do %>
          <svg class="w-4 h-4" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span>프로필</span>
        <% end %>
        <%= link_to pd_hero_images_path, class: "flex items-center space-x-2 px-3 py-2 rounded text-sm transition-colors #{request.path.include?('/pd/hero') ? 'bg-primary/10 text-primary font-medium' : 'text-gray-500 hover:text-navy hover:bg-gray-50'}" do %>
          <svg class="w-4 h-4" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <span>히어로 이미지</span>
        <% end %>
        <%= link_to pd_sns_accounts_path, class: "flex items-center space-x-2 px-3 py-2 rounded text-sm transition-colors #{request.path.include?('/pd/sns') ? 'bg-primary/10 text-primary font-medium' : 'text-gray-500 hover:text-navy hover:bg-gray-50'}" do %>
          <svg class="w-4 h-4" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          <span>SNS 계정</span>
        <% end %>
        <%= link_to pd_scheduled_posts_path, class: "flex items-center space-x-2 px-3 py-2 rounded text-sm transition-colors #{request.path.include?('/pd/scheduled') ? 'bg-primary/10 text-primary font-medium' : 'text-gray-500 hover:text-navy hover:bg-gray-50'}" do %>
          <svg class="w-4 h-4" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <span>예약 발행</span>
        <% end %>
        <%= link_to pd_kanban_projects_path, class: "flex items-center space-x-2 px-3 py-2 rounded text-sm transition-colors #{request.path.include?('/pd/kanban') ? 'bg-primary/10 text-primary font-medium' : 'text-gray-500 hover:text-navy hover:bg-gray-50'}" do %>
          <svg class="w-4 h-4" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          <span>칸반 보드</span>
        <% end %>
        <%= link_to pd_leads_path, class: "flex items-center space-x-2 px-3 py-2 rounded text-sm transition-colors #{request.path.include?('/pd/leads') ? 'bg-primary/10 text-primary font-medium' : 'text-gray-500 hover:text-navy hover:bg-gray-50'}" do %>
          <svg class="w-4 h-4" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <span>뉴스레터 구독</span>
        <% end %>

        <div class="pt-4 mt-4 border-t">
          <%= link_to destroy_admin_user_session_path, data: { turbo_method: :delete },
              class: "flex items-center space-x-2 px-3 py-2 rounded text-sm text-gray-400 hover:text-red-500 hover:bg-red-50 transition-colors" do %>
            <svg class="w-4 h-4" stroke="currentColor" fill="none" viewBox="0 0 24 24" stroke-width="2">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
              <polyline points="16 17 21 12 16 7"/>
              <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            <span>로그아웃</span>
          <% end %>
        </div>
      </nav>
    </aside>

    <!-- 메인 영역 -->
    <div class="ml-60 flex-1 flex flex-col min-h-screen">
      <header class="bg-white border-b px-6 py-3 flex items-center justify-between sticky top-0 z-30">
        <h1 class="text-sm font-semibold text-gray-700"><%= content_for?(:title) ? yield(:title) : "대시보드" %></h1>
        <div class="flex items-center space-x-3">
          <%= link_to root_path, target: "_blank", class: "text-xs text-gray-500 hover:text-primary" do %>
            공개 사이트 보기
          <% end %>
          <%= link_to admin_root_path, class: "text-xs text-gray-500 hover:text-primary" do %>
            Admin
          <% end %>
        </div>
      </header>

      <% if flash[:notice] %>
        <div class="bg-green-50 border-l-4 border-green-500 text-green-800 px-6 py-3 text-sm"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="bg-red-50 border-l-4 border-red-500 text-red-800 px-6 py-3 text-sm"><%= flash[:alert] %></div>
      <% end %>

      <main class="flex-1 p-6">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
