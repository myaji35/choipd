<% content_for :title, "페이스북 페이지 선택 — #{@member.name}" %>

<div class="impd-wrap" style="max-width: 760px; margin: 0 auto; padding: 40px;">
  <header style="margin-bottom: 32px;">
    <p class="impd-label-muted">FACEBOOK PAGE · /<%= @member.slug %></p>
    <h1 class="impd-display" style="font-size: 40px; margin-top: 12px;">연결할 페이지 선택</h1>
    <p style="margin-top: 12px; color: var(--impd-ink2); font-size: 14px; line-height: 1.7;">
      회원님이 관리하는 페이지 중 이 계정에 연결할 페이지를 선택해 주세요.
    </p>
  </header>

  <% if @pages.any? %>
    <%= form_with url: slug_admin_facebook_save_page_path(slug: @member.slug), method: :post do |form| %>
      <fieldset style="margin: 0; padding: 0; border: 0; display: grid; gap: 12px;">
        <legend class="impd-label" style="margin-bottom: 14px;">관리 중인 페이지</legend>
        <% @pages.each_with_index do |page, index| %>
          <label class="facebook-page-option">
            <%= radio_button_tag :page_id, page[:id], index.zero?, required: true %>
            <span>
              <strong style="display: block; color: var(--impd-ink); font-size: 16px;"><%= page[:name] %></strong>
              <span class="impd-label-muted" style="display: block; margin-top: 5px;">PAGE ID · <%= page[:id] %></span>
            </span>
          </label>
        <% end %>
      </fieldset>
      <%= form.submit "선택한 페이지 연결", class: "impd-btn impd-btn-primary", style: "margin-top: 24px;" %>
    <% end %>
  <% else %>
    <section class="impd-card" style="padding: 36px 24px; text-align: center;">
      <h2 class="impd-display" style="font-size: 22px;">관리 중인 페이스북 페이지가 없습니다</h2>
      <p style="margin-top: 10px; color: var(--impd-ink2); font-size: 14px; line-height: 1.7;">
        페이스북에서 페이지 권한을 확인한 뒤 다시 연결해 주세요.
      </p>
      <%= link_to "SNS 계정으로 돌아가기", slug_admin_sns_accounts_path(slug: @member.slug), class: "impd-btn impd-btn-secondary", style: "margin-top: 22px;" %>
    </section>
  <% end %>
</div>

<style>
  .facebook-page-option { display: flex; align-items: center; gap: 14px; border: 1px solid var(--impd-rule); background: var(--impd-card); padding: 18px; cursor: pointer; }
  .facebook-page-option:has(input:checked) { border-color: var(--impd-accent); }
  .facebook-page-option input { width: 17px; height: 17px; accent-color: var(--impd-accent); }
  @media (max-width: 640px) {
    .impd-wrap { padding: 28px 20px !important; }
  }
</style>
