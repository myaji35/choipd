<% content_for :title, "예약 발행 — #{@member.name}" %>

<div class="scheduled-posts-wrap" style="max-width: 1120px; margin: 0 auto; padding: 40px;">
  <header style="margin-bottom: 32px;">
    <p class="impd-label-muted">SCHEDULED POSTS · /<%= @member.slug %></p>
    <h1 class="impd-display" style="font-size: 44px; margin-top: 12px;">예약 발행</h1>
    <p style="margin-top: 12px; color: var(--impd-ink2); font-size: 14px; line-height: 1.7;">
      페이스북 페이지에 게시할 내용을 원하는 시각에 자동으로 발행합니다.
    </p>
  </header>

  <div class="scheduled-posts-layout" style="display: grid; grid-template-columns: 380px minmax(0, 1fr); gap: 32px; align-items: start;">
    <section class="impd-card" style="padding: 24px;">
      <div class="impd-section-header" style="margin-bottom: 20px;">
        <span class="impd-label">§01</span>
        <h2 class="impd-display" style="font-size: 24px;">새 예약</h2>
      </div>

      <% if @account %>
        <%= form_with scope: :sns_scheduled_post, url: slug_admin_scheduled_posts_path(slug: @member.slug) do |form| %>
          <div class="scheduled-field">
            <%= form.label :message, "발행 내용" %>
            <%= form.text_area :message, class: "scheduled-input", rows: 8, required: true, placeholder: "페이스북에 발행할 내용을 입력하세요" %>
          </div>
          <div class="scheduled-field">
            <%= form.label :scheduled_at, "예약 시각" %>
            <%= form.datetime_local_field :scheduled_at, class: "scheduled-input", required: true, min: Time.current.strftime("%Y-%m-%dT%H:%M") %>
          </div>
          <%= form.submit "발행 예약", class: "impd-btn impd-btn-primary", style: "width: 100%; justify-content: center; margin-top: 20px;" %>
        <% end %>
      <% else %>
        <p style="color: var(--impd-ink2); font-size: 14px; line-height: 1.7;">예약 발행을 사용하려면 먼저 페이스북 페이지를 연결해주세요.</p>
        <%= link_to "먼저 페이스북 연결", slug_admin_sns_accounts_path(slug: @member.slug), class: "impd-btn impd-btn-primary", style: "width: 100%; justify-content: center; margin-top: 18px;" %>
      <% end %>
    </section>

    <section>
      <div class="impd-section-header">
        <span class="impd-label">§02</span>
        <h2 class="impd-display" style="font-size: 24px; flex: 1;">예약 목록</h2>
        <span class="impd-label-muted"><%= @scheduled.size %>건</span>
      </div>

      <% if @scheduled.any? %>
        <div style="display: grid; gap: 14px;">
          <% @scheduled.each do |post| %>
            <% status_label = { "scheduled" => "예약", "published" => "발행됨", "failed" => "실패", "draft" => "초안" }.fetch(post.status, post.status) %>
            <article class="impd-card" style="padding: 20px;">
              <div style="display: flex; justify-content: space-between; gap: 20px; align-items: flex-start;">
                <div style="min-width: 0; flex: 1;">
                  <p style="color: var(--impd-ink); font-size: 14px; line-height: 1.65; overflow-wrap: anywhere;"><%= truncate(post.message, length: 140) %></p>
                  <div style="display: flex; flex-wrap: wrap; gap: 10px; align-items: center; margin-top: 12px;">
                    <span class="scheduled-status is-<%= post.status %>"><%= status_label %></span>
                    <time class="impd-label-muted" datetime="<%= post.scheduled_at&.iso8601 %>"><%= post.scheduled_at&.strftime("%Y.%m.%d %H:%M") %></time>
                  </div>
                </div>
                <% if post.status_scheduled? %>
                  <%= button_to "취소", slug_admin_scheduled_post_path(slug: @member.slug, id: post), method: :delete,
                        form: { data: { turbo_confirm: "이 예약을 취소하시겠습니까?" } },
                        class: "impd-btn impd-btn-secondary", style: "height: 36px; padding: 0 12px; font-size: 12px; color: var(--impd-accent-2); border-color: var(--impd-accent-2);" %>
                <% end %>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="impd-card" style="padding: 48px 24px; text-align: center;">
          <p style="color: var(--impd-ink2); font-size: 14px;">아직 예약한 포스트가 없습니다.</p>
        </div>
      <% end %>
    </section>
  </div>
</div>

<style>
  .scheduled-field { margin-top: 16px; }
  .scheduled-field:first-child { margin-top: 0; }
  .scheduled-field label { display: block; margin-bottom: 6px; color: var(--impd-muted); font-size: 13px; font-weight: 600; }
  .scheduled-input { width: 100%; border: 1px solid var(--impd-rule); background: var(--impd-paper); padding: 10px 12px; color: var(--impd-ink); font-family: var(--impd-font-sans); font-size: 14px; }
  .scheduled-status { border: 1px solid var(--impd-rule); padding: 3px 7px; color: var(--impd-muted); font-size: 12px; font-weight: 600; }
  .scheduled-status.is-scheduled { border-color: var(--impd-accent); color: var(--impd-accent); }
  .scheduled-status.is-published { border-color: var(--impd-ink2); color: var(--impd-ink2); }
  .scheduled-status.is-failed { border-color: var(--impd-accent-2); color: var(--impd-accent-2); }
  @media (max-width: 820px) {
    .scheduled-posts-wrap { padding: 28px 20px !important; }
    .scheduled-posts-layout { grid-template-columns: 1fr !important; }
  }
</style>
