<% display_src = photo.display_url %>
<% thumb_src   = photo.thumbnail_url || display_src %>

<figure data-controller="member-photo-card"
        data-member-photo-card-delete-url-value="<%= slug_admin_photo_path(slug: member.slug, id: photo.id, format: :json) %>"
        data-member-photo-card-csrf-value="<%= form_authenticity_token %>"
        data-member-photo-card-id-value="<%= photo.id %>"
        style="position: relative; margin: 0; aspect-ratio: 1/1; overflow: hidden; background: var(--impd-ink); border: 1px solid var(--impd-rule);">
  <% if photo.image.attached? %>
    <% if photo.video? %>
      <video src="<%= display_src %>"
             style="width: 100%; height: 100%; object-fit: cover; display: block; background: #000;"
             preload="metadata" muted playsinline></video>
      <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; pointer-events: none;">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="rgba(255,255,255,0.9)" stroke="none" aria-hidden="true">
          <polygon points="8,5 19,12 8,19"/>
        </svg>
      </div>
    <% else %>
      <img src="<%= thumb_src %>"
           data-fallback="<%= display_src %>"
           onerror="if(this.dataset.fallback && this.src !== this.dataset.fallback){this.src=this.dataset.fallback;this.dataset.fallback='';}else{this.style.display='none';}"
           alt="<%= photo.caption %>"
           style="width: 100%; height: 100%; object-fit: cover; display: block;" loading="lazy">
    <% end %>
  <% end %>

  <%# 카테고리 배지 %>
  <figcaption style="position: absolute; top: 0; left: 0; background: var(--impd-paper); color: var(--impd-ink); font-family: var(--impd-font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 1.2px; padding: 3px 8px; border-right: 1px solid var(--impd-ink); border-bottom: 1px solid var(--impd-ink);">
    <%= photo.category %>
  </figcaption>

  <%# 삭제 버튼 — 호버 시 노출 %>
  <button type="button" data-action="click->member-photo-card#destroy"
          aria-label="삭제"
          style="position: absolute; top: 6px; right: 6px; width: 26px; height: 26px; background: rgba(15,13,11,0.85); color: var(--impd-paper); border: 0; cursor: pointer; font-size: 14px; line-height: 1; display: flex; align-items: center; justify-content: center;">
    ×
  </button>
</figure>
