<% doc_categories = MemberDocument::CATEGORIES %>
<div style="border: 2px dashed var(--impd-ink); padding: 48px 24px; text-align: center; background: var(--impd-card);"
     data-controller="member-doc-uploader"
     data-member-doc-uploader-create-url-value="<%= slug_admin_documents_path(slug: member.slug, format: :json) %>"
     data-member-doc-uploader-csrf-value="<%= form_authenticity_token %>"
     data-action="dragover->member-doc-uploader#dragover dragleave->member-doc-uploader#dragleave drop->member-doc-uploader#drop">
  <!-- Feather upload-cloud icon -->
  <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="var(--impd-ink)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 12px;" aria-hidden="true">
    <polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/>
    <path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/><polyline points="16 16 12 12 8 16"/>
  </svg>
  <p style="font-family: var(--impd-font-display); font-size: 22px; font-weight: 800;">파일을 여기에 끌어다 놓으세요</p>
  <p style="font-size: 14px; color: var(--impd-muted); margin-top: 8px;">또는 클릭해서 선택 — 여러 개 한 번에 OK</p>
  <label style="margin-top: 20px; display: inline-block; cursor: pointer;">
    <span class="impd-btn impd-btn-primary">파일 선택</span>
    <input type="file" multiple class="hidden" style="display:none;" accept=".md,.markdown,.txt,.pdf"
           data-member-doc-uploader-target="fileInput"
           data-action="change->member-doc-uploader#fileSelected">
  </label>
  <input type="hidden" data-member-doc-uploader-target="title" value="">
  <select data-member-doc-uploader-target="category" style="display:none;"><option value="other">other</option></select>
  <p style="font-size: 11px; color: var(--impd-muted); margin-top: 12px;">파일명에 <strong>이력 / 수료 / 후기 / 강의 / 언론 / 작품</strong> 키워드가 있으면 자동 분류됩니다.</p>

  <div data-member-doc-uploader-target="progress" style="display: none; margin-top: 20px;">
    <div style="background: var(--impd-rule); height: 6px; overflow: hidden;">
      <div data-member-doc-uploader-target="progressBar" style="background: var(--impd-accent); height: 100%; width: 0%; transition: width 0.2s ease;"></div>
    </div>
  </div>

  <div data-member-doc-uploader-target="error" style="display: none; margin-top: 16px; padding: 12px; background: rgba(255,90,31,.1); color: var(--impd-accent-2); font-size: 13px; text-align: left; line-height: 1.5;"></div>
  <p data-member-doc-uploader-target="status" class="impd-label-muted" style="margin-top: 16px; min-height: 16px; font-family: var(--impd-font-mono);"></p>
</div>

<!-- 업로드된 자료 리스트 -->
<% if member.member_documents.any? %>
  <div style="margin-top: 32px;">
    <p class="impd-label-muted">업로드된 자료 (<%= member.member_documents.count %>)</p>
    <table style="width: 100%; margin-top: 12px; border-collapse: collapse;">
      <thead style="border-bottom: 1px solid var(--impd-ink);">
        <tr>
          <th style="text-align: left; padding: 8px 0;" class="impd-label-muted">파일명</th>
          <th style="text-align: left; padding: 8px 0;" class="impd-label-muted">종류</th>
          <th style="text-align: left; padding: 8px 0;" class="impd-label-muted">자동 인식</th>
          <th style="text-align: right; padding: 8px 0;" class="impd-label-muted">업로드</th>
          <th style="text-align: right; padding: 8px 0;" class="impd-label-muted">작업</th>
        </tr>
      </thead>
      <tbody>
        <% member.member_documents.order(uploaded_at: :desc).limit(10).each do |d| %>
          <tr style="border-bottom: 1px solid var(--impd-rule);"
              data-controller="member-doc-row"
              data-member-doc-row-delete-url-value="<%= slug_admin_document_path(slug: member.slug, id: d.id, format: :json) %>"
              data-member-doc-row-reparse-url-value="<%= reparse_slug_admin_document_path(slug: member.slug, id: d.id, format: :json) %>"
              data-member-doc-row-update-url-value="<%= slug_admin_document_path(slug: member.slug, id: d.id, format: :json) %>"
              data-member-doc-row-csrf-value="<%= form_authenticity_token %>"
              data-member-doc-row-filename-value="<%= d.filename %>">
            <td style="padding: 10px 0; font-family: var(--impd-font-mono); font-size: 13px;"><%= d.filename %></td>
            <td style="padding: 10px 0;">
              <select data-action="change->member-doc-row#updateCategory"
                      style="font-size: 12px; padding: 2px 6px; border: 1px solid var(--impd-rule); background: var(--impd-paper);">
                <% doc_categories.each do |cat| %>
                  <option value="<%= cat %>" <%= "selected" if d.category == cat %>><%= cat %></option>
                <% end %>
              </select>
            </td>
            <td style="padding: 10px 0; font-size: 12px; color: var(--impd-muted);">
              <% if d.extracted_skills_count.to_i > 0 %>달란트 <%= d.extracted_skills_count %>개<% else %>—<% end %>
            </td>
            <td style="padding: 10px 0; text-align: right; font-family: var(--impd-font-mono); font-size: 11px; color: var(--impd-muted);">
              <%= d.uploaded_at&.strftime("%y.%m.%d %H:%M") || "—" %>
            </td>
            <td style="padding: 10px 0; text-align: right; white-space: nowrap;">
              <button type="button" data-action="click->member-doc-row#reparse"
                      style="background: transparent; border: 1px solid var(--impd-rule); padding: 4px 10px; font-size: 11px; cursor: pointer; margin-right: 4px;">
                ↻ 재추출
              </button>
              <button type="button" data-action="click->member-doc-row#destroy"
                      style="background: transparent; border: 1px solid var(--impd-accent-2); color: var(--impd-accent-2); padding: 4px 10px; font-size: 11px; cursor: pointer;">
                삭제
              </button>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <!-- F14 빈 상태 -->
  <div style="margin-top: 32px; padding: 32px; border: 1px solid var(--impd-rule); background: var(--impd-card); text-align: center;">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--impd-soft-muted)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 12px;">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
    </svg>
    <p style="font-family: var(--impd-font-display); font-size: 18px; font-weight: 800;">첫 파일을 올려 보세요</p>
    <p style="font-size: 13px; color: var(--impd-muted); margin-top: 6px;">이력서 · 포트폴리오 · 수료증 무엇이든 OK. imPD가 달란트를 자동 추출합니다.</p>
  </div>
<% end %>
