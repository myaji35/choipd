<%# 사진·영상 전용 드롭존 — 에디토리얼 톤에 맞는 미니멀 스타일 %>
<div data-controller="member-photo-uploader"
     data-member-photo-uploader-create-url-value="<%= slug_admin_photos_path(slug: member.slug, format: :json) %>"
     data-member-photo-uploader-csrf-value="<%= form_authenticity_token %>"
     data-action="dragover->member-photo-uploader#dragover dragleave->member-photo-uploader#dragleave drop->member-photo-uploader#drop"
     style="position: relative; border: 1px dashed var(--impd-ink); padding: 36px 28px; background: var(--impd-paper); transition: background 150ms ease;">

  <%# 격자 장식 (에디토리얼 시그니처) %>
  <div aria-hidden="true" style="position: absolute; inset: 0; background-image: linear-gradient(to right, var(--impd-rule) 1px, transparent 1px); background-size: 80px 100%; pointer-events: none; opacity: 0.4;"></div>

  <div style="position: relative; display: grid; grid-template-columns: auto 1fr auto; gap: 24px; align-items: center;">
    <%# 아이콘 %>
    <div style="width: 56px; height: 56px; border: 1px solid var(--impd-ink); background: var(--impd-card); display: flex; align-items: center; justify-content: center;">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--impd-ink)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
        <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
        <circle cx="12" cy="13" r="4"/>
      </svg>
    </div>

    <%# 중앙 카피 %>
    <div>
      <p style="font-family: var(--impd-font-display); font-size: 22px; font-weight: 800; letter-spacing: -0.4px; line-height: 1.1;">
        여기에 <span style="font-family: var(--impd-font-serif); font-style: italic; color: var(--impd-accent-2);">올려만</span> 주세요.
      </p>
      <p style="font-size: 12px; color: var(--impd-muted); margin-top: 6px; font-family: var(--impd-font-mono);">
        JPG · PNG · WebP · HEIC · GIF · AVIF · BMP / MP4 · MOV · WebM
      </p>
    </div>

    <%# 버튼 스택 %>
    <div style="display: flex; flex-direction: column; gap: 6px; min-width: 144px;">
      <label style="cursor: pointer;">
        <input type="file" accept="image/*,video/*" capture="environment" multiple style="display:none;"
               data-member-photo-uploader-target="cameraInput"
               data-action="change->member-photo-uploader#fileSelected">
        <span class="impd-btn impd-btn-primary" style="width: 100%; justify-content: center; height: 40px; font-size: 13px;">
          카메라
        </span>
      </label>
      <label style="cursor: pointer;">
        <input type="file" accept="image/*,video/*" multiple style="display:none;"
               data-member-photo-uploader-target="galleryInput"
               data-action="change->member-photo-uploader#fileSelected">
        <span class="impd-btn impd-btn-secondary" style="width: 100%; justify-content: center; height: 40px; font-size: 13px;">
          갤러리
        </span>
      </label>
    </div>
  </div>

  <%# 하단: 분류 셀렉트 + 진행 %>
  <div style="position: relative; display: flex; align-items: center; gap: 14px; margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--impd-rule);">
    <span class="impd-label-muted">분류</span>
    <select data-member-photo-uploader-target="category"
            style="font-size: 12px; padding: 4px 10px; border: 1px solid var(--impd-ink); background: var(--impd-card); font-family: var(--impd-font-mono);">
      <% categories.each do |cat| %>
        <option value="<%= cat %>"><%= cat %></option>
      <% end %>
    </select>
    <span style="flex: 1; font-size: 11px; color: var(--impd-muted); font-family: var(--impd-font-mono);">이미지 ≤ 25MB · 영상 ≤ 100MB</span>
  </div>

  <div data-member-photo-uploader-target="progress" style="display: none; margin-top: 14px;">
    <div style="background: var(--impd-rule); height: 4px;">
      <div data-member-photo-uploader-target="progressBar" style="background: var(--impd-accent); height: 100%; width: 0%; transition: width 0.2s ease;"></div>
    </div>
  </div>

  <div data-member-photo-uploader-target="error"
       style="display: none; margin-top: 14px; padding: 10px 12px; background: rgba(255,90,31,.08); border-left: 2px solid var(--impd-accent-2); color: var(--impd-accent-2); font-size: 12px; line-height: 1.5; white-space: pre-wrap; font-family: var(--impd-font-mono);"></div>
  <p data-member-photo-uploader-target="status" class="impd-label-muted" style="margin-top: 10px; min-height: 14px; font-family: var(--impd-font-mono);"></p>
</div>
