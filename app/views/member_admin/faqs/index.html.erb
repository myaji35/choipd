<% content_for :title, "자주 묻는 질문(FAQ) — #{@member.name}" %>

<div class="impd-wrap" style="max-width: 1120px; margin: 0 auto; padding: 40px;">
  <header style="margin-bottom: 32px;">
    <p class="impd-label-muted">FAQ · /<%= @member.slug %></p>
    <h1 class="impd-display" style="font-size: 44px; margin-top: 12px;">자주 묻는 질문(FAQ)</h1>
    <p style="margin-top: 12px; color: var(--impd-ink2); font-size: 14px; line-height: 1.7; word-break: keep-all;">
      공개 페이지에 FAQ로 표시되고, 검색·AI 노출(구조화 데이터)에 활용됩니다. 3~5개 권장.
    </p>
  </header>

  <div class="faqs-layout" style="display: grid; grid-template-columns: minmax(0, 1fr) 380px; gap: 32px; align-items: start;">
    <section>
      <div class="impd-section-header">
        <span class="impd-label">§01</span>
        <h2 class="impd-display" style="font-size: 24px; flex: 1;">등록된 FAQ</h2>
        <span class="impd-label-muted"><%= @faqs.size %>개</span>
      </div>

      <% if @faqs.any? %>
        <div style="display: grid; gap: 14px;">
          <% @faqs.each do |faq| %>
            <article class="impd-card" style="padding: 20px;">
              <div style="display: flex; justify-content: space-between; gap: 20px; align-items: flex-start;">
                <div style="min-width: 0;">
                  <div style="display: flex; flex-wrap: wrap; gap: 8px; align-items: center;">
                    <h3 style="font-size: 17px; line-height: 1.5; word-break: keep-all;"><%= faq.question %></h3>
                    <span style="border: 1px solid <%= faq.is_published.to_i == 1 ? 'var(--impd-accent)' : 'var(--impd-rule)' %>; color: <%= faq.is_published.to_i == 1 ? 'var(--impd-accent)' : 'var(--impd-muted)' %>; padding: 3px 7px; font-size: 12px; font-weight: 600; white-space: nowrap;">
                      <%= faq.is_published.to_i == 1 ? "발행" : "미발행" %>
                    </span>
                  </div>
                  <p style="margin-top: 8px; color: var(--impd-ink2); font-size: 14px; line-height: 1.7; overflow-wrap: anywhere;"><%= truncate(faq.answer, length: 120) %></p>
                </div>
                <%= button_to "삭제", slug_admin_faq_path(slug: @member.slug, id: faq), method: :delete,
                      form: { data: { turbo_confirm: "이 FAQ를 삭제하시겠습니까?" } },
                      class: "impd-btn impd-btn-secondary", style: "height: 36px; padding: 0 12px; font-size: 12px; color: var(--impd-accent-2); border-color: var(--impd-accent-2);" %>
              </div>

              <details style="margin-top: 16px; border-top: 1px solid var(--impd-rule); padding-top: 14px;">
                <summary style="cursor: pointer; color: var(--impd-accent); font-size: 13px; font-weight: 600;">수정</summary>
                <%= form_with model: faq, url: slug_admin_faq_path(slug: @member.slug, id: faq), method: :patch, style: "margin-top: 18px;" do |form| %>
                  <%= render "faq_fields", form: form, submit_label: "변경사항 저장" %>
                <% end %>
              </details>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="impd-card" style="padding: 40px 24px; text-align: center;">
          <p style="font-size: 14px; color: var(--impd-ink2); line-height: 1.7; word-break: keep-all;">아직 등록한 FAQ가 없습니다. 자주 받는 질문과 답변을 추가해 주세요.</p>
        </div>
      <% end %>
    </section>

    <section class="impd-card" style="position: sticky; top: 88px;">
      <div class="impd-section-header" style="margin-bottom: 20px;">
        <span class="impd-label">§02</span>
        <h2 class="impd-display" style="font-size: 24px;">신규 등록</h2>
      </div>
      <%= form_with model: MemberFaq.new, url: slug_admin_faqs_path(slug: @member.slug) do |form| %>
        <%= render "faq_fields", form: form, submit_label: "FAQ 저장" %>
      <% end %>
    </section>
  </div>
</div>

<style>
  .faq-field { margin-top: 15px; }
  .faq-field:first-child { margin-top: 0; }
  .faq-field label { display: block; margin-bottom: 6px; color: var(--impd-muted); font-size: 13px; font-weight: 600; }
  .faq-input { width: 100%; border: 1px solid var(--impd-rule); background: var(--impd-card); padding: 10px 12px; color: var(--impd-ink); font-family: var(--impd-font-sans); font-size: 14px; line-height: 1.6; }
  @media (max-width: 820px) {
    .impd-wrap { padding: 28px 20px !important; }
    .faqs-layout { grid-template-columns: 1fr !important; }
    .faqs-layout > section:last-child { position: static !important; }
  }
</style>
