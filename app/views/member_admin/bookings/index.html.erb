<% content_for :title, "예약 링크 관리 — #{@member.name}" %>

<div class="impd-wrap" style="max-width: 1120px; margin: 0 auto; padding: 40px;">
  <header style="margin-bottom: 32px;">
    <p class="impd-label-muted">BOOKINGS · /<%= @member.slug %></p>
    <h1 class="impd-display" style="font-size: 44px; margin-top: 12px;">예약 링크 관리</h1>
    <p style="margin-top: 12px; color: var(--impd-ink2); font-size: 14px; line-height: 1.7;">
      여기 등록한 예약 링크가 공개 페이지의 '예약하기' 버튼으로 노출됩니다. (네이버 예약, 캘린들리, 카카오 예약 등)
    </p>
  </header>

  <div class="bookings-layout" style="display: grid; grid-template-columns: minmax(0, 1fr) 380px; gap: 32px; align-items: start;">
    <section>
      <div class="impd-section-header">
        <span class="impd-label">§01</span>
        <h2 class="impd-display" style="font-size: 24px; flex: 1;">등록된 예약 링크</h2>
        <span class="impd-label-muted"><%= @bookings.size %>개</span>
      </div>

      <% if @bookings.any? %>
        <div style="display: grid; gap: 14px;">
          <% @bookings.each do |booking| %>
            <article class="impd-card" style="padding: 20px;">
              <div style="display: flex; justify-content: space-between; gap: 20px; align-items: flex-start;">
                <div style="min-width: 0;">
                  <h3 style="font-size: 17px; line-height: 1.45;"><%= booking.booking_type.presence || "예약 링크" %></h3>
                  <%= link_to booking.external_url, booking.external_url, target: "_blank", rel: "noopener", style: "display: block; margin-top: 8px; color: var(--impd-accent); font-size: 13px; line-height: 1.5; overflow-wrap: anywhere;" %>
                  <% if booking.description.present? %>
                    <p style="margin-top: 8px; color: var(--impd-ink2); font-size: 14px; line-height: 1.6;"><%= booking.description %></p>
                  <% end %>
                </div>
                <%= button_to "삭제", slug_admin_booking_path(slug: @member.slug, id: booking), method: :delete,
                      form: { data: { turbo_confirm: "이 예약 링크를 삭제하시겠습니까?" } },
                      class: "impd-btn impd-btn-secondary", style: "height: 36px; padding: 0 12px; font-size: 12px; color: var(--impd-accent-2); border-color: var(--impd-accent-2);" %>
              </div>

              <details style="margin-top: 16px; border-top: 1px solid var(--impd-rule); padding-top: 14px;">
                <summary style="cursor: pointer; color: var(--impd-accent); font-size: 13px; font-weight: 600;">수정</summary>
                <%= form_with model: booking, url: slug_admin_booking_path(slug: @member.slug, id: booking), method: :patch, class: "booking-form", style: "margin-top: 18px;" do |form| %>
                  <%= render "booking_fields", form: form, submit_label: "변경사항 저장" %>
                <% end %>
              </details>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="impd-card" style="padding: 40px 24px; text-align: center;">
          <p style="font-size: 14px; color: var(--impd-ink2); line-height: 1.7;">아직 등록한 예약 링크가 없습니다. 첫 링크를 추가하면 공개 페이지에 바로 노출됩니다.</p>
        </div>
      <% end %>
    </section>

    <section class="impd-card" style="position: sticky; top: 88px;">
      <div class="impd-section-header" style="margin-bottom: 20px;">
        <span class="impd-label">§02</span>
        <h2 class="impd-display" style="font-size: 24px;">신규 등록</h2>
      </div>
      <%= form_with model: MemberBooking.new, url: slug_admin_bookings_path(slug: @member.slug), class: "booking-form" do |form| %>
        <%= render "booking_fields", form: form, submit_label: "예약 링크 저장" %>
      <% end %>
    </section>
  </div>
</div>

<style>
  .booking-field { margin-top: 15px; }
  .booking-field:first-child { margin-top: 0; }
  .booking-field label { display: block; margin-bottom: 6px; color: var(--impd-muted); font-size: 13px; font-weight: 600; }
  .booking-input { width: 100%; border: 1px solid var(--impd-rule); background: #fff; padding: 10px 12px; color: var(--impd-ink); font-family: var(--impd-font-sans); font-size: 14px; line-height: 1.5; }
  @media (max-width: 820px) {
    .impd-wrap { padding: 28px 20px !important; }
    .bookings-layout { grid-template-columns: 1fr !important; }
    .bookings-layout > section:last-child { position: static !important; }
  }
</style>
