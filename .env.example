# choi-pd-rails 환경변수 명세
# 사용: cp .env.example .env 후 실제 값 채우기 (.env는 .gitignore됨)

# ── Rails 기본 ──
RAILS_ENV=development
RAILS_MASTER_KEY=                  # config/master.key 값 (production 배포 시 필수)
SECRET_KEY_BASE=                   # bin/rails secret 으로 생성

# ── Database ──
# 개발: SQLite (storage/development.sqlite3)
# 프로덕션: SQLite (Kamal 볼륨 /rails/storage)
DATABASE_URL=sqlite3:storage/development.sqlite3

# ── 인증 (JWT/Encryption) ──
JWT_SECRET=                        # API JWT 발급용 (32자 이상)
ENCRYPTION_KEY=                    # Active Record encrypted attributes (32자 이상)

# ── 외부 서비스 ──
# Google Cloud Storage (이미지/파일 저장)
GCS_PROJECT_ID=
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=    # 서비스 계정 JSON 경로

# OpenAI / Anthropic (AI 기능 - Phase 3)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 결제 - TossPayments (Phase 1+)
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# SNS API 키 (Phase 1)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=

# ── Kamal 배포 ──
KAMAL_REGISTRY_PASSWORD=           # GHCR PAT (~/.zshrc에 export 권장)

# ── 모니터링 (선택) ──
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=

# ── 개발 편의 ──
RAILS_LOG_LEVEL=debug
WEB_CONCURRENCY=2
RAILS_MAX_THREADS=5

# ── Townin 연동 (ISS-321) ──
# imPD 회원을 Townin 파트너로 승급할 때 Townin 백엔드 호출에 사용.
# TOWNIN_API_KEY = Townin 백엔드의 CHOPD_API_KEY env 값 (동일 시크릿)
TOWNIN_API_URL=https://api.townin.net/api/v1
TOWNIN_API_KEY=
